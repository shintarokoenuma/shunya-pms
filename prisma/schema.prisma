  shootStartTime  String?  @map("shoot_start_time") @db.VarChar(20)
  shootEndTime    String?  @map("shoot_end_time") @db.VarChar(20)
  location        String?  @db.VarChar(255)
  locationAddress String?  @map("location_address") @db.Text

  // スタッフ
  photographerName String? @map("photographer_name") @db.VarChar(255)
  stylistName      String? @map("stylist_name") @db.VarChar(255)
  hairMakeupName   String? @map("hair_makeup_name") @db.VarChar(255)
