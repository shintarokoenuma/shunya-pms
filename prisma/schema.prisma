// =====================================================
// データインポート・エクスポート
// =====================================================

/// CSVインポートジョブ
/// マスターデータの一括取り込み
model CsvImportJob {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  // ジョブ情報
  jobNumber String @map("job_number") @db.VarChar(50)

  // インポート対象
  targetEntity ImportTargetEntity @map("target_entity")

  // ファイル情報
  fileName String  @map("file_name") @db.VarChar(255)
  fileUrl  String  @map("file_url") @db.VarChar(500)
  fileSize BigInt? @map("file_size")

  // 設定
  hasHeaderRow Boolean @default(true) @map("has_header_row")
  delimiter    String  @default(",") @db.VarChar(5)
  encoding     String  @default("UTF-8") @db.VarChar(20)

  // マッピング
  columnMapping Json @map("column_mapping")
  // {csv_column: "db_field", ...}

  // 処理結果
  totalRows     Int? @map("total_rows")
  processedRows Int  @default(0) @map("processed_rows")
  successRows   Int  @default(0) @map("success_rows")
  errorRows     Int  @default(0) @map("error_rows")
  skippedRows   Int  @default(0) @map("skipped_rows")

  // エラー詳細
  errors Json?
  // [{row, column, message, data}, ...]

  // ステータス
  status JobStatus @default(PENDING)

  // 担当者
  initiatedByUserId String? @map("initiated_by_user_id")

  // タイムスタンプ
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@unique([companyId, jobNumber])
  @@index([companyId, status])
  @@index([companyId, targetEntity])
  @@map("csv_import_jobs")
}

enum ImportTargetEntity {
  CLIENTS // クライアントマスター
  BRANDS // ブランドマスター
  SUPPLIERS // 仕入先マスター
  FACTORIES // 工場マスター
  CONTRACTORS // 外注先マスター
  BUYERS // バイヤーマスター
  DELIVERY_DESTINATIONS // 納品先マスター
  MATERIALS // 生地・副資材マスター
  PRODUCT_CATEGORIES // 商品カテゴリマスター
  EXPENSE_CATEGORIES // 諸経費マスター
  PRODUCTS // 品番（選択的）
  MODEL_CODES // モデルコード
  USERS // ユーザー
  EXCHANGE_RATES // 為替レート
  OTHER
}

enum JobStatus {
  PENDING // 待機中
  RUNNING // 実行中
  COMPLETED // 完了
  FAILED // 失敗
  CANCELLED // キャンセル
  PARTIAL // 一部成功
}

/// データエクスポートジョブ
model DataExportJob {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  // ジョブ情報
  jobNumber String @map("job_number") @db.VarChar(50)

  // エクスポート対象
  targetEntity String @map("target_entity") @db.VarChar(100)
  filters      Json?

  // 出力設定
  exportFormat ExportFormat @map("export_format")

  // 結果ファイル
  outputFileName String? @map("output_file_name") @db.VarChar(255)
  outputFileUrl  String? @map("output_file_url") @db.VarChar(500)
  outputFileSize BigInt? @map("output_file_size")

  // 統計
  totalRows Int? @map("total_rows")

  // ステータス
  status       JobStatus @default(PENDING)
  errorMessage String?   @map("error_message") @db.Text

  // 担当者
  initiatedByUserId String? @map("initiated_by_user_id")

  // 有効期限（ファイルダウンロード可能期限）
  expiresAt DateTime? @map("expires_at")

  // タイムスタンプ
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@unique([companyId, jobNumber])
  @@index([companyId, status])
  @@map("data_export_jobs")
}

enum ExportFormat {
  CSV
  EXCEL
  JSON
  PDF
  XML
}

// =====================================================
// 外部連携
// =====================================================

/// 外部サービス連携
/// Google Workspace、Resend、saagara V2、各種APIとの連携設定
model ExternalIntegration {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  // 連携サービス
  serviceName String                 @map("service_name") @db.VarChar(100)
  serviceType IntegrationServiceType @map("service_type")

  // 認証情報（暗号化推奨）
  authType             String? @map("auth_type") @db.VarChar(50) // oauth2 / api_key / basic_auth
  credentialsEncrypted String? @map("credentials_encrypted") @db.Text

  // 設定
  config Json

  // ステータス
  isActive Boolean           @default(true) @map("is_active")
  status   IntegrationStatus @default(NOT_CONFIGURED)

  // 接続情報
  lastConnectedAt  DateTime? @map("last_connected_at")
  lastSyncAt       DateTime? @map("last_sync_at")
  lastErrorAt      DateTime? @map("last_error_at")
  lastErrorMessage String?   @map("last_error_message") @db.Text

  // 同期統計
  totalSyncCount   Int @default(0) @map("total_sync_count")
  successSyncCount Int @default(0) @map("success_sync_count")
  failedSyncCount  Int @default(0) @map("failed_sync_count")

  // タイムスタンプ
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([companyId, serviceName])
  @@index([companyId, serviceType])
  @@index([companyId, isActive])
  @@map("external_integrations")
}

enum IntegrationServiceType {
  // Google Workspace
  GOOGLE_WORKSPACE
  GMAIL
  GOOGLE_DRIVE
  GOOGLE_CALENDAR
  GOOGLE_MEET
  GOOGLE_CHAT

  // メール送信
  RESEND
  SENDGRID

  // クラウドストレージ
  CLOUDFLARE_R2
  AWS_S3

  // AI
  ANTHROPIC_CLAUDE

  // チャット（海外）
  WECHAT
  LINE
  ZALO

  // ファイル共有
  GIGAFILE
  WETRANSFER

  // saagara V2
  SAAGARA_V2

  // 既存ツール
  TRANSCRIPTION_TOOL // 文字起こしツール
  CARE_LABEL_TOOL // 下げ札・品質表示ツール

  // 銀行・決済
  BANK_API
  STRIPE
  PAYPAL

  // 物流・通関
  SHIPPING_API
  CUSTOMS_API

  // BOJ・為替レート
  BOJ_API
  EXCHANGE_RATE_API

  // 監視・分析
  SENTRY
  ANALYTICS

  // その他
  CUSTOM_API
  OTHER
}

enum IntegrationStatus {
  NOT_CONFIGURED // 未設定
  CONFIGURED // 設定済み
  CONNECTED // 接続中
  DISCONNECTED // 切断
  ERROR // エラー
  SUSPENDED // 停止中
  EXPIRED // 期限切れ
}

/// Webhook ログ
model WebhookLog {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  // Webhook情報
  source    String @db.VarChar(255) // 送信元サービス
  eventType String @map("event_type") @db.VarChar(255)

  // リクエスト情報
  requestMethod  String @map("request_method") @db.VarChar(10)
  requestUrl     String @map("request_url") @db.VarChar(1000)
  requestHeaders Json?  @map("request_headers")
  requestBody    Json?  @map("request_body")

  // レスポンス
  responseStatus Int?    @map("response_status")
  responseBody   String? @map("response_body") @db.Text

  // 処理結果
  isProcessed     Boolean   @default(false) @map("is_processed")
  processedAt     DateTime? @map("processed_at")
  processingError String?   @map("processing_error") @db.Text

  // 関連エンティティ
  relatedEntityType String? @map("related_entity_type") @db.VarChar(50)
  relatedEntityId   String? @map("related_entity_id") @db.VarChar(255)

  // タイムスタンプ
  receivedAt DateTime @default(now()) @map("received_at")

  @@index([companyId, source])
  @@index([companyId, eventType])
  @@index([receivedAt])
  @@index([isProcessed])
  @@map("webhook_logs")
}
