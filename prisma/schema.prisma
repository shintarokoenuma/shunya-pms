/// メール統合管理
/// Gmail等から自動取得、AI振り分け対応
model EmailMessage {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  // メールID
  messageId String  @unique @map("message_id") @db.VarChar(500) // Gmail message ID
  threadId  String? @map("thread_id") @db.VarChar(500)

  // 送信者・受信者
  fromEmail    String  @map("from_email") @db.VarChar(255)
  fromName     String? @map("from_name") @db.VarChar(255)
  toEmails     Json    @map("to_emails") // [email1, email2]
  ccEmails     Json?   @map("cc_emails")
  bccEmails    Json?   @map("bcc_emails")
  replyToEmail String? @map("reply_to_email") @db.VarChar(255)

  // 件名・本文
  subject  String  @db.Text
  bodyText String? @map("body_text") @db.Text
  bodyHtml String? @map("body_html") @db.Text
  snippet  String? @db.Text // 短いプレビュー

  // メタデータ
  receivedAt DateTime  @map("received_at")
  sentAt     DateTime? @map("sent_at")

  // 方向
  direction EmailDirection

  // ステータス
  status      EmailStatus @default(UNPROCESSED)
  isRead      Boolean     @default(false) @map("is_read")
  isStarred   Boolean     @default(false) @map("is_starred")
  isArchived  Boolean     @default(false) @map("is_archived")
  isImportant Boolean     @default(false) @map("is_important")

  // 言語
  detectedLanguage Language? @map("detected_language")

  // AI 振り分け結果（仕様書H：3段階フィルタリング）
  aiClassification  EmailClassification? @map("ai_classification")
  aiConfidence      Decimal?             @map("ai_confidence") @db.Decimal(5, 4) // 0.0000 - 1.0000
  aiProcessingLevel Int?                 @map("ai_processing_level") // 1, 2, 3（処理レベル）
  aiSummary         String?              @map("ai_summary") @db.Text
  aiSuggestedAction String?              @map("ai_suggested_action") @db.Text
  aiKeywords        Json?                @map("ai_keywords")
  aiSentiment       String?              @map("ai_sentiment") @db.VarChar(50) // positive / neutral / negative / urgent

  // 関連エンティティ（自動紐付け）
  relatedEntities Json? @map("related_entities")
  // [{type: "product", id: "uuid", confidence: 0.95}, ...]

  // 担当者アサイン
  assignedToUserId String?   @map("assigned_to_user_id")
  assignedAt       DateTime? @map("assigned_at")

  // ラベル・タグ
  labels Json?

  // 添付ファイル情報
  hasAttachments  Boolean @default(false) @map("has_attachments")
  attachmentCount Int     @default(0) @map("attachment_count")

  // 返信状況
  isReplied      Boolean   @default(false) @map("is_replied")
  repliedAt      DateTime? @map("replied_at")
  replyMessageId String?   @map("reply_message_id") @db.VarChar(500)

  // AIによる返信下書き
  aiDraftReply            String?   @map("ai_draft_reply") @db.Text
  aiDraftReplyLanguage    Language? @map("ai_draft_reply_language")
  aiDraftReplyGeneratedAt DateTime? @map("ai_draft_reply_generated_at")

  // タイムスタンプ
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // リレーション
  attachments        EmailAttachment[]
  classificationLogs EmailClassificationLog[]

  @@index([companyId, status])
  @@index([companyId, direction])
  @@index([companyId, receivedAt])
  @@index([threadId])
  @@index([fromEmail])
  @@index([aiClassification])
  @@index([assignedToUserId])
  @@map("email_messages")
}

enum EmailDirection {
