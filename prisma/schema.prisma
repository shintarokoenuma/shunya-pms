/// コメント機能
/// 仕様書のあらゆるエンティティ（品番、見積もり、発注、仕様書等）にコメント可能
model Comment {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  // 多態的紐付け
  attachedToType String @map("attached_to_type") @db.VarChar(50)
  // product / inquiry / quotation / po / wo / so / specification / sample / invoice / etc.
  attachedToId   String @map("attached_to_id") @db.VarChar(255)

  // コメント本文
  content       String        @db.Text
  contentFormat CommentFormat @default(MARKDOWN) @map("content_format")

  // 親コメント（返信機能）
  parentCommentId String? @map("parent_comment_id")
  threadRootId    String? @map("thread_root_id") // スレッド全体のルート

  // 投稿者情報
  authorUserId     String   @map("author_user_id")
  authorRole       UserRole @map("author_role")
  isExternalAuthor Boolean  @default(false) @map("is_external_author") // 外部ユーザーからのコメント

  // コメントタイプ
  commentType CommentType @default(GENERAL) @map("comment_type")

  // 重要度
  priority CommentPriority @default(NORMAL)

  // 添付ファイル
  attachments Json?
  // [{fileName, fileUrl, fileType, fileSize}]

  // メンション情報
  mentionedUserIds Json? @map("mentioned_user_ids") // [user_id, ...]

  // 解決状態（質問・タスク的コメントの場合）
  isResolved       Boolean   @default(false) @map("is_resolved")
  resolvedByUserId String?   @map("resolved_by_user_id")
  resolvedAt       DateTime? @map("resolved_at")
  resolutionNotes  String?   @map("resolution_notes") @db.Text

  // ピン留め
  isPinned Boolean @default(false) @map("is_pinned")

  // 編集履歴
  isEdited        Boolean   @default(false) @map("is_edited")
  editedAt        DateTime? @map("edited_at")
  originalContent String?   @map("original_content") @db.Text

  // リアクション（絵文字）
  reactions Json?
  // {"👍": [user_id1, user_id2], "❤️": [user_id3]}

  // 言語（多言語コメント対応）
  language Language @default(JA)

  // 翻訳
  translations Json?
  // {en: "translated text", zh: "...", vi: "..."}

  // タイムスタンプ
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // リレーション
  mentions CommentMention[]

  @@index([companyId, attachedToType, attachedToId])
  @@index([companyId, authorUserId])
  @@index([parentCommentId])
  @@index([threadRootId])
  @@index([createdAt])
  @@map("comments")
}

enum CommentFormat {
  PLAIN // プレーンテキスト
  MARKDOWN // Markdown
  HTML // HTML（リッチエディタ）
}

enum CommentType {
  GENERAL // 一般コメント
  QUESTION // 質問
  ANSWER // 回答
  FEEDBACK // フィードバック
  APPROVAL // 承認コメント
  REJECTION // 却下コメント
  REVISION_REQUEST // 修正依頼
  TASK // タスク的コメント
  DECISION // 決定事項
  ANNOUNCEMENT // お知らせ
  INTERNAL_NOTE // 内部メモ（外部に見せない）
}

enum CommentPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

/// コメントメンション
model CommentMention {
  id              String @id @default(uuid())
  commentId       String @map("comment_id")
  mentionedUserId String @map("mentioned_user_id")

  // 通知済みフラグ
  isNotified Boolean   @default(false) @map("is_notified")
  notifiedAt DateTime? @map("notified_at")

  // 既読フラグ
  isRead Boolean   @default(false) @map("is_read")
  readAt DateTime? @map("read_at")

  // タイムスタンプ
  createdAt DateTime @default(now()) @map("created_at")

  // リレーション
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([commentId, mentionedUserId])
  @@index([mentionedUserId, isRead])
  @@map("comment_mentions")
}

