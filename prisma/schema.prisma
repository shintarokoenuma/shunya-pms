  // メモ
  notes String? @db.Text

  // タイムスタンプ
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([companyId, periodYear, periodMonth, calculationType])
  @@index([companyId, periodYear, periodMonth])
  @@map("tax_calculation_logs")
}

enum TaxCalculationType {
  MONTHLY // 月次計算
  QUARTERLY // 四半期計算
  ANNUAL // 年次計算
  INTERIM // 中間計算
}

// =====================================================
// 経過措置記録
// =====================================================

/// 経過措置記録
/// インボイス制度の経過措置（80%控除 → 50%控除 → 0%控除）
model TransitionMeasureRecord {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  // 関連エンティティ
  invoiceId  String? @map("invoice_id") // 関連請求書（仕入側）
  poId       String? @map("po_id")
  woId       String? @map("wo_id")
  supplierId String  @map("supplier_id")

  // 取引情報
  transactionDate DateTime @map("transaction_date") @db.Date

  // 金額
  transactionAmount Decimal  @map("transaction_amount") @db.Decimal(15, 2)
  originalTaxAmount Decimal  @map("original_tax_amount") @db.Decimal(15, 2) // 通常の税額
  currency          Currency @default(JPY)

  // 経過措置の適用
  isQualifiedSupplier  Boolean @default(false) @map("is_qualified_supplier")
  deductiblePercentage Decimal @map("deductible_percentage") @db.Decimal(5, 2)
  // 100% (適格) / 80% (2023/10-2026/9) / 50% (2026/10-2029/9) / 0% (2029/10-)
  deductibleAmount     Decimal @map("deductible_amount") @db.Decimal(15, 2)
  nonDeductibleAmount  Decimal @map("non_deductible_amount") @db.Decimal(15, 2)

  // 措置の根拠
  measurePeriod String @map("measure_period") @db.VarChar(100) // "2026-2029"

  // メモ
  notes String? @db.Text

  // タイムスタンプ
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([companyId, transactionDate])
  @@index([supplierId])
  @@index([invoiceId])
  @@map("transition_measure_records")
}

