  COST_ANALYSIS // 原価分析用
  COMPARISON // 比較資料
}

// =====================================================
// 受注変換（見積もり → 受注の橋渡し）
// =====================================================

/// 見積もり → 受注変換の追跡
/// FINAL見積もり承認時に作成
/// 数量・単価の変動を記録
model QuotationConversion {
  id          String @id @default(uuid())
  quotationId String @map("quotation_id")

  // 変換タイプ
  conversionType ConversionType @default(DIRECT) @map("conversion_type")

  // 数量変動
  quotedQuantity Int? @map("quoted_quantity")
  actualQuantity Int? @map("actual_quantity")

  // 単価変動
  quotedUnitPrice Decimal? @map("quoted_unit_price") @db.Decimal(15, 2)
  actualUnitPrice Decimal? @map("actual_unit_price") @db.Decimal(15, 2)

  // 為替変動
  quotedExchangeRate Decimal? @map("quoted_exchange_rate") @db.Decimal(15, 6)
  actualExchangeRate Decimal? @map("actual_exchange_rate") @db.Decimal(15, 6)
  fxChangePercent    Decimal? @map("fx_change_percent") @db.Decimal(5, 2)

  // 単価変動の理由
  priceChangeReason  String? @map("price_change_reason") @db.VarChar(100)
  priceChangeDetails String? @map("price_change_details") @db.Text

  // 利益への影響
  costImpact        Decimal? @map("cost_impact") @db.Decimal(15, 2)
  grossProfitImpact Decimal? @map("gross_profit_impact") @db.Decimal(15, 2)

  // 関連受注（受注テーブルから参照される）
  // sales_order_id は後のステップで設定

  // メモ
  notes String? @db.Text

  // 担当者
  confirmedByUserId String? @map("confirmed_by_user_id")

  // タイムスタンプ
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([quotationId])
  @@map("quotation_conversions")
}

enum ConversionType {
  DIRECT // 直接変換（変更なし）
  WITH_PRICE_CHANGE // 単価変更あり
  WITH_QUANTITY_CHANGE // 数量変更あり
  PARTIAL // 一部のみ変換
  EMERGENCY // 緊急進行
}

