// =====================================================

/// 月次ステータス確認（仕様書5.1で確定）
/// AI下書き → 担当者承認 → 送信
model OrderStatusCheck {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  // 対象
  targetType StatusCheckTargetType @map("target_type") // PO / WO / SO

  // 仕入先・工場別にまとめる
  supplierId   String? @map("supplier_id")
  factoryId    String? @map("factory_id")
  contractorId String? @map("contractor_id")

  // 対象期間
  checkMonth DateTime @map("check_month") @db.Date // 確認月

  // 対象のID一覧（JSON）
  targetIds Json @map("target_ids") // [{type, id, number, status, expected_delivery}]

  // AI生成内容
