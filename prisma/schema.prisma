model Notification {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  // 通知対象ユーザー
  recipientUserId String @map("recipient_user_id")

  // 通知タイプ
  notificationType NotificationType     @map("notification_type")
  category         NotificationCategory

  // 優先度
  priority NotificationPriority @default(NORMAL)

  // 通知内容
  title       String  @db.VarChar(255)
  message     String  @db.Text
  actionUrl   String? @map("action_url") @db.VarChar(500)
  actionLabel String? @map("action_label") @db.VarChar(100)

  // 関連エンティティ
  relatedEntityType String? @map("related_entity_type") @db.VarChar(50)
  relatedEntityId   String? @map("related_entity_id") @db.VarChar(255)

  // 追加データ
  metadata Json?

  // 配信チャンネル
  channels NotificationChannel[]

  // 配信状況
  deliveryStatus Json? @map("delivery_status")
  // {in_app: {sent: true, sent_at}, email: {sent: true, sent_at, message_id}, push: {...}}

  // 既読状態
  isRead Boolean   @default(false) @map("is_read")
  readAt DateTime? @map("read_at")

  // アクション実行状態
  isActioned Boolean   @default(false) @map("is_actioned")
