  shotList       Json?   @map("shot_list") // 予定カット数等

  // 素材保管（Google Drive中心）
  rawFolderUrl    String? @map("raw_folder_url") @db.VarChar(500)
  editedFolderUrl String? @map("edited_folder_url") @db.VarChar(500)
  finalFolderUrl  String? @map("final_folder_url") @db.VarChar(500)

  // 進捗
  totalShots      Int? @map("total_shots")
  completedShots  Int  @default(0) @map("completed_shots")
  retouchProgress Int  @default(0) @map("retouch_progress") // 0-100%

  // 納品
  deliveryDate   DateTime? @map("delivery_date") @db.Date
  deliveryStatus String    @default("PENDING") @map("delivery_status") @db.VarChar(20)

  // 予算
