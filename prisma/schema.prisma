/// マージン適用元（4階層のどこから取得したか）
enum MarginSource {
  COMPANY_DEFAULT // 全社デフォルト
  BRAND_LEVEL // ブランド別
  PRODUCT_LEVEL // 品番別
  ITEM_LEVEL // 項目別
  MANUAL_OVERRIDE // 手動上書き
}

// =====================================================
// マージン4階層継承設定
// =====================================================

/// マージン4階層継承設定
/// 全社 → ブランド → 品番 → 項目別 の優先順位
/// 仕様書で確定済み（コスト計算フロー）
model MarginSetting {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  // 階層レベル
  level MarginLevel

  // 適用対象（レベルに応じて）
  brandId          String?               @map("brand_id") // BRAND_LEVELの場合
  productId        String?               @map("product_id") // PRODUCT_LEVELの場合
  externalCategory ExternalCostCategory? @map("external_category") // ITEM_LEVELの場合
  internalCategory InternalCostCategory? @map("internal_category") // ITEM_LEVELの場合

  // マージン率
  marginRate Decimal @map("margin_rate") @db.Decimal(5, 2) // 例：20.00%

  // 適用条件
  minQuantity Int? @map("min_quantity") // 数量帯別マージン
  maxQuantity Int? @map("max_quantity")

  // 有効期間
  validFrom  DateTime? @map("valid_from") @db.Date
  validUntil DateTime? @map("valid_until") @db.Date

  // ステータス
  isActive Boolean @default(true) @map("is_active")

  // メモ
  notes String? @db.Text

  // 作成・更新者
  createdByUserId String? @map("created_by_user_id")
  updatedByUserId String? @map("updated_by_user_id")

  // タイムスタンプ
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([companyId, level])
  @@index([brandId])
  @@index([productId])
  @@map("margin_settings")
}

enum MarginLevel {
  COMPANY_DEFAULT // 全社デフォルト
  BRAND_LEVEL // ブランド別
  PRODUCT_LEVEL // 品番別
  ITEM_LEVEL // 項目別
}

// =====================================================
// 承認履歴
// =====================================================

/// 見積もり承認履歴（saagara V2継承の承認フロー）
model QuotationApprovalHistory {
  id          String @id @default(uuid())
  quotationId String @map("quotation_id")

  // アクション
  action ApprovalAction

  // 実行者
  performedByUserId String?           @map("performed_by_user_id")
  performedByType   ApprovalActorType @map("performed_by_type") // INTERNAL / CLIENT

  // 詳細
  comment     String? @db.Text
  attachments Json? // 添付ファイル

  // 関連情報
  fromStatus QuotationStatus? @map("from_status")
  toStatus   QuotationStatus? @map("to_status")

  // タイムスタンプ
  performedAt DateTime @default(now()) @map("performed_at")

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([quotationId, performedAt])
  @@map("quotation_approval_history")
}

enum ApprovalAction {
  SUBMITTED // 提出
  APPROVED // 承認
  REJECTED // 却下
  REVISION_REQUESTED // 修正依頼
  COMMENT // コメントのみ
  ESCALATED // エスカレーション
  RE_SUBMITTED // 再提出
  CANCELLED // 取消
  EXPIRED // 期限切れ
}

enum ApprovalActorType {
  INTERNAL // 社内担当者
  CLIENT // クライアント側
  SYSTEM // システム自動
}

