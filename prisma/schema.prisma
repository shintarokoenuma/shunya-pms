  SUPPLIER_COMMUNICATION // 仕入先とのやり取り
  FACTORY_COMMUNICATION // 工場とのやり取り
  CONTRACTOR_COMMUNICATION // 外注先とのやり取り

  ORDER_CONFIRMATION // 発注確認
