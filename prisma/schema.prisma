// =====================================================
// INQ：相談ID + 営業先データベース
// =====================================================

/// INQ（問い合わせ）+ 営業先データベース
/// 気づき1で確定：会社情報必須入力、失注・保留も蓄積
model Inquiry {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  // INQ番号（INQ-2026-001形式）
  inquiryNumber String @map("inquiry_number") @db.VarChar(50)

  // 既存クライアント判定
  existingClientId String? @map("existing_client_id") // 既存マッチした場合

  // クライアント情報（必須項目）
  clientCompanyName  String              @map("client_company_name") @db.VarChar(255)
  clientLegalEntity  String?             @map("client_legal_entity") @db.VarChar(255)
  clientBusinessType ClientBusinessType? @map("client_business_type")
  clientSize         ClientSize?         @map("client_size")

  // 担当者情報（必須）
  contactFirstName  String  @map("contact_first_name") @db.VarChar(100)
  contactLastName   String  @map("contact_last_name") @db.VarChar(100)
  contactJobTitle   String? @map("contact_job_title") @db.VarChar(255)
  contactDepartment String? @map("contact_department") @db.VarChar(255)
  contactEmail      String  @map("contact_email") @db.VarChar(255)
  contactPhone      String? @map("contact_phone") @db.VarChar(50)
  contactMobile     String? @map("contact_mobile") @db.VarChar(50)

  // 住所
  postalCode String? @map("postal_code") @db.VarChar(20)
  country    String  @default("JP") @db.VarChar(2)
  prefecture String? @db.VarChar(50)
  city       String? @db.VarChar(100)
  address    String? @db.Text

  // Webサイト・SNS
  website   String? @db.VarChar(500)
  instagram String? @db.VarChar(255)
  twitter   String? @db.VarChar(255)

  // 流入経路
  leadSource      LeadSource @map("lead_source")
  referrer        String?    @db.VarChar(255)
  referrerDetails String?    @map("referrer_details") @db.Text

  // 問い合わせ内容
  inquiryContent String      @map("inquiry_content") @db.Text
  inquiryType    InquiryType @default(GENERAL) @map("inquiry_type") // 直接サンプル/企画/見積もり

  // 想定情報
  expectedItems          String?   @map("expected_items") @db.Text // 想定アイテム
  expectedQuantity       Int?      @map("expected_quantity") // 想定数量
  expectedDelivery       DateTime? @map("expected_delivery") @db.Date // 想定納期
  expectedBudget         Decimal?  @map("expected_budget") @db.Decimal(15, 2) // 予算感
  expectedBudgetCurrency Currency? @map("expected_budget_currency")

  // 参考資料・画像
  referenceFiles Json? @map("reference_files") // ファイルURL配列

  // ステータス（気づき1で確定の4パターン）
  status InquiryStatus @default(INITIAL_CONTACT)

  // 失注時の情報
  lossReason        LossReason? @map("loss_reason")
  lossReasonDetails String?     @map("loss_reason_details") @db.Text
  lostAt            DateTime?   @map("lost_at")

  // 保留時の情報
  pausedUntil  DateTime? @map("paused_until") @db.Date // 再フォロー予定日
  pausedReason String?   @map("paused_reason") @db.Text

  // 案件化時の情報
  convertedAt DateTime? @map("converted_at")

  // 担当者
  assignedToUserId String? @map("assigned_to_user_id")

  // メモ
  internalNotes String? @map("internal_notes") @db.Text

  // 重複チェック用
  duplicateCheckHash String? @map("duplicate_check_hash") @db.VarChar(64)

  // タイムスタンプ
  receivedAt      DateTime  @default(now()) @map("received_at")
  lastContactedAt DateTime? @map("last_contacted_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  // リレーション
  products  Product[]
  followUps InquiryFollowUp[]

  @@unique([companyId, inquiryNumber])
  @@index([companyId, status])
  @@index([companyId, leadSource])
  @@index([companyId, existingClientId])
  @@index([companyId, country])
  @@index([receivedAt])
  @@index([assignedToUserId])
  @@map("inquiries")
}

enum InquiryType {
  DIRECT_SAMPLE // 直接サンプル製作（仕様確定済み）
  PLANNING // 企画相談（コンセプトレベル）
  QUOTATION // 見積もり相談（コスト把握優先）
  GENERAL // 一般問い合わせ
  RECURRING // 既存クライアントからのリピート
}

enum InquiryStatus {
  INITIAL_CONTACT // 相談中
  IN_DISCUSSION // 企画相談中
  QUOTATION_SENT // 見積もり提出済
  CONVERTED // 案件化（品番発番済）
  LOST // 失注
  PAUSED // 保留
  ARCHIVED // アーカイブ
}

enum LossReason {
  PRICE_TOO_HIGH // 価格が予算オーバー
  DELIVERY_MISMATCH // 納期が合わない
  SPEC_CHANGE // 仕様変更
  CANCELLED // 案件キャンセル
  COMPETITOR // 競合に流れた
  NO_RESPONSE // 連絡が途絶えた
  NOT_FIT // 案件規模・条件が合わない
  OTHER
}

/// INQ のフォローアップ履歴
model InquiryFollowUp {
  id        String @id @default(uuid())
  inquiryId String @map("inquiry_id")

  followUpDate    DateTime @map("follow_up_date")
  followUpType    String   @map("follow_up_type") @db.VarChar(50) // email / phone / meeting / chat
  followUpContent String   @map("follow_up_content") @db.Text
  outcomeNotes    String?  @map("outcome_notes") @db.Text

  performedByUserId String? @map("performed_by_user_id")

  createdAt DateTime @default(now()) @map("created_at")

  inquiry Inquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)

  @@index([inquiryId, followUpDate])
  @@map("inquiry_follow_ups")
}

// =====================================================
// モデルコード（リピート系譜の中心）
// =====================================================

/// モデルコード
/// 商品の「型」を表す不変ID、リピートで継承
/// 気づき4で確定：保有資産（パターン・グレーディング・デザイン）をモデル単位で管理
model ModelCode {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  // モデルコード（M-MK-0001形式）
  modelCode String @map("model_code") @db.VarChar(50)

  // 関連ブランド
  brandId String @map("brand_id")

  // 基本情報
  modelName   String  @map("model_name") @db.VarChar(255) // モデル名
  modelNameEn String? @map("model_name_en") @db.VarChar(255)
  description String? @db.Text

  // 商品分類
  categoryId String? @map("category_id") // ProductCategory
  silhouette String? @db.VarChar(100) // オーバーサイズ / レギュラー / スリム等

  // 累積データ（リピート系譜の集計）
  totalRepetitions   Int      @default(0) @map("total_repetitions")
  totalProductionQty Int      @default(0) @map("total_production_qty")
  totalRevenue       Decimal? @map("total_revenue") @db.Decimal(15, 2)
  totalPatternCost   Decimal? @map("total_pattern_cost") @db.Decimal(15, 2) // パターン関連累計コスト
  totalDesignCost    Decimal? @map("total_design_cost") @db.Decimal(15, 2) // デザイン関連累計コスト
  costPerUnit        Decimal? @map("cost_per_unit") @db.Decimal(15, 4) // 累積コスト÷累積生産数

  // 最新使用品番
  latestProductId String? @map("latest_product_id")

  // 保有資産フラグ
  hasPattern Boolean @default(false) @map("has_pattern")
  hasGrading Boolean @default(false) @map("has_grading")
  hasDesign  Boolean @default(false) @map("has_design")

  // 著作権・所有権（モデル単位の設定、案件で上書き可能）
  patternOwnership OwnershipType @default(SHUNYA) @map("pattern_ownership")
  designOwnership  OwnershipType @default(SHUNYA) @map("design_ownership")

  // ステータス
  status ModelCodeStatus @default(ACTIVE)

  // タイムスタンプ
  firstCreatedAt DateTime  @default(now()) @map("first_created_at")
  lastUsedAt     DateTime? @map("last_used_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  // リレーション
  products Product[]

  @@unique([companyId, modelCode])
  @@index([companyId, brandId])
  @@index([companyId, status])
  @@index([companyId, categoryId])
  @@map("model_codes")
}

enum ModelCodeStatus {
  ACTIVE // 現役モデル
  INACTIVE // 一時休止
  DISCONTINUED // 廃番
  ARCHIVED
}

// =====================================================
// 品番カルテ（システムの中核）
// =====================================================

/// 品番カルテ
/// MK-26SS-TS-001（社内品番）+ MARKA-25001（先方品番）
model Product {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  // 品番情報
  productCode       String  @map("product_code") @db.VarChar(50) // 社内品番：MK-26SS-TS-001
  clientProductCode String? @map("client_product_code") @db.VarChar(50) // 先方品番：MARKA-25001

  // 関連エンティティ
  inquiryId   String? @map("inquiry_id") // 起源INQ
  modelCodeId String  @map("model_code_id") // モデルコード
  clientId    String  @map("client_id")
  brandId     String  @map("brand_id")
  categoryId  String? @map("category_id") // ProductCategory

  // 基本情報
  productName   String  @map("product_name") @db.VarChar(255)
  productNameEn String? @map("product_name_en") @db.VarChar(255)
  description   String? @db.Text

  // シーズン・年度
  season String @db.VarChar(20) // 26SS / 26FW
  year   Int    @db.SmallInt // 2026

  // 商品特性
  silhouette String? @db.VarChar(100)

  // 数量
  expectedQuantity Int? @map("expected_quantity") // 想定数量
  receivedOrderQty Int? @map("received_order_qty") // 受注数
  productionQty    Int? @map("production_qty") // 量産数
  deliveredQty     Int? @map("delivered_qty") // 納品数
  defectQty        Int? @map("defect_qty") // 不良数

  // 減産率（自動計算）
  defectRate Decimal? @map("defect_rate") @db.Decimal(5, 2) // (1 - delivered/production) × 100

  // 価格情報
  samplePrice     Decimal? @map("sample_price") @db.Decimal(15, 2)
  massUnitPrice   Decimal? @map("mass_unit_price") @db.Decimal(15, 2) // 量産単価
  totalRevenue    Decimal? @map("total_revenue") @db.Decimal(15, 2)
  totalCost       Decimal? @map("total_cost") @db.Decimal(15, 2)
  grossProfit     Decimal? @map("gross_profit") @db.Decimal(15, 2)
  grossProfitRate Decimal? @map("gross_profit_rate") @db.Decimal(5, 2)
  currency        Currency @default(JPY)

  // ステータス（仕様書F-3：A〜D の表示パターンに対応した10段階）
  status ProductStatus @default(PLANNING)

  // 仕様書ロック状態
  isSpecLocked Boolean   @default(false) @map("is_spec_locked")
  specLockedAt DateTime? @map("spec_locked_at")

  // 受注期間
  orderPeriodStart DateTime? @map("order_period_start") @db.Date
  orderPeriodEnd   DateTime? @map("order_period_end") @db.Date

  // 納期情報
  desiredDeliveryDate DateTime? @map("desired_delivery_date") @db.Date
  plannedDeliveryDate DateTime? @map("planned_delivery_date") @db.Date
  actualDeliveryDate  DateTime? @map("actual_delivery_date") @db.Date

  // 海外生産情報
  isOverseasProduction Boolean @default(false) @map("is_overseas_production")
  productionCountry    String? @map("production_country") @db.VarChar(2)

  // 担当者
  assignedToUserId String? @map("assigned_to_user_id")
  designerId       String? @map("designer_id") // デザイナー
  patternMakerId   String? @map("pattern_maker_id") // パタンナー

  // 著作権・所有権（モデルから継承、品番で上書き可能）
  patternOwnership OwnershipType? @map("pattern_ownership")
  designOwnership  OwnershipType? @map("design_ownership")

  // メモ
  internalNotes String? @map("internal_notes") @db.Text

  // タイムスタンプ
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // リレーション
  inquiry         Inquiry?               @relation(fields: [inquiryId], references: [id])
  modelCode       ModelCode              @relation(fields: [modelCodeId], references: [id])
  skus            Sku[]
  statusHistory   ProductStatusHistory[]
  collectionLinks CollectionProduct[]

  @@unique([companyId, productCode])
  @@index([companyId, status])
  @@index([companyId, season])
  @@index([companyId, clientId])
  @@index([companyId, brandId])
  @@index([companyId, modelCodeId])
  @@index([companyId, inquiryId])
  @@index([companyId, assignedToUserId])
  @@index([companyId, isOverseasProduction])
  @@map("products")
}

/// 品番ステータス（10段階詳細）
/// 表示パターンA：すべて表示 / B：5段階に集約 / C：2段階に集約 / D：非開示
enum ProductStatus {
  PLANNING // 1. 企画中
  SAMPLE_REQUESTED // 2. サンプル依頼受付
  SAMPLE_IN_PROGRESS // 3. サンプル製作中
  SAMPLE_APPROVED // 4. サンプル承認済
  ORDERING_PERIOD // 5. 受注期間中
  ORDER_CONFIRMED // 6. 受注確定
  MASS_PRODUCTION // 7. 量産中
  INSPECTION // 8. 検品中
  DELIVERED // 9. 納品済
  COMPLETED // 10. 完了（請求・入金確認済）
  CANCELLED // キャンセル
  ON_HOLD // 保留中
  ARCHIVED // アーカイブ
}

/// 品番ステータス遷移履歴
model ProductStatusHistory {
  id        String @id @default(uuid())
  productId String @map("product_id")

  fromStatus ProductStatus? @map("from_status")
  toStatus   ProductStatus  @map("to_status")

  changedByUserId String? @map("changed_by_user_id")
  changeReason    String? @map("change_reason") @db.Text

  changedAt DateTime @default(now()) @map("changed_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, changedAt])
  @@map("product_status_history")
}

// =====================================================
// SKU（カラー × サイズの最小単位）
// =====================================================

/// SKU
/// MK-26SS-TS-001-BLK-M形式
/// saagara V2のマトリクスUI継承
model Sku {
  id        String @id @default(uuid())
  companyId String @map("company_id")
  productId String @map("product_id")

  // SKU コード
  skuCode       String  @map("sku_code") @db.VarChar(100)
  clientSkuCode String? @map("client_sku_code") @db.VarChar(100) // 先方SKUコード

  // カラー
  colorCode   String  @map("color_code") @db.VarChar(20) // BLK / WHT / NVY
  colorName   String  @map("color_name") @db.VarChar(100)
  colorNameEn String? @map("color_name_en") @db.VarChar(100)
  colorHex    String? @map("color_hex") @db.VarChar(7) // #000000
  pantone     String? @db.VarChar(50) // Pantone番号

  // サイズ
  size      String @db.VarChar(20) // S / M / L / XL
  sizeOrder Int    @default(0) @map("size_order") // ソート順

  // バーコード
  janCode String? @map("jan_code") @db.VarChar(20)

  // 数量管理
  orderedQuantity    Int @default(0) @map("ordered_quantity") // 受注合計
  productionQuantity Int @default(0) @map("production_quantity") // 量産発注数
  producedQuantity   Int @default(0) @map("produced_quantity") // 生産完了数
  deliveredQuantity  Int @default(0) @map("delivered_quantity") // 納品済数
  defectQuantity     Int @default(0) @map("defect_quantity") // 不良数
  remainingStock     Int @default(0) @map("remaining_stock") // 完成品在庫

  // SKU別MOQ判定結果（気づき3で確定）
  moqStatus SkuMoqStatus @default(NOT_DETERMINED) @map("moq_status")

  // ステータス
  status String @default("ACTIVE") @db.VarChar(20)

  // タイムスタンプ
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // リレーション
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([companyId, skuCode])
  @@index([productId])
  @@index([companyId, janCode])
  @@index([companyId, colorCode])
  @@map("skus")
}

enum SkuMoqStatus {
  NOT_DETERMINED // 未判定
  MEETS_MOQ // MOQ達成
  BELOW_MOQ_PRODUCE // MOQ未達だが増産で生産
  BELOW_MOQ_PRICE_UP // MOQ未達、単価UPで小ロット生産
  EXCLUDED // 量産から除外
  NO_ORDERS // 受注なし
  PENDING_DECISION // クライアントに相談中
}

// =====================================================
// コレクション（複数品番のグルーピング、オプション）
// =====================================================

/// コレクション
/// 気づき1で確定：複数品番を後付けで束ねるオプション機能
/// 必須ではない、1品番だけの案件はコレクション不要
model Collection {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  // コレクション情報
  collectionCode   String  @map("collection_code") @db.VarChar(50) // COL-2026-0042
  collectionName   String  @map("collection_name") @db.VarChar(255)
  collectionNameEn String? @map("collection_name_en") @db.VarChar(255)

  // 関連エンティティ
  clientId String? @map("client_id") // 主要クライアント
  brandId  String? @map("brand_id") // 主要ブランド
  season   String? @db.VarChar(20)

  // 説明・コンセプト
  concept     String? @db.Text
  description String? @db.Text

  // 集計情報
  productCount     Int      @default(0) @map("product_count")
  totalQuantity    Int      @default(0) @map("total_quantity")
  totalRevenue     Decimal? @map("total_revenue") @db.Decimal(15, 2)
  totalCost        Decimal? @map("total_cost") @db.Decimal(15, 2)
  totalGrossProfit Decimal? @map("total_gross_profit") @db.Decimal(15, 2)

  // 契約情報（コレクション単位の契約）
  contractTerms String?  @map("contract_terms") @db.Text
  depositAmount Decimal? @map("deposit_amount") @db.Decimal(15, 2)
  depositPaid   Boolean  @default(false) @map("deposit_paid")

  // ステータス
  status CollectionStatus @default(ACTIVE)

  // 開始・終了
  startDate DateTime? @map("start_date") @db.Date
  endDate   DateTime? @map("end_date") @db.Date

  // 担当者
  assignedToUserId String? @map("assigned_to_user_id")

  // メモ
  notes String? @db.Text

  // タイムスタンプ
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // リレーション
  productLinks CollectionProduct[]

  @@unique([companyId, collectionCode])
  @@index([companyId, status])
  @@index([companyId, clientId])
  @@index([companyId, season])
  @@map("collections")
}

enum CollectionStatus {
  ACTIVE // 進行中
  COMPLETED // 完了
  ARCHIVED // アーカイブ
  CANCELLED // キャンセル
}

/// コレクションと品番の中間テーブル
/// 1品番が複数コレクションに属することも可能（用途別グルーピング）
model CollectionProduct {
  id           String @id @default(uuid())
  collectionId String @map("collection_id")
  productId    String @map("product_id")

  // 関係性のメモ
  notes        String? @db.Text
  displayOrder Int     @default(0) @map("display_order")

  addedByUserId String?  @map("added_by_user_id")
  addedAt       DateTime @default(now()) @map("added_at")

  // リレーション
  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([collectionId, productId])
  @@index([productId])
  @@map("collection_products")
}

// =====================================================
// リピート系譜
// =====================================================

/// リピート系譜
/// モデルコード単位で、過去の品番と新しい品番の関係性を追跡
/// 「これは過去のあの品番のリピート版」を明示的に管理
model ProductRepetitionLineage {
  id          String @id @default(uuid())
  companyId   String @map("company_id")
  modelCodeId String @map("model_code_id")

  // 親品番・子品番
  parentProductId String @map("parent_product_id") // リピート元
  childProductId  String @map("child_product_id") // リピート先（新品番）

  // リピートタイプ
  repetitionType RepetitionType @map("repetition_type")

  // 変更内容
  changeDescription String? @map("change_description") @db.Text
  changesData       Json?   @map("changes_data") // {colors_changed, sizes_changed, spec_modified}

  // 参考にしたバージョン
  basedOnSpecVersion    String? @map("based_on_spec_version") @db.VarChar(20)
  basedOnPatternVersion String? @map("based_on_pattern_version") @db.VarChar(20)
  basedOnDesignVersion  String? @map("based_on_design_version") @db.VarChar(20)

  // タイムスタンプ
  createdAt       DateTime @default(now()) @map("created_at")
  createdByUserId String?  @map("created_by_user_id")

  @@unique([parentProductId, childProductId])
  @@index([modelCodeId])
  @@index([parentProductId])
  @@index([childProductId])
  @@map("product_repetition_lineage")
}

enum RepetitionType {
  EXACT_REPEAT // 完全リピート（仕様変更なし）
  MINOR_CHANGE // 軽微な変更（色追加、サイズ追加等）
  MAJOR_CHANGE // 大幅な変更（仕様変更、パターン修正必要）
  SEASONAL_VARIATION // シーズンバリエーション（同モデル、季節変更）
  COLLABORATION // コラボバージョン
}

