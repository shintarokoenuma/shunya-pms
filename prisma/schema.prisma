/// 為替レート履歴（日銀公示レート等）
model ExchangeRate {
  id String @id @default(uuid())

  baseCurrency   Currency @map("base_currency") // 例：USD
  targetCurrency Currency @map("target_currency") // 例：JPY
  rate           Decimal  @db.Decimal(15, 6)

  rateDate DateTime @map("rate_date") @db.Date // 適用日
  source   String   @default("BOJ") @db.VarChar(50) // BOJ（日銀）など

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([baseCurrency, targetCurrency, rateDate, source])
  @@index([rateDate])
  @@map("exchange_rates")
}

