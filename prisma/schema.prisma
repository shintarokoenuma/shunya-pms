model SoItem {
  id   String @id @default(uuid())
  soId String @map("so_id")

  // SKU
  skuId String @map("sku_id")

  // 受注情報
  orderedQuantity Int      @map("ordered_quantity")
  unitPrice       Decimal  @map("unit_price") @db.Decimal(15, 2)
  subtotal        Decimal  @db.Decimal(15, 2)
  currency        Currency @default(JPY)

  // 納品先（SKUごとに違う場合）
  deliveryDestinationId String? @map("delivery_destination_id")

  // SKU別MOQ判定（気づき3で確定）
  moqStatus         SkuMoqStatus @default(NOT_DETERMINED) @map("moq_status")
