  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // リレーション
  tradeTransaction TradeTransaction  @relation(fields: [tradeTransactionId], references: [id], onDelete: Cascade)
  items            PackingListItem[]

  @@unique([companyId, plNumber])
  @@index([tradeTransactionId])
  @@index([commercialInvoiceId])
  @@index([companyId, status])
  @@map("packing_lists")
}

/// Packing List 明細（カートン単位）
model PackingListItem {
  id            String @id @default(uuid())
  packingListId String @map("packing_list_id")

  // カートン番号
  cartonNumber     String @map("carton_number") @db.VarChar(50) // 例：1/10, 2/10
  fromCartonNumber Int?   @map("from_carton_number")
  toCartonNumber   Int?   @map("to_carton_number")

  // 関連商品（同一品目が複数カートンの場合）
  productId String? @map("product_id")
  skuId     String? @map("sku_id")

  // 商品情報
  itemDescription String  @map("item_description") @db.Text
  itemCode        String? @map("item_code") @db.VarChar(100)

  // カラー・サイズ別の梱包
  colorBreakdown Json? @map("color_breakdown") // [{color, sizes: [{size, qty}]}]

  // 数量
  quantityPerCarton Int    @map("quantity_per_carton")
  totalCartons      Int    @map("total_cartons")
  totalQuantity     Int    @map("total_quantity")
  unit              String @default("PCS") @db.VarChar(20)

  // 重量
  netWeightPerCarton   Decimal @map("net_weight_per_carton") @db.Decimal(10, 3)
  grossWeightPerCarton Decimal @map("gross_weight_per_carton") @db.Decimal(10, 3)
  totalNetWeight       Decimal @map("total_net_weight") @db.Decimal(15, 3)
  totalGrossWeight     Decimal @map("total_gross_weight") @db.Decimal(15, 3)

  // 容積・寸法
  cartonDimensions String?  @map("carton_dimensions") @db.VarChar(100) // 例：60×40×30cm
  cartonVolume     Decimal? @map("carton_volume") @db.Decimal(10, 4)
  totalVolume      Decimal? @map("total_volume") @db.Decimal(15, 4)

  // メモ
  notes String? @db.Text

  // タイムスタンプ
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  packingList PackingList @relation(fields: [packingListId], references: [id], onDelete: Cascade)

  @@index([packingListId])
  @@index([productId])
  @@map("packing_list_items")
}

// =====================================================
// Certificate of Origin（原産地証明）
// =====================================================

/// Certificate of Origin（原産地証明）
/// FTA適用に必須
model CertificateOfOrigin {
  id                 String @id @default(uuid())
  companyId          String @map("company_id")
  tradeTransactionId String @map("trade_transaction_id")

  // 原産地証明番号
  coNumber String @map("co_number") @db.VarChar(50)

  // 証明書タイプ
  coType CertificateOfOriginType @map("co_type")

  // FTA関連
  ftaName  String? @map("fta_name") @db.VarChar(100) // 日越EPA等
  ftaCode  String? @map("fta_code") @db.VarChar(50)
  formType String? @map("form_type") @db.VarChar(50) // Form VJ / Form E / RCEP-CO等

  // 発行情報
  issuingAuthority String    @map("issuing_authority") @db.VarChar(255)
  issuingCountry   String    @map("issuing_country") @db.VarChar(2)
  issueDate        DateTime  @map("issue_date") @db.Date
  validUntil       DateTime? @map("valid_until") @db.Date

  // 取引情報
  exporterName    String  @map("exporter_name") @db.VarChar(255)
  exporterAddress String  @map("exporter_address") @db.Text
  exporterCountry String  @map("exporter_country") @db.VarChar(2)
  exporterTaxId   String? @map("exporter_tax_id") @db.VarChar(50)

  importerName    String  @map("importer_name") @db.VarChar(255)
  importerAddress String  @map("importer_address") @db.Text
  importerCountry String  @map("importer_country") @db.VarChar(2)
  importerTaxId   String? @map("importer_tax_id") @db.VarChar(50)

  // 関連書類
  commercialInvoiceId String? @map("commercial_invoice_id")
  ciNumber            String? @map("ci_number") @db.VarChar(50)

  // 輸送情報
  vesselOrFlight  String?   @map("vessel_or_flight") @db.VarChar(255)
  portOfLoading   String?   @map("port_of_loading") @db.VarChar(255)
  portOfDischarge String?   @map("port_of_discharge") @db.VarChar(255)
  blOrAwbNumber   String?   @map("bl_or_awb_number") @db.VarChar(100)
  shipmentDate    DateTime? @map("shipment_date") @db.Date

  // 原産品の情報
  itemsData Json @map("items_data") // 構造化された品目情報
  // [{hs_code, description, origin_criteria, quantity, value}]

  // 原産性基準
  originCriteria String? @map("origin_criteria") @db.VarChar(255)
  // 例："WO" (Wholly Obtained), "PSR" (Product Specific Rule), "RVC" (Regional Value Content)

  // 言語
  language Language @default(EN)

  // ファイル
  pdfFileUrl  String? @map("pdf_file_url") @db.VarChar(500)
  scanFileUrl String? @map("scan_file_url") @db.VarChar(500) // 実物のスキャン

  // ステータス
  status CertificateStatus @default(APPLIED)

  // 申請・発行情報
  applicationDate DateTime? @map("application_date") @db.Date
  receivedDate    DateTime? @map("received_date") @db.Date

  // 担当者
  createdByUserId String? @map("created_by_user_id")

  // メモ
  notes String? @db.Text

  // タイムスタンプ
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // リレーション
  tradeTransaction TradeTransaction @relation(fields: [tradeTransactionId], references: [id], onDelete: Cascade)

  @@unique([companyId, coNumber])
  @@index([tradeTransactionId])
  @@index([companyId, formType])
  @@index([companyId, status])
  @@index([issueDate])
  @@map("certificates_of_origin")
}

enum CertificateOfOriginType {
  GENERAL // 一般原産地証明
  PREFERENTIAL_EPA // EPA特恵
  PREFERENTIAL_RCEP // RCEP特恵
  PREFERENTIAL_ACFTA // ACFTA特恵
  PREFERENTIAL_OTHER // その他FTA
  GSP // 一般特恵関税制度
  CHAMBER // 商工会議所発行
  SELF_DECLARATION // 自己申告
}

enum CertificateStatus {
  PLANNED // 計画中
  APPLIED // 申請済み
  ISSUED // 発行済み
  RECEIVED // 受領済み
  USED // 使用済み
  EXPIRED // 期限切れ
  REJECTED // 却下
  CANCELLED // キャンセル
}

// =====================================================
// FTA 適用記録
// =====================================================

/// FTA 適用記録
/// 関税優遇の適用と税額計算の証跡
model FtaApplication {
  id                 String @id @default(uuid())
  companyId          String @map("company_id")
  tradeTransactionId String @map("trade_transaction_id")

  // 関連書類
  certificateOfOriginId String? @map("certificate_of_origin_id")

  // FTA 情報
  ftaName   String  @map("fta_name") @db.VarChar(100)
  ftaCode   String  @map("fta_code") @db.VarChar(50)
  ftaRuleId String? @map("fta_rule_id") // マスター参照

  // 適用対象
  itemsData Json @map("items_data")
  // [{hs_code, description, quantity, value, base_rate, preferential_rate, tariff_saved}]

  // 関税優遇額
  totalValueBeforePreference Decimal  @map("total_value_before_preference") @db.Decimal(15, 2)
  baseTariffAmount           Decimal  @map("base_tariff_amount") @db.Decimal(15, 2) // 通常関税額
  preferentialTariffAmount   Decimal  @map("preferential_tariff_amount") @db.Decimal(15, 2) // 特恵関税額
  tariffSavedAmount          Decimal  @map("tariff_saved_amount") @db.Decimal(15, 2) // 節税額
  currency                   Currency

  // JPY換算
  tariffSavedAmountJpy Decimal? @map("tariff_saved_amount_jpy") @db.Decimal(15, 2)

  // 適用日
  applicationDate DateTime @map("application_date") @db.Date

  // 原産性基準の根拠
  originCriteriaUsed    String? @map("origin_criteria_used") @db.VarChar(255)
  criteriaJustification String? @map("criteria_justification") @db.Text

  // 検証情報
  isVerified       Boolean   @default(false) @map("is_verified")
  verifiedByUserId String?   @map("verified_by_user_id")
  verifiedAt       DateTime? @map("verified_at")

  // ステータス
  status String @default("ACTIVE") @db.VarChar(20)

  // メモ
  notes String? @db.Text

  // タイムスタンプ
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // リレーション
  tradeTransaction TradeTransaction @relation(fields: [tradeTransactionId], references: [id], onDelete: Cascade)

  @@index([tradeTransactionId])
  @@index([companyId, ftaCode])
  @@index([applicationDate])
  @@map("fta_applications")
}

// =====================================================
// Bill of Lading（B/L：船荷証券）
// =====================================================

/// Bill of Lading（B/L：船荷証券）
/// 海上輸送時の必須書類
model BillOfLading {
  id                 String @id @default(uuid())
  companyId          String @map("company_id")
  tradeTransactionId String @map("trade_transaction_id")

  // B/L番号
  blNumber String @map("bl_number") @db.VarChar(100)

  // B/Lタイプ
  blType BillOfLadingType @map("bl_type")

  // 船社情報
  shippingLineName String  @map("shipping_line_name") @db.VarChar(255)
  shippingLineCode String? @map("shipping_line_code") @db.VarChar(50)
  vesselName       String  @map("vessel_name") @db.VarChar(255)
  voyageNumber     String? @map("voyage_number") @db.VarChar(50)

  // 取引当事者
  shipperName    String @map("shipper_name") @db.VarChar(255)
  shipperAddress String @map("shipper_address") @db.Text

  consigneeName    String @map("consignee_name") @db.VarChar(255)
  consigneeAddress String @map("consignee_address") @db.Text

  notifyPartyName    String? @map("notify_party_name") @db.VarChar(255)
  notifyPartyAddress String? @map("notify_party_address") @db.Text

  // 港・場所情報
  portOfLoading   String  @map("port_of_loading") @db.VarChar(255)
  portOfDischarge String  @map("port_of_discharge") @db.VarChar(255)
  placeOfReceipt  String? @map("place_of_receipt") @db.VarChar(255)
  placeOfDelivery String? @map("place_of_delivery") @db.VarChar(255)

  // 日付
  shipmentDate         DateTime  @map("shipment_date") @db.Date
  estimatedArrivalDate DateTime? @map("estimated_arrival_date") @db.Date
  actualArrivalDate    DateTime? @map("actual_arrival_date") @db.Date

  // コンテナ情報
  containerNumbers Json? @map("container_numbers") // [{container_no, seal_no, type, size}]
  containerCount   Int?  @map("container_count")

  // 貨物情報
  cargoDescription String?  @map("cargo_description") @db.Text
  totalPackages    Int      @map("total_packages")
  totalGrossWeight Decimal  @map("total_gross_weight") @db.Decimal(15, 3)
  totalVolume      Decimal? @map("total_volume") @db.Decimal(15, 4)

  // 運賃
  freightTerm     String?   @map("freight_term") @db.VarChar(50) // PREPAID / COLLECT
  freightAmount   Decimal?  @map("freight_amount") @db.Decimal(15, 2)
  freightCurrency Currency? @map("freight_currency")

  // ファイル
  pdfFileUrl      String? @map("pdf_file_url") @db.VarChar(500)
  originalScanUrl String? @map("original_scan_url") @db.VarChar(500)

  // ステータス
  status DocumentStatus @default(DRAFT)

  // 受領情報（実物のB/L受領）
  originalsReceived   Boolean   @default(false) @map("originals_received")
  originalsReceivedAt DateTime? @map("originals_received_at")
  originalsCount      Int?      @map("originals_count") // 通常は3通

  // テレックスリリース
  isTelexRelease Boolean   @default(false) @map("is_telex_release")
  telexReleaseAt DateTime? @map("telex_release_at")

  // メモ
  notes String? @db.Text

  // タイムスタンプ
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // リレーション
  tradeTransaction TradeTransaction @relation(fields: [tradeTransactionId], references: [id], onDelete: Cascade)

  @@unique([companyId, blNumber])
  @@index([tradeTransactionId])
  @@index([companyId, status])
  @@index([shipmentDate])
  @@map("bills_of_lading")
}

enum BillOfLadingType {
  MASTER_BL // Master B/L（船社発行）
  HOUSE_BL // House B/L（フォワーダー発行）
  SEAWAY_BILL // Seaway Bill
  STRAIGHT_BL // Straight B/L（記名式）
  ORDER_BL // Order B/L（指図式）
  BEARER_BL // Bearer B/L（持参人式）
  TELEX_RELEASE // テレックスリリース
}

