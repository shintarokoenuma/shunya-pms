/// AI処理ログ
/// 仕様書7：Haiku/Sonnet/Opus 使い分け、コスト追跡
model AiProcessingLog {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  // 処理タイプ
  processingType AiProcessingType @map("processing_type")

  // モデル情報
  modelName    String  @map("model_name") @db.VarChar(100)
  modelVersion String? @map("model_version") @db.VarChar(50)

  // 関連エンティティ
  relatedEntityType String? @map("related_entity_type") @db.VarChar(50)
  relatedEntityId   String? @map("related_entity_id") @db.VarChar(255)

  // 入力情報
  promptType  String? @map("prompt_type") @db.VarChar(100)
  inputTokens Int?    @map("input_tokens")
  inputData   Json?   @map("input_data") // 入力データのメタデータ

  // 出力情報
  outputTokens Int?  @map("output_tokens")
  totalTokens  Int?  @map("total_tokens")
  outputData   Json? @map("output_data")

  // コスト
  inputCostUsd  Decimal? @map("input_cost_usd") @db.Decimal(10, 6)
  outputCostUsd Decimal? @map("output_cost_usd") @db.Decimal(10, 6)
  totalCostUsd  Decimal? @map("total_cost_usd") @db.Decimal(10, 6)
  totalCostJpy  Decimal? @map("total_cost_jpy") @db.Decimal(15, 4)

  // 処理時間
  processingTimeMs Int? @map("processing_time_ms")

  // 結果
  isSuccessful Boolean @default(true) @map("is_successful")
  errorMessage String? @map("error_message") @db.Text

  // ユーザー
  triggeredByUserId String? @map("triggered_by_user_id")
  isAutomated       Boolean @default(false) @map("is_automated")

  // メタデータ
  metadata Json?

  // タイムスタンプ
  processedAt DateTime @default(now()) @map("processed_at")

  @@index([companyId, processingType])
  @@index([companyId, processedAt])
  @@index([companyId, modelName])
  @@index([relatedEntityType, relatedEntityId])
  @@map("ai_processing_logs")
}

enum AiProcessingType {
  EMAIL_CLASSIFICATION // メール分類
  EMAIL_DRAFT_GENERATION // メール下書き生成
  MEETING_TRANSCRIPTION // 議事録文字起こし
  MEETING_SUMMARIZATION // 議事録要約
  TRANSLATION // 翻訳
  CHAT_ASSISTANT // チャットアシスタント
  SPEC_SHEET_DRAFT // 仕様書ドラフト生成
  COST_ANOMALY_DETECTION // 異常値検知
  DELIVERY_DELAY_PREDICTION // 納期遅延予測
  IMAGE_RECOGNITION // 画像認識
  DOCUMENT_OCR // 書類OCR
  DATA_EXTRACTION // データ抽出
  CONTENT_MODERATION // コンテンツモデレーション
  OTHER
}

