// =====================================================
// shunya 生産管理システム Prisma スキーマ
// ステップ9：貿易書類
// =====================================================

// =====================================================
// 貿易取引（核）
// =====================================================

/// 貿易取引
/// 3国間貿易の起点となるエンティティ
/// 仕様書5.4で確定：日越EPA / RCEP / ACFTA / 将来世界対応
model TradeTransaction {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  // 取引番号（TRADE-2026-0042）
  tradeNumber String @map("trade_number") @db.VarChar(50)

  // 取引タイプ
  tradeType TradeType @map("trade_type")

  // 関連エンティティ
  productId    String? @map("product_id")
  collectionId String? @map("collection_id") // コレクション単位の場合
  poId         String? @map("po_id") // 関連PO
  woId         String? @map("wo_id") // 関連WO
  soId         String? @map("so_id") // 関連SO

  // 3国間貿易の関与国
  originCountry         String @map("origin_country") @db.VarChar(2) // 原産国
  exportCountry         String @map("export_country") @db.VarChar(2) // 輸出国
  importCountry         String @map("import_country") @db.VarChar(2) // 輸入国
  intermediaryCountries Json?  @map("intermediary_countries") // 中継国（複数可）

  // 取引当事者
  shipperType    PartyType @map("shipper_type") // 輸出者タイプ
  shipperId      String    @map("shipper_id") @db.VarChar(255)
  shipperName    String    @map("shipper_name") @db.VarChar(255)
  shipperAddress String    @map("shipper_address") @db.Text
  shipperCountry String    @map("shipper_country") @db.VarChar(2)
  shipperTaxId   String?   @map("shipper_tax_id") @db.VarChar(50)

  consigneeType    PartyType @map("consignee_type") // 受荷主タイプ
  consigneeId      String    @map("consignee_id") @db.VarChar(255)
  consigneeName    String    @map("consignee_name") @db.VarChar(255)
  consigneeAddress String    @map("consignee_address") @db.Text
  consigneeCountry String    @map("consignee_country") @db.VarChar(2)
  consigneeTaxId   String?   @map("consignee_tax_id") @db.VarChar(50)

  // Notify Party（着荷通知先、通常はconsigneeと同じだが異なる場合あり）
  notifyPartyName    String? @map("notify_party_name") @db.VarChar(255)
  notifyPartyAddress String? @map("notify_party_address") @db.Text
  notifyPartyContact String? @map("notify_party_contact") @db.VarChar(255)

  // 取引条件（インコタームズ）
  incoterm         IncotermType @map("incoterm")
  incotermLocation String?      @map("incoterm_location") @db.VarChar(255) // 例：FOB Shanghai

  // 輸送情報
  transportMode   TransportMode @map("transport_mode")
  portOfLoading   String?       @map("port_of_loading") @db.VarChar(255)
  portOfDischarge String?       @map("port_of_discharge") @db.VarChar(255)
  placeOfReceipt  String?       @map("place_of_receipt") @db.VarChar(255)
  placeOfDelivery String?       @map("place_of_delivery") @db.VarChar(255)

  // スケジュール
  shipmentDate           DateTime? @map("shipment_date") @db.Date
  estimatedDepartureDate DateTime? @map("estimated_departure_date") @db.Date
  estimatedArrivalDate   DateTime? @map("estimated_arrival_date") @db.Date
  actualArrivalDate      DateTime? @map("actual_arrival_date") @db.Date

  // 通貨・金額
  currency       Currency @default(USD)
  totalAmount    Decimal? @map("total_amount") @db.Decimal(15, 2)
  totalAmountJpy Decimal? @map("total_amount_jpy") @db.Decimal(15, 2)
  exchangeRate   Decimal? @map("exchange_rate") @db.Decimal(15, 6)

  // 重量・容積
  totalGrossWeight Decimal? @map("total_gross_weight") @db.Decimal(15, 3) // 総重量(kg)
  totalNetWeight   Decimal? @map("total_net_weight") @db.Decimal(15, 3) // 正味重量(kg)
  totalVolume      Decimal? @map("total_volume") @db.Decimal(15, 4) // 容積(m³)
  totalPackages    Int?     @map("total_packages")

  // FTA・関税優遇
  ftaApplicable Boolean @default(false) @map("fta_applicable")
  ftaName       String? @map("fta_name") @db.VarChar(100) // 日越EPA / RCEP等
  ftaCode       String? @map("fta_code") @db.VarChar(50)

  // 通関情報
  exportLicenseNumber String? @map("export_license_number") @db.VarChar(100)
  importLicenseNumber String? @map("import_license_number") @db.VarChar(100)

  // ステータス
  status TradeTransactionStatus @default(PLANNING)

  // 担当者
  createdByUserId  String? @map("created_by_user_id")
  assignedToUserId String? @map("assigned_to_user_id")

  // メモ
  internalNotes String? @map("internal_notes") @db.Text

  // タイムスタンプ
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // リレーション
  commercialInvoices   CommercialInvoice[]
  packingLists         PackingList[]
  certificatesOfOrigin CertificateOfOrigin[]
  billsOfLading        BillOfLading[]
  airWaybills          AirWaybill[]
  customsDeclarations  CustomsDeclaration[]
  ftaApplications      FtaApplication[]
  documentFiles        TradeDocumentFile[]

  @@unique([companyId, tradeNumber])
  @@index([companyId, status])
  @@index([companyId, tradeType])
  @@index([companyId, productId])
  @@index([companyId, shipmentDate])
  @@index([originCountry, importCountry])
  @@map("trade_transactions")
}

enum TradeType {
  EXPORT // 輸出（日本 → 海外）
  IMPORT // 輸入（海外 → 日本）
  TRILATERAL // 3国間貿易（中→越→日 等）
  RE_EXPORT // 再輸出
  TRANSIT // 中継貿易
  PROCESSING // 加工貿易
}

enum PartyType {
  SUPPLIER // 仕入先
  FACTORY // 工場
  CLIENT // クライアント
  BUYER // バイヤー
  OWN_COMPANY // 自社（shunya）
  THIRD_PARTY // 第三者
}

enum IncotermType {
  // 全11種類のインコタームズ2020
  EXW // Ex Works（工場渡し）
  FCA // Free Carrier（運送人渡し）
  CPT // Carriage Paid To（輸送費込み）
  CIP // Carriage and Insurance Paid（輸送費保険料込み）
  DAP // Delivered at Place（仕向地持込渡し）
  DPU // Delivered at Place Unloaded（仕向地荷卸込み）
  DDP // Delivered Duty Paid（仕向地関税込み）

  // 海上・内陸水路のみ
  FAS // Free Alongside Ship（船側渡し）
  FOB // Free On Board（本船渡し）
  CFR // Cost and Freight（運賃込み）
  CIF // Cost, Insurance and Freight（運賃保険料込み）
}

enum TransportMode {
  SEA // 海上輸送
  AIR // 航空輸送
  LAND // 陸送
  RAIL // 鉄道
  MULTIMODAL // 複合輸送
  COURIER // クーリエ（DHL等）
}

enum TradeTransactionStatus {
  PLANNING // 企画中
  DOCUMENTS_PREP // 書類準備中
  DOCUMENTS_READY // 書類準備完了
  CUSTOMS_EXPORT // 輸出通関
  IN_TRANSIT // 輸送中
  CUSTOMS_IMPORT // 輸入通関
  ARRIVED // 到着
  COMPLETED // 完了
  CANCELLED // キャンセル
  ON_HOLD // 保留
}

// =====================================================
// Commercial Invoice（商業送り状）
