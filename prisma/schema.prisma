// =====================================================
// 通関申告
// =====================================================

/// 通関申告
/// 輸出入時の税関手続き記録
model CustomsDeclaration {
  id                 String @id @default(uuid())
  companyId          String @map("company_id")
  tradeTransactionId String @map("trade_transaction_id")

  // 申告番号
  declarationNumber String @map("declaration_number") @db.VarChar(100)

  // 申告タイプ
  declarationType CustomsDeclarationType @map("declaration_type")

  // 通関業者
  customsBrokerId   String? @map("customs_broker_id")
  customsBrokerName String  @map("customs_broker_name") @db.VarChar(255)
  brokerContactName String? @map("broker_contact_name") @db.VarChar(255)
  brokerEmail       String? @map("broker_email") @db.VarChar(255)
  brokerPhone       String? @map("broker_phone") @db.VarChar(50)

  // 通関国・税関
  customsCountry String  @map("customs_country") @db.VarChar(2)
  customsOffice  String? @map("customs_office") @db.VarChar(255)

  // 申告日
  declarationDate DateTime  @map("declaration_date") @db.Date
  clearanceDate   DateTime? @map("clearance_date") @db.Date

  // 関税・税金
  totalDeclaredValue Decimal?  @map("total_declared_value") @db.Decimal(15, 2)
  declaredCurrency   Currency? @map("declared_currency")

  totalTariffAmount   Decimal? @map("total_tariff_amount") @db.Decimal(15, 2)
  totalConsumptionTax Decimal? @map("total_consumption_tax") @db.Decimal(15, 2) // 輸入消費税
  otherDuties         Decimal? @map("other_duties") @db.Decimal(15, 2)
  totalDutiesPaid     Decimal? @map("total_duties_paid") @db.Decimal(15, 2)

  // 通関手数料
  brokerFee         Decimal?  @map("broker_fee") @db.Decimal(15, 2)
  brokerFeeCurrency Currency? @map("broker_fee_currency")

  // FTA適用
  ftaApplied       Boolean @default(false) @map("fta_applied")
  ftaApplicationId String? @map("fta_application_id")

  // 関連書類のリスト
  relatedDocuments Json? @map("related_documents")
  // [{type, document_id, file_url}]

  // ステータス
  status CustomsDeclarationStatus @default(PREPARING)

  // 検査情報
  inspectionRequired Boolean   @default(false) @map("inspection_required")
  inspectionDate     DateTime? @map("inspection_date") @db.Date
  inspectionResult   String?   @map("inspection_result") @db.Text

  // ファイル
  declarationFormUrl String? @map("declaration_form_url") @db.VarChar(500)
  receiptUrl         String? @map("receipt_url") @db.VarChar(500)

  // メモ
  notes String? @db.Text

  // 担当者
  createdByUserId String? @map("created_by_user_id")

  // タイムスタンプ
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // リレーション
  tradeTransaction TradeTransaction @relation(fields: [tradeTransactionId], references: [id], onDelete: Cascade)

  @@unique([companyId, declarationNumber])
  @@index([tradeTransactionId])
  @@index([companyId, status])
  @@index([declarationDate])
  @@map("customs_declarations")
}

enum CustomsDeclarationType {
  EXPORT // 輸出申告
  IMPORT // 輸入申告
  RE_EXPORT // 再輸出申告
  TRANSIT // 通過申告
  TEMPORARY // 一時輸入
}

enum CustomsDeclarationStatus {
  PREPARING // 準備中
  SUBMITTED // 申告済み
  UNDER_REVIEW // 審査中
  INSPECTION // 検査中
  APPROVED // 承認
  CLEARED // 通関完了
  REJECTED // 却下
  AMENDED // 修正済み
  CANCELLED // キャンセル
}

// =====================================================
// 貿易書類ファイル管理（統合）
// =====================================================

/// 貿易書類ファイル管理
/// 各種貿易書類の実ファイル（PDF、スキャン等）を統合管理
model TradeDocumentFile {
  id                 String @id @default(uuid())
  companyId          String @map("company_id")
  tradeTransactionId String @map("trade_transaction_id")

  // 書類タイプ
  documentType TradeDocumentType @map("document_type")

  // 関連書類ID（タイプに応じて）
  relatedDocumentId String? @map("related_document_id") @db.VarChar(255)

  // ファイル情報
  fileName     String  @map("file_name") @db.VarChar(255)
  fileType     String? @map("file_type") @db.VarChar(50)
  fileSize     BigInt? @map("file_size")
  fileUrl      String  @map("file_url") @db.VarChar(500)
  thumbnailUrl String? @map("thumbnail_url") @db.VarChar(500)

  // ストレージ
  storageLocation AssetStorageLocation @default(SYSTEM_R2) @map("storage_location")

  // バージョン
  version  Int     @default(1)
  isLatest Boolean @default(true) @map("is_latest")

  // メタデータ
  documentNumber String?   @map("document_number") @db.VarChar(100)
  issueDate      DateTime? @map("issue_date") @db.Date
  isOriginal     Boolean   @default(false) @map("is_original") // 原本かコピーか

  // 言語
  language Language?

  // アップロード情報
  uploadedByUserId String? @map("uploaded_by_user_id")
  uploadSource     String? @map("upload_source") @db.VarChar(50) // manual / email / api
  emailMessageId   String? @map("email_message_id") @db.VarChar(255)

  // タグ
  tags Json?

  // メモ
  notes String? @db.Text

  // タイムスタンプ
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // リレーション
  tradeTransaction TradeTransaction @relation(fields: [tradeTransactionId], references: [id], onDelete: Cascade)

  @@index([tradeTransactionId])
  @@index([companyId, documentType])
  @@index([relatedDocumentId])
  @@map("trade_document_files")
}

enum TradeDocumentType {
  // 主要書類
  COMMERCIAL_INVOICE // 商業送り状
  PACKING_LIST // 梱包明細書
  CERTIFICATE_OF_ORIGIN // 原産地証明
  BILL_OF_LADING // B/L
  AIR_WAYBILL // AWB

  // 補助書類
  PROFORMA_INVOICE // プロフォーマインボイス
  LETTER_OF_CREDIT // L/C
  INSURANCE_CERTIFICATE // 保険証券
  INSPECTION_CERTIFICATE // 検査証明書
  FUMIGATION_CERTIFICATE // 燻蒸証明書

  // 通関関連
  CUSTOMS_DECLARATION // 通関申告書
  CUSTOMS_RECEIPT // 通関完了証
  IMPORT_LICENSE // 輸入許可証
  EXPORT_LICENSE // 輸出許可証

