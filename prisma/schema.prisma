/// 受注（SO）
/// バイヤー・納品先別に管理
model SalesOrder {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  // SO番号（SO-2026-0042）
  soNumber String @map("so_number") @db.VarChar(50)

  // 関連エンティティ
  productId             String  @map("product_id")
  clientId              String  @map("client_id")
  buyerId               String? @map("buyer_id") // バイヤー
  deliveryDestinationId String? @map("delivery_destination_id") // 納品先

  // 紐付け見積もり
  quotationId      String? @map("quotation_id")
  quotationVersion String? @map("quotation_version") @db.VarChar(20)

  // 受注ソース（仕様書5.3：気づき3で確定）
  sourceType    OrderSourceType @map("source_type")
  sourceDetails Json?           @map("source_details") // メールID等の追加情報

  // 原本ファイル（外部受注の場合）
  originalFiles Json? @map("original_files") // [{fileName, fileUrl, fileType}]

  // タイトル・摘要
  title       String? @db.VarChar(255)
  description String? @db.Text

  // 通貨
  currency Currency @default(JPY)

  // 単価（MOQ階段から自動適用 or 手動指定）
  unitPrice        Decimal? @map("unit_price") @db.Decimal(15, 2)
  appliedMoqTierId String?  @map("applied_moq_tier_id") // 適用されたMOQ階段

  // 金額情報
  totalQuantity Int      @default(0) @map("total_quantity")
  subtotal      Decimal? @db.Decimal(15, 2)
  taxAmount     Decimal? @map("tax_amount") @db.Decimal(15, 2)
  totalAmount   Decimal? @map("total_amount") @db.Decimal(15, 2)

  // 納期
  desiredDeliveryDate DateTime? @map("desired_delivery_date") @db.Date
  plannedDeliveryDate DateTime? @map("planned_delivery_date") @db.Date
  actualDeliveryDate  DateTime? @map("actual_delivery_date") @db.Date

  // ステータス（気づき3で確定）
  status SalesOrderStatus @default(TENTATIVE)

  // バージョン管理（受注変更履歴）
  version       Int     @default(1)
  isLatest      Boolean @default(true) @map("is_latest")
  baseVersionId String? @map("base_version_id")

  // 確定情報
  confirmedAt       DateTime? @map("confirmed_at")
  confirmedByUserId String?   @map("confirmed_by_user_id")

  // クライアント確認
  clientConfirmedAt       DateTime? @map("client_confirmed_at")
  clientConfirmationNotes String?   @map("client_confirmation_notes") @db.Text

  // 量産発注への変換
  isConvertedToProduction Boolean   @default(false) @map("is_converted_to_production")
  convertedAt             DateTime? @map("converted_at")

  // 受注メモ
  buyerOrderNumber     String? @map("buyer_order_number") @db.VarChar(100) // バイヤー側の発注番号
  buyerSpecialRequests String? @map("buyer_special_requests") @db.Text

  // メモ
  internalNotes String? @map("internal_notes") @db.Text

  // 担当者
  createdByUserId  String? @map("created_by_user_id")
  assignedToUserId String? @map("assigned_to_user_id")

  // タイムスタンプ
  orderDate DateTime  @default(now()) @map("order_date") @db.Date
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // リレーション
  items         SoItem[]
  changeHistory SalesOrderChangeHistory[]

  @@unique([companyId, soNumber])
  @@index([companyId, productId])
  @@index([companyId, clientId])
  @@index([companyId, buyerId])
  @@index([companyId, status])
  @@index([companyId, sourceType])
  @@index([companyId, orderDate])
  @@index([quotationId])
  @@index([isLatest, productId])
  @@map("sales_orders")
}

enum OrderSourceType {
