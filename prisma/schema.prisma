// =====================================================
// バイヤー・納品先マスター
// =====================================================

/// バイヤー（小売・卸の会社、または Client の事業部単位）
model Buyer {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  // 関連クライアント（このバイヤーがクライアントの取引先 / 事業部）
  clientId String? @map("client_id")

  // 基本情報
  buyerCode   String  @map("buyer_code") @db.VarChar(50)
  buyerName   String  @map("buyer_name") @db.VarChar(255)
  buyerNameEn String? @map("buyer_name_en") @db.VarChar(255)

  // 連絡先（住所 5 分割、Client / AddressFields と揃える）
  postalCode    String? @map("postal_code") @db.VarChar(20)
  country       String  @default("JP") @db.VarChar(2)
  prefecture    String? @db.VarChar(50)
  city          String? @db.VarChar(100)
  address       String? @db.Text
  addressLine2  String? @map("address_line2") @db.VarChar(255)
  contactPerson String? @map("contact_person") @db.VarChar(255)
  phone         String? @db.VarChar(50)
  email         String? @db.VarChar(255)

  // メモ
  notes String? @db.Text

  // ステータス
  status BuyerStatus @default(ACTIVE)

  // タイムスタンプ
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // リレーション
  client               Client?               @relation(fields: [clientId], references: [id])
  deliveryDestinations DeliveryDestination[]

  @@unique([companyId, buyerCode])
  @@index([companyId, clientId])
  @@index([companyId, status])
  @@map("buyers")
}

enum BuyerStatus {
  ACTIVE
  ARCHIVED
}

/// 納品先（バイヤーの店舗・倉庫等）
model DeliveryDestination {
  id        String @id @default(uuid())
  companyId String @map("company_id")
  buyerId   String @map("buyer_id")

  // 識別
  destinationCode String @map("destination_code") @db.VarChar(50)
  destinationName String @map("destination_name") @db.VarChar(255) // 例：BEAMS渋谷店

  // 住所（A-3：5 分割 + addressLine2）
  postalCode   String? @map("postal_code") @db.VarChar(20)
  country      String  @default("JP") @db.VarChar(2)
  prefecture   String? @db.VarChar(50)
  city         String? @db.VarChar(100)
  address      String? @db.Text
  addressLine2 String? @map("address_line2") @db.VarChar(255) // 例：山田ビル 3F

  // 連絡先（A-2：単一連絡先）
  contactPerson String? @map("contact_person") @db.VarChar(255)
  phone         String? @db.VarChar(50)
  email         String? @db.VarChar(255)

  // 配送指示（C-3）
  deliveryNotes          String? @map("delivery_notes") @db.Text
  preferredDeliveryDays  String? @map("preferred_delivery_days") @db.VarChar(255) // 例：火・木
  preferredDeliveryHours String? @map("preferred_delivery_hours") @db.VarChar(255) // 例：10:00-15:00

  // 海外取引（A-4：timezone のみ）
  timezone String? @db.VarChar(50)

  // ステータス（A-1：Buyer に揃えて 2 値）
  status DeliveryDestinationStatus @default(ACTIVE)

  // メモ
  notes String? @db.Text

  // タイムスタンプ
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // リレーション
  buyer Buyer @relation(fields: [buyerId], references: [id], onDelete: Cascade)

  @@unique([companyId, destinationCode])
  @@index([companyId, buyerId])
  @@index([companyId, status])
  @@map("delivery_destinations")
}

enum DeliveryDestinationStatus {
  ACTIVE
  ARCHIVED
}

// =====================================================
// 生地・副資材マスター
// =====================================================

/// 生地・副資材マスター
/// 貿易データ（HSコード、原産国、組成等）を含む
model Material {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  // 基本情報
  materialCode   String  @map("material_code") @db.VarChar(50)
  materialName   String  @map("material_name") @db.VarChar(255)
  materialNameEn String? @map("material_name_en") @db.VarChar(255)
  materialNameZh String? @map("material_name_zh") @db.VarChar(255)
  materialNameVi String? @map("material_name_vi") @db.VarChar(255)

  // 分類
  categoryId   String?      @map("category_id")
  materialType MaterialType @map("material_type")

  // 仕入先（Phase 1A-13a-fix で必須化 + relation 追加）
  primarySupplierId String @map("primary_supplier_id")

  // 仕様
  specification String? @db.Text

  // 生地の場合
  fabricWeight    Decimal? @map("fabric_weight") @db.Decimal(8, 2) // g/m²
  fabricWidth     Decimal? @map("fabric_width") @db.Decimal(8, 2) // cm
  composition     String?  @db.Text // 例：Cotton 100%
  compositionData Json?    @map("composition_data") // 構造化された組成データ

  // 規格・標準
  standardUsage    Decimal? @map("standard_usage") @db.Decimal(8, 4) // 標準用尺（m/枚）
  standardLossRate Decimal? @map("standard_loss_rate") @db.Decimal(5, 2) // 標準ロス率（%）

  // 単価
  unitPrice Decimal? @map("unit_price") @db.Decimal(15, 4)
  currency  Currency @default(JPY)
  unit      String   @db.VarChar(20) // m / 個 / kg / 巻き

  // MOQ
  minimumOrderQty Decimal? @map("minimum_order_qty") @db.Decimal(15, 2)

  // 貿易データ（海外取引時の必須項目）
  hsCode        String? @map("hs_code") @db.VarChar(20)
  originCountry String? @map("origin_country") @db.VarChar(2) // ISO 3166-1

  // 色展開（生地・糸など）
  availableColors Json? @map("available_colors") // [{name, code, hex}]

  // 画像
  imageUrl       String? @map("image_url") @db.VarChar(500)
  swatchImageUrl String? @map("swatch_image_url") @db.VarChar(500) // 生地見本

  // メモ
  notes String? @db.Text

  // ステータス（Phase 1A-13a で enum 化、ModelCode と同じ 4 値）
  status MaterialStatus @default(ACTIVE)

  // タイムスタンプ
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // リレーション
  category        MaterialCategory? @relation(fields: [categoryId], references: [id])
  primarySupplier Supplier          @relation(fields: [primarySupplierId], references: [id], onDelete: Restrict)

  // Phase 1A-13a-fix：仕入先ごとに独立した materialCode 採番を許可する複合 unique
  @@unique([companyId, primarySupplierId, materialCode])
  @@index([companyId, materialType])
  @@index([companyId, status])
  @@index([primarySupplierId])
  @@map("materials")
}

enum MaterialStatus {
  ACTIVE
  INACTIVE
  DISCONTINUED
  ARCHIVED
}

enum MaterialType {
  FABRIC // 生地（メイン）
  LINING // 裏地
  INTERLINING // 芯地
  ZIPPER // ファスナー
  BUTTON // ボタン
  THREAD // 糸
  ELASTIC // ゴム
  TAPE // テープ
  LABEL // ネーム
  HANG_TAG // 下げ札
  CARE_LABEL // 品質表示
  PACKAGING_BAG // 袋
  POLYBAG // ポリ袋
  BOX // 箱
  OTHER
}

/// 素材カテゴリ
model MaterialCategory {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  categoryCode   String  @map("category_code") @db.VarChar(50)
  categoryName   String  @map("category_name") @db.VarChar(255)
  categoryNameEn String? @map("category_name_en") @db.VarChar(255)

  parentCategoryId String? @map("parent_category_id")

  // タイムスタンプ
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // リレーション
  materials Material[]
  parent    MaterialCategory?  @relation("CategoryHierarchy", fields: [parentCategoryId], references: [id])
  children  MaterialCategory[] @relation("CategoryHierarchy")

  @@unique([companyId, categoryCode])
  @@map("material_categories")
}

// =====================================================
// アイテムカテゴリマスター（Tシャツ、ジャケット等）
// =====================================================

/// 商品カテゴリマスター（標準値を保持）
model ProductCategory {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  // 基本情報（Phase 1A-14：階層コード `LADIES-TOPS-TSHIRT` 対応で 50 文字に拡張）
  categoryCode   String  @map("category_code") @db.VarChar(50)
  categoryName   String  @map("category_name") @db.VarChar(100)
  categoryNameEn String? @map("category_name_en") @db.VarChar(100)

  // 階層構造
  parentCategoryId String? @map("parent_category_id")
  level            Int     @default(1)

  // 標準値
  standardFabricUsage Decimal? @map("standard_fabric_usage") @db.Decimal(8, 4) // 標準用尺（m/枚）
  standardLossRate    Decimal? @map("standard_loss_rate") @db.Decimal(5, 2) // 標準ロス率（%）
  standardSewingFee   Decimal? @map("standard_sewing_fee") @db.Decimal(10, 2) // 標準縫製工賃

  // 標準MOQ階段（デフォルト）
  defaultMoqTiers Json? @map("default_moq_tiers") // [{min, max, price_adjustment}]

  // 標準サイズ展開
  defaultSizeOptions Json? @map("default_size_options") // ["S", "M", "L", "XL"]

  // ステータス
  status ProductCategoryStatus @default(ACTIVE)

  // タイムスタンプ
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // 自己参照
  parent   ProductCategory?  @relation("ProductCategoryHierarchy", fields: [parentCategoryId], references: [id])
  children ProductCategory[] @relation("ProductCategoryHierarchy")

  // Phase 1A-14：categoryName 単独 unique を廃止（同名「Tシャツ」を異なる親に持つため）
  // categoryCode は会社内一意のまま
  @@unique([companyId, categoryCode])
  @@index([companyId, parentCategoryId])
  @@index([companyId, status])
  @@index([companyId, level])
  @@map("product_categories")
}

enum ProductCategoryStatus {
  ACTIVE
  ARCHIVED
}

// =====================================================
// 諸経費マスター
// =====================================================

/// 諸経費マスター（パターン代、検品費等）
model ExpenseCategory {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  expenseCode   String  @map("expense_code") @db.VarChar(50)
  expenseName   String  @map("expense_name") @db.VarChar(100)
  expenseNameEn String? @map("expense_name_en") @db.VarChar(100)

  expenseType ExpenseType @map("expense_type")

  // 標準金額
  standardAmount Decimal? @map("standard_amount") @db.Decimal(15, 2)
  currency       Currency @default(JPY)

  // 計算方法
  calculationType CalculationType @default(FIXED) @map("calculation_type")

  // メモ
  notes String? @db.Text

  // ステータス
  status ExpenseCategoryStatus @default(ACTIVE)

  // タイムスタンプ
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([companyId, expenseCode])
  @@index([companyId, status])
  @@index([companyId, expenseType])
  @@map("expense_categories")
}

enum ExpenseType {
  PATTERN_FEE // パターン代
  GRADING_FEE // グレーディング代
