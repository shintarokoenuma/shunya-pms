/// Commercial Invoice（商業送り状）
/// 輸出入時の必須書類
model CommercialInvoice {
  id                 String @id @default(uuid())
  companyId          String @map("company_id")
  tradeTransactionId String @map("trade_transaction_id")

  // CI番号
  ciNumber String @map("ci_number") @db.VarChar(50)

  // 関連請求書（国内請求書との連携）
  domesticInvoiceId String? @map("domestic_invoice_id")

  // 発行情報
  issueDate DateTime @map("issue_date") @db.Date

  // 取引情報（TradeTransactionからコピー、必要に応じて上書き）
  shipperName    String  @map("shipper_name") @db.VarChar(255)
  shipperAddress String  @map("shipper_address") @db.Text
  shipperCountry String  @map("shipper_country") @db.VarChar(2)
  shipperTaxId   String? @map("shipper_tax_id") @db.VarChar(50)

  consigneeName    String  @map("consignee_name") @db.VarChar(255)
  consigneeAddress String  @map("consignee_address") @db.Text
  consigneeCountry String  @map("consignee_country") @db.VarChar(2)
  consigneeTaxId   String? @map("consignee_tax_id") @db.VarChar(50)

  notifyPartyName    String? @map("notify_party_name") @db.VarChar(255)
  notifyPartyAddress String? @map("notify_party_address") @db.Text

  // 取引条件
  incoterm         IncotermType
  incotermLocation String?      @map("incoterm_location") @db.VarChar(255)
  paymentTerms     String?      @map("payment_terms") @db.VarChar(255) // 例：T/T 30 days

  // 輸送情報
  portOfLoading   String? @map("port_of_loading") @db.VarChar(255)
  portOfDischarge String? @map("port_of_discharge") @db.VarChar(255)
  vesselOrFlight  String? @map("vessel_or_flight") @db.VarChar(255)
  blOrAwbNumber   String? @map("bl_or_awb_number") @db.VarChar(100)

  shipmentDate DateTime? @map("shipment_date") @db.Date

  // 通貨・金額
  currency      Currency @default(USD)
  subtotal      Decimal  @db.Decimal(15, 2)
  freightCost   Decimal? @map("freight_cost") @db.Decimal(15, 2)
  insuranceCost Decimal? @map("insurance_cost") @db.Decimal(15, 2)
  otherCharges  Decimal? @map("other_charges") @db.Decimal(15, 2)
  totalAmount   Decimal  @map("total_amount") @db.Decimal(15, 2)

  // JPY換算
  exchangeRate   Decimal? @map("exchange_rate") @db.Decimal(15, 6)
  totalAmountJpy Decimal? @map("total_amount_jpy") @db.Decimal(15, 2)

  // 原産国（複数品目の場合はItem側でも管理）
  countryOfOrigin String? @map("country_of_origin") @db.VarChar(2)

  // L/C情報
  lcNumber      String? @map("lc_number") @db.VarChar(100)
  lcIssuingBank String? @map("lc_issuing_bank") @db.VarChar(255)

  // 言語
  language Language @default(EN)

  // 表示テンプレート
  templateId String? @map("template_id")

  // PDF出力
  pdfFileUrl     String?   @map("pdf_file_url") @db.VarChar(500)
  pdfGeneratedAt DateTime? @map("pdf_generated_at")

  // ステータス
  status DocumentStatus @default(DRAFT)

  // 署名・印鑑
  signatureUrl   String?   @map("signature_url") @db.VarChar(500)
  signedByUserId String?   @map("signed_by_user_id")
  signedAt       DateTime? @map("signed_at")

  // メモ
  notes String? @db.Text

  // 担当者
  createdByUserId String? @map("created_by_user_id")

  // タイムスタンプ
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // リレーション
  tradeTransaction TradeTransaction        @relation(fields: [tradeTransactionId], references: [id], onDelete: Cascade)
  items            CommercialInvoiceItem[]

  @@unique([companyId, ciNumber])
  @@index([tradeTransactionId])
  @@index([companyId, status])
  @@index([issueDate])
  @@map("commercial_invoices")
}

enum DocumentStatus {
