// =====================================================

/// 納品書
/// 仕様書6.3で確定：先方品番中心の記載、分納先別の自動生成（Phase 2）
model DeliveryNote {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  // 納品書番号（DLV-2026-0042）
  deliveryNumber String @map("delivery_number") @db.VarChar(50)

  // 関連エンティティ
  productId             String  @map("product_id")
  clientId              String  @map("client_id")
  buyerId               String? @map("buyer_id")
  deliveryDestinationId String? @map("delivery_destination_id")

  // 関連受注（複数SOから1納品書もあり得る）
  primarySoId  String? @map("primary_so_id")
  relatedSoIds Json?   @map("related_so_ids")

  // 出荷元・出荷先情報
  shipFromAddress String  @map("ship_from_address") @db.Text
  shipFromContact String? @map("ship_from_contact") @db.VarChar(255)
  shipToAddress   String  @map("ship_to_address") @db.Text
  shipToContact   String? @map("ship_to_contact") @db.VarChar(255)
  shipToPhone     String? @map("ship_to_phone") @db.VarChar(50)

  // 納品日
  deliveryDate         DateTime  @map("delivery_date") @db.Date
  expectedDeliveryDate DateTime? @map("expected_delivery_date") @db.Date

  // 数量・金額情報
  totalQuantity Int      @default(0) @map("total_quantity")
  totalCartons  Int?     @map("total_cartons") // 段ボール数
  totalWeight   Decimal? @map("total_weight") @db.Decimal(15, 2) // 総重量(kg)
  totalVolume   Decimal? @map("total_volume") @db.Decimal(15, 4) // 総容積(m³)

  // 金額（任意：納品書に金額を記載する場合）
  showAmounts    Boolean  @default(false) @map("show_amounts")
  subtotalAmount Decimal? @map("subtotal_amount") @db.Decimal(15, 2)
  taxAmount      Decimal? @map("tax_amount") @db.Decimal(15, 2)
  totalAmount    Decimal? @map("total_amount") @db.Decimal(15, 2)
  currency       Currency @default(JPY)

  // 配送情報
  shippingMethod String? @map("shipping_method") @db.VarChar(100) // 宅配便/トラック便/航空便/海上便
  carrierName    String? @map("carrier_name") @db.VarChar(255)
  trackingNumber String? @map("tracking_number") @db.VarChar(100)

  // 国際配送
  isInternational Boolean @default(false) @map("is_international")
  hsCode          String? @map("hs_code") @db.VarChar(20)

  // 配送指示
  deliveryInstructions  String? @map("delivery_instructions") @db.Text
  packagingInstructions String? @map("packaging_instructions") @db.Text

  // 言語設定
  outputLanguage Language @default(JA) @map("output_language")

  // テンプレート
  templateId String? @map("template_id")

  // PDF出力
  pdfFileUrl     String?   @map("pdf_file_url") @db.VarChar(500)
  pdfGeneratedAt DateTime? @map("pdf_generated_at")

  // ステータス
  status DeliveryNoteStatus @default(DRAFT)

  // 出荷・受領情報
  shippedAt           DateTime? @map("shipped_at")
  shippedByUserId     String?   @map("shipped_by_user_id")
  receivedAt          DateTime? @map("received_at")
  receivedByName      String?   @map("received_by_name") @db.VarChar(255)
  receiptSignatureUrl String?   @map("receipt_signature_url") @db.VarChar(500)

  // 受領確認
  acknowledgmentStatus String? @map("acknowledgment_status") @db.VarChar(50)
  // not_required / pending / received / confirmed
  acknowledgmentNotes  String? @map("acknowledgment_notes") @db.Text

  // 担当者
  createdByUserId  String? @map("created_by_user_id")
  assignedToUserId String? @map("assigned_to_user_id")

  // メモ
  internalNotes String? @map("internal_notes") @db.Text
  clientNotes   String? @map("client_notes") @db.Text

  // タイムスタンプ
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // リレーション
  items     DeliveryNoteItem[]
  shipments Shipment[]

  @@unique([companyId, deliveryNumber])
  @@index([companyId, productId])
  @@index([companyId, clientId])
  @@index([companyId, buyerId])
  @@index([companyId, status])
  @@index([companyId, deliveryDate])
  @@index([primarySoId])
  @@map("delivery_notes")
}

enum DeliveryNoteStatus {
  DRAFT // ドラフト
  PENDING_APPROVAL // 承認待ち
  APPROVED // 承認済み
  SHIPPED // 出荷済み
  IN_TRANSIT // 配送中
  DELIVERED // 納品完了
  RECEIVED // 受領確認済み
  RETURNED // 返品
  CANCELLED // キャンセル
}

/// 納品書明細
model DeliveryNoteItem {
  id             String @id @default(uuid())
  deliveryNoteId String @map("delivery_note_id")

  // 明細順序
  itemOrder Int @map("item_order")

  // SKU情報
  skuId     String @map("sku_id")
  productId String @map("product_id")

  // 表示用情報（仕様書6.3：先方品番中心）
  clientProductCode String? @map("client_product_code") @db.VarChar(50) // 先方品番
  productName       String  @map("product_name") @db.VarChar(255)
  colorCode         String? @map("color_code") @db.VarChar(50)
  colorName         String? @map("color_name") @db.VarChar(100)
  size              String? @db.VarChar(20)
  janCode           String? @map("jan_code") @db.VarChar(20)

  // 数量
  quantity Int
  unit     String @default("枚") @db.VarChar(20)

  // 単価・金額（任意）
  unitPrice Decimal? @map("unit_price") @db.Decimal(15, 2)
  subtotal  Decimal? @db.Decimal(15, 2)
  currency  Currency @default(JPY)

  // 関連SO・WO
  soId     String? @map("so_id")
  soItemId String? @map("so_item_id")
  woId     String? @map("wo_id")

  // 在庫紐付け
  finishedGoodsMovementId String? @map("finished_goods_movement_id")

  // 梱包情報
  cartonNumber String? @map("carton_number") @db.VarChar(50)

  // メモ
  notes String? @db.Text

  // タイムスタンプ
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  deliveryNote DeliveryNote @relation(fields: [deliveryNoteId], references: [id], onDelete: Cascade)

  @@index([deliveryNoteId, itemOrder])
  @@index([skuId])
  @@index([productId])
  @@index([soId])
  @@map("delivery_note_items")
}

// =====================================================
// 出荷追跡
// =====================================================

/// 出荷追跡
/// 1納品書につき1出荷、もしくは複数出荷もあり得る
model Shipment {
  id             String  @id @default(uuid())
  companyId      String  @map("company_id")
  deliveryNoteId String? @map("delivery_note_id")

  // 出荷番号
  shipmentNumber String @map("shipment_number") @db.VarChar(50)

  // 配送業者情報
  carrierName    String  @map("carrier_name") @db.VarChar(255)
  carrierCode    String? @map("carrier_code") @db.VarChar(50)
  serviceType    String? @map("service_type") @db.VarChar(100) // 宅配便/航空便/海上便
  trackingNumber String? @map("tracking_number") @db.VarChar(100)
  trackingUrl    String? @map("tracking_url") @db.VarChar(500)

  // 出荷情報
  shippedDate        DateTime @map("shipped_date") @db.Date
  shippedFromAddress String   @map("shipped_from_address") @db.Text
  shippedToAddress   String   @map("shipped_to_address") @db.Text

  // 国際配送
  isInternational Boolean @default(false) @map("is_international")

  // 重量・サイズ
  totalWeight   Decimal? @map("total_weight") @db.Decimal(15, 2)
  totalCartons  Int?     @map("total_cartons")
  cartonDetails Json?    @map("carton_details") // [{number, weight, dimensions}]

  // 配送費用
  shippingCost  Decimal? @map("shipping_cost") @db.Decimal(15, 2)
  insuranceCost Decimal? @map("insurance_cost") @db.Decimal(15, 2)
  totalCost     Decimal? @map("total_cost") @db.Decimal(15, 2)
  currency      Currency @default(JPY)

  // 配送ステータス
  status ShipmentStatus @default(PREPARING)

  // タイムライン
  pickedUpAt       DateTime? @map("picked_up_at")
  inTransitAt      DateTime? @map("in_transit_at")
  outForDeliveryAt DateTime? @map("out_for_delivery_at")
  deliveredAt      DateTime? @map("delivered_at")

  // 到着情報
  receivedByName   String? @map("received_by_name") @db.VarChar(255)
  deliveryProofUrl String? @map("delivery_proof_url") @db.VarChar(500)

  // 関連書類
  invoiceUrl String? @map("invoice_url") @db.VarChar(500) // 配送業者請求書

  // メモ
  notes String? @db.Text

  // タイムスタンプ
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  deliveryNote DeliveryNote? @relation(fields: [deliveryNoteId], references: [id])

  @@unique([companyId, shipmentNumber])
  @@index([companyId, status])
  @@index([trackingNumber])
  @@index([deliveryNoteId])
  @@map("shipments")
}

enum ShipmentStatus {
  PREPARING // 出荷準備中
  PICKED_UP // 集荷済み
  IN_TRANSIT // 輸送中
  CUSTOMS_CLEARANCE // 通関中
  OUT_FOR_DELIVERY // 配達中
  DELIVERED // 配達完了
  FAILED // 配達失敗
  RETURNED // 返送
  LOST // 紛失
  DAMAGED // 破損
}

// =====================================================
// 請求書（Invoices）
// =====================================================

/// 請求書
/// 仕様書5.5 + 第10部：インボイス制度対応、多通貨、国際取引
model Invoice {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  // 請求書番号（INV-2026-0042）
  invoiceNumber String @map("invoice_number") @db.VarChar(50)

  // 請求書タイプ
  invoiceType InvoiceType @map("invoice_type")

  // 関連エンティティ
  clientId String  @map("client_id")
  buyerId  String? @map("buyer_id")

  // 関連受注・納品書
  primarySoId            String? @map("primary_so_id")
  relatedSoIds           Json?   @map("related_so_ids")
  primaryDeliveryNoteId  String? @map("primary_delivery_note_id")
  relatedDeliveryNoteIds Json?   @map("related_delivery_note_ids")

  // 関連クライアント側情報
  clientPoNumber String? @map("client_po_number") @db.VarChar(100) // クライアント側の発注番号

  // 発行情報
  invoiceDate    DateTime @map("invoice_date") @db.Date
  paymentDueDate DateTime @map("payment_due_date") @db.Date

  // 発行者情報（自社）
  issuerName        String  @map("issuer_name") @db.VarChar(255)
  issuerLegalEntity String? @map("issuer_legal_entity") @db.VarChar(255)
  issuerAddress     String  @map("issuer_address") @db.Text
  issuerPhone       String? @map("issuer_phone") @db.VarChar(50)
  issuerEmail       String? @map("issuer_email") @db.VarChar(255)

  // インボイス制度対応（必須）
  issuerTaxId String @map("issuer_tax_id") @db.VarChar(50) // 適格請求書発行事業者番号

  // 請求先情報
  billToName          String  @map("bill_to_name") @db.VarChar(255)
  billToLegalEntity   String? @map("bill_to_legal_entity") @db.VarChar(255)
  billToAddress       String  @map("bill_to_address") @db.Text
  billToContactPerson String? @map("bill_to_contact_person") @db.VarChar(255)
  billToTaxId         String? @map("bill_to_tax_id") @db.VarChar(50)

  // 通貨
  currency Currency @default(JPY)

  // 為替レート（多通貨時、JPY換算用）
  exchangeRate       Decimal?  @map("exchange_rate") @db.Decimal(15, 6)
  exchangeRateDate   DateTime? @map("exchange_rate_date") @db.Date
  exchangeRateSource String?   @map("exchange_rate_source") @db.VarChar(50)

  // 金額情報（税抜表示+税額別表示）
  subtotal Decimal @db.Decimal(15, 2) // 小計（税抜）

  // 消費税（仕様書第10部）
  taxableAmount10 Decimal? @map("taxable_amount_10") @db.Decimal(15, 2) // 10%対象
  taxAmount10     Decimal? @map("tax_amount_10") @db.Decimal(15, 2) // 10%税額
  taxableAmount8  Decimal? @map("taxable_amount_8") @db.Decimal(15, 2) // 8%対象（軽減税率）
  taxAmount8      Decimal? @map("tax_amount_8") @db.Decimal(15, 2) // 8%税額
  exemptAmount    Decimal? @map("exempt_amount") @db.Decimal(15, 2) // 免税対象（輸出）
  totalTaxAmount  Decimal? @map("total_tax_amount") @db.Decimal(15, 2)

  // 合計
  totalAmount Decimal @map("total_amount") @db.Decimal(15, 2) // 税込合計

  // JPY換算（多通貨時）
  subtotalJpy    Decimal? @map("subtotal_jpy") @db.Decimal(15, 2)
  totalAmountJpy Decimal? @map("total_amount_jpy") @db.Decimal(15, 2)

  // USD表記（国際取引時の二重表示）
  showDualCurrency     Boolean   @default(false) @map("show_dual_currency")
  secondaryCurrency    Currency? @map("secondary_currency")
  totalAmountSecondary Decimal?  @map("total_amount_secondary") @db.Decimal(15, 2)

  // 取引区分
  transactionType InvoiceTransactionType @map("transaction_type")

  // 国際取引
  isInternational Boolean @default(false) @map("is_international")
  isExport        Boolean @default(false) @map("is_export") // 輸出免税対象

  // 支払い情報
  paymentMethod PaymentMethod? @map("payment_method")
  bankInfo      Json?          @map("bank_info") // 振込先銀行情報
  swiftCode     String?        @map("swift_code") @db.VarChar(20)
  iban          String?        @db.VarChar(50)
  bankFeeBurden BankFeeBurden? @map("bank_fee_burden") // 振込手数料負担

  // 言語設定
  outputLanguage Language @default(JA) @map("output_language")

  // テンプレート
  templateId String? @map("template_id")

  // PDF出力
  pdfFileUrl     String?   @map("pdf_file_url") @db.VarChar(500)
  pdfGeneratedAt DateTime? @map("pdf_generated_at")

  // 英語版PDF
  pdfFileUrlEn String? @map("pdf_file_url_en") @db.VarChar(500)

  // ステータス
  status InvoiceStatus @default(DRAFT)

  // 入金状況
  paidAmount      Decimal   @default(0) @map("paid_amount") @db.Decimal(15, 2)
  remainingAmount Decimal?  @map("remaining_amount") @db.Decimal(15, 2)
  isFullyPaid     Boolean   @default(false) @map("is_fully_paid")
  fullyPaidAt     DateTime? @map("fully_paid_at")

  // 為替差損益（多通貨時、入金完了後に確定）
  fxGainLossAmount Decimal? @map("fx_gain_loss_amount") @db.Decimal(15, 2)

  // 送付情報
  sentAt       DateTime? @map("sent_at")
  sentByUserId String?   @map("sent_by_user_id")
  sentMethod   String?   @map("sent_method") @db.VarChar(50) // email/post/portal
  sentTo       String?   @map("sent_to") @db.VarChar(500)

  // クライアント確認
  acknowledgedAt      DateTime? @map("acknowledged_at")
  acknowledgmentNotes String?   @map("acknowledgment_notes") @db.Text

  // 値引き・調整
  discountAmount Decimal? @map("discount_amount") @db.Decimal(15, 2)
  discountReason String?  @map("discount_reason") @db.Text

  // 担当者
  createdByUserId  String? @map("created_by_user_id")
  assignedToUserId String? @map("assigned_to_user_id")

  // メモ
  internalNotes String? @map("internal_notes") @db.Text
  clientNotes   String? @map("client_notes") @db.Text

  // タイムスタンプ
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // リレーション
  items        InvoiceItem[]
  paymentLinks InvoicePayment[]

  @@unique([companyId, invoiceNumber])
  @@index([companyId, clientId])
  @@index([companyId, status])
  @@index([companyId, invoiceType])
  @@index([companyId, paymentDueDate])
  @@index([companyId, isFullyPaid])
  @@index([primarySoId])
  @@map("invoices")
}

enum InvoiceType {
  STANDARD // 通常請求書
  DEPOSIT // デポジット請求
  PROFORMA // プロフォーマインボイス（見積もり的）
  PROGRESS // 進行中請求（中間請求）
  FINAL // 最終請求
  CREDIT_NOTE // クレジットノート（返金）
  DEBIT_NOTE // デビットノート（追加請求）
  COMMERCIAL // Commercial Invoice（輸出用）
}

enum InvoiceTransactionType {
  DOMESTIC_TAXABLE_10 // 国内取引（10%課税）
  DOMESTIC_REDUCED_8 // 国内取引（軽減税率8%）
  EXPORT // 輸出取引（免税）
  IMPORT // 輸入取引
  INTERNATIONAL // 国際取引（多通貨）
  MIXED // 混合取引
}

enum InvoiceStatus {
  DRAFT // ドラフト
  PENDING_APPROVAL // 承認待ち
  APPROVED // 承認済み
  SENT // 送付済み
  ACKNOWLEDGED // クライアント受領
  PARTIALLY_PAID // 一部入金
  PAID // 完全入金
  OVERDUE // 支払期限超過
  CANCELLED // キャンセル
  REFUNDED // 返金済み
  WRITTEN_OFF // 不良債権処理
}

enum PaymentMethod {
  BANK_TRANSFER // 銀行振込
  WIRE_TRANSFER_TT // T/T送金（電信送金）
  LETTER_OF_CREDIT // L/C（信用状）
  CASH // 現金
  CREDIT_CARD // クレジットカード
  CHECK // 小切手
  PAYPAL // PayPal
  WISE // Wise
  OTHER
}

enum BankFeeBurden {
  SENDER // 送金人負担（OUR）
  RECEIVER // 受取人負担（BEN）
  SHARED // 折半（SHA）
}

/// 請求書明細
model InvoiceItem {
  id        String @id @default(uuid())
  invoiceId String @map("invoice_id")

  // 明細順序
  itemOrder Int @map("item_order")

  // 関連エンティティ
  productId          String? @map("product_id")
  skuId              String? @map("sku_id")
  deliveryNoteItemId String? @map("delivery_note_item_id")

  // 表示情報
  itemCode    String? @map("item_code") @db.VarChar(100) // 先方品番が一般的
  itemName    String  @map("item_name") @db.VarChar(255)
  description String? @db.Text
  colorCode   String? @map("color_code") @db.VarChar(50)
  size        String? @db.VarChar(20)

  // 数量・単価
  quantity  Decimal @db.Decimal(15, 4)
  unit      String  @default("枚") @db.VarChar(20)
  unitPrice Decimal @map("unit_price") @db.Decimal(15, 4)

  // 金額（税抜）
  subtotal Decimal @db.Decimal(15, 2)

  // 税区分（インボイス制度）
  taxRate           Decimal           @map("tax_rate") @db.Decimal(5, 2) // 10.00 / 8.00 / 0.00
  taxClassification TaxClassification @map("tax_classification")
  taxAmount         Decimal?          @map("tax_amount") @db.Decimal(15, 2)

  // 適格仕入の場合のフラグ
  isQualifiedPurchase Boolean @default(true) @map("is_qualified_purchase")

  // 通貨
  currency Currency @default(JPY)

  // JPY換算
  subtotalJpy Decimal? @map("subtotal_jpy") @db.Decimal(15, 2)

  // 値引き
  discountAmount Decimal? @map("discount_amount") @db.Decimal(15, 2)
  discountReason String?  @map("discount_reason") @db.VarChar(255)

  // メモ
  notes String? @db.Text

  // タイムスタンプ
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId, itemOrder])
  @@index([productId])
  @@index([skuId])
  @@map("invoice_items")
}

enum TaxClassification {
  STANDARD_10 // 標準税率10%
  REDUCED_8 // 軽減税率8%（食品等、通常使わない）
  EXEMPT // 免税（輸出）
  NON_TAXABLE // 非課税
  OUT_OF_SCOPE // 不課税
  ZERO_RATED // ゼロ税率
}

// =====================================================
// 支払い・入金管理（Payments）
// =====================================================

/// 支払い・入金管理
/// 仕入先への支払い + クライアントからの入金 を統合管理
model Payment {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  // 支払い番号
  paymentNumber String @map("payment_number") @db.VarChar(50) // PAY-2026-0042

  // 支払いタイプ
  paymentDirection PaymentDirection @map("payment_direction") // INCOMING / OUTGOING

  // 取引相手
  counterpartType CounterpartType @map("counterpart_type")
  counterpartId   String          @map("counterpart_id") @db.VarChar(255)
  counterpartName String          @map("counterpart_name") @db.VarChar(255)

  // タイトル・摘要
  title       String? @db.VarChar(255)
  description String? @db.Text

  // 金額
  amount   Decimal  @db.Decimal(15, 2)
  currency Currency @default(JPY)

  // 為替レート（多通貨時）
  exchangeRate Decimal? @map("exchange_rate") @db.Decimal(15, 6)
  amountJpy    Decimal? @map("amount_jpy") @db.Decimal(15, 2)

  // 支払い方法
  paymentMethod PaymentMethod @map("payment_method")

  // 銀行情報
  bankName          String? @map("bank_name") @db.VarChar(255)
  bankAccountNumber String? @map("bank_account_number") @db.VarChar(100)
  swiftCode         String? @map("swift_code") @db.VarChar(20)
  iban              String? @db.VarChar(50)

  // 手数料
  feeAmount   Decimal?       @map("fee_amount") @db.Decimal(15, 2)
  feeCurrency Currency?      @map("fee_currency")
  feeBurden   BankFeeBurden? @map("fee_burden")

  // 国際送金
  isInternational           Boolean @default(false) @map("is_international")
  internationalRemittanceId String? @map("international_remittance_id")

  // スケジュール・実行情報
  scheduledDate     DateTime  @map("scheduled_date") @db.Date
  actualPaymentDate DateTime? @map("actual_payment_date") @db.Date

  // 支払いステータス
  status PaymentStatus @default(SCHEDULED)

  // 決済参照番号
  referenceNumber String? @map("reference_number") @db.VarChar(100)
  bankReference   String? @map("bank_reference") @db.VarChar(100)

  // 為替差損益
  fxGainLossAmount       Decimal?  @map("fx_gain_loss_amount") @db.Decimal(15, 2)
  fxGainLossCalculatedAt DateTime? @map("fx_gain_loss_calculated_at")

  // 関連エンティティ（紐付け）
  relatedInvoiceIds Json? @map("related_invoice_ids")
  relatedPoIds      Json? @map("related_po_ids")
  relatedWoIds      Json? @map("related_wo_ids")

  // 添付書類
  attachments Json?
  receiptUrl  String? @map("receipt_url") @db.VarChar(500)

  // メモ
  internalNotes String? @map("internal_notes") @db.Text

  // 承認情報
  approvedByUserId String?   @map("approved_by_user_id")
  approvedAt       DateTime? @map("approved_at")

  // 担当者
  createdByUserId  String? @map("created_by_user_id")
  executedByUserId String? @map("executed_by_user_id")

  // タイムスタンプ
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // リレーション
  invoiceLinks InvoicePayment[]

  @@unique([companyId, paymentNumber])
  @@index([companyId, paymentDirection])
  @@index([companyId, status])
  @@index([companyId, counterpartType, counterpartId])
  @@index([companyId, scheduledDate])
  @@index([companyId, actualPaymentDate])
  @@map("payments")
}

enum PaymentDirection {
  INCOMING // 入金（クライアントから）
  OUTGOING // 支払い（仕入先・工場へ）
}

enum CounterpartType {
  CLIENT // クライアント
  SUPPLIER // 仕入先
  FACTORY // 工場
  CONTRACTOR // 外注先
  BUYER // バイヤー
  CARRIER // 配送業者
  CUSTOMS_BROKER // 通関業者
  PHOTOGRAPHER // 撮影
  RENTAL_COMPANY // レンタル
  OTHER
}

enum PaymentStatus {
  SCHEDULED // 予定
  PENDING_APPROVAL // 承認待ち
  APPROVED // 承認済み
  PROCESSING // 処理中
  COMPLETED // 完了
  CONFIRMED // 着金確認済み
  FAILED // 失敗
  CANCELLED // キャンセル
  REFUNDED // 返金
  PARTIALLY_COMPLETED // 一部完了
}

// =====================================================
// 請求書と支払いの紐付け
// =====================================================

/// 請求書と支払いの紐付け
/// 1請求書に複数支払い、1支払いで複数請求書もあり得る
model InvoicePayment {
  id        String @id @default(uuid())
  invoiceId String @map("invoice_id")
  paymentId String @map("payment_id")

  // 充当額（部分入金対応）
  allocatedAmount Decimal  @map("allocated_amount") @db.Decimal(15, 2)
  currency        Currency @default(JPY)

  // JPY換算
  allocatedAmountJpy Decimal? @map("allocated_amount_jpy") @db.Decimal(15, 2)

  // メモ
  notes String? @db.Text

  // タイムスタンプ
  allocatedAt DateTime @default(now()) @map("allocated_at")
  createdAt   DateTime @default(now()) @map("created_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@unique([invoiceId, paymentId])
  @@index([invoiceId])
  @@index([paymentId])
  @@map("invoice_payments")
}

// =====================================================
// 国際送金記録
// =====================================================

/// 国際送金記録
/// 仕様書5.5：T/T送金履歴、手数料、着金確認、為替差損益自動計算
model InternationalRemittance {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  // 送金番号
  remittanceNumber String @map("remittance_number") @db.VarChar(50)

  // 送金方向
  direction PaymentDirection

  // 送金人情報
  senderName        String  @map("sender_name") @db.VarChar(255)
  senderAddress     String? @map("sender_address") @db.Text
  senderBankName    String? @map("sender_bank_name") @db.VarChar(255)
  senderBankCountry String? @map("sender_bank_country") @db.VarChar(2)
  senderSwiftCode   String? @map("sender_swift_code") @db.VarChar(20)
  senderAccount     String? @map("sender_account") @db.VarChar(100)

  // 受取人情報
  receiverName        String  @map("receiver_name") @db.VarChar(255)
  receiverAddress     String? @map("receiver_address") @db.Text
  receiverBankName    String  @map("receiver_bank_name") @db.VarChar(255)
  receiverBankCountry String  @map("receiver_bank_country") @db.VarChar(2)
  receiverSwiftCode   String  @map("receiver_swift_code") @db.VarChar(20)
  receiverAccount     String  @map("receiver_account") @db.VarChar(100)
  receiverIban        String? @map("receiver_iban") @db.VarChar(50)

  // 中継銀行情報（コルレス銀行）
  intermediaryBankName  String? @map("intermediary_bank_name") @db.VarChar(255)
  intermediaryBankSwift String? @map("intermediary_bank_swift") @db.VarChar(20)

  // 送金額
  amount   Decimal  @db.Decimal(15, 2)
  currency Currency

  // 送金時の為替レート（送金通貨 → JPY）
  exchangeRate Decimal? @map("exchange_rate") @db.Decimal(15, 6)
  amountJpy    Decimal? @map("amount_jpy") @db.Decimal(15, 2)

  // 手数料の内訳
  senderBankFee           Decimal?      @map("sender_bank_fee") @db.Decimal(15, 2)
  senderBankFeeCurrency   Currency?     @map("sender_bank_fee_currency")
  receiverBankFee         Decimal?      @map("receiver_bank_fee") @db.Decimal(15, 2)
  receiverBankFeeCurrency Currency?     @map("receiver_bank_fee_currency")
  intermediaryFee         Decimal?      @map("intermediary_fee") @db.Decimal(15, 2)
  totalFeesJpy            Decimal?      @map("total_fees_jpy") @db.Decimal(15, 2)
  feeBurden               BankFeeBurden @map("fee_burden")

  // 送金理由・目的
  purpose     String? @db.VarChar(500)
  purposeCode String? @map("purpose_code") @db.VarChar(50) // BOJ報告用

  // ステータス
  status RemittanceStatus @default(INITIATED)

  // タイムライン
  initiatedAt DateTime  @map("initiated_at")
  processedAt DateTime? @map("processed_at")
  arrivedAt   DateTime? @map("arrived_at") // 着金確認日

  // 着金確認
  arrivalConfirmed   Boolean   @default(false) @map("arrival_confirmed")
  arrivalConfirmedAt DateTime? @map("arrival_confirmed_at")
  arrivalConfirmedBy String?   @map("arrival_confirmed_by") @db.VarChar(255)
  arrivalDifference  Decimal?  @map("arrival_difference") @db.Decimal(15, 2) // 着金額の差異

  // 銀行参照番号
  bankReferenceNumber String? @map("bank_reference_number") @db.VarChar(100)
  trackingNumber      String? @map("tracking_number") @db.VarChar(100)

  // 関連支払い
  paymentId String? @map("payment_id")

  // 添付書類
  remittanceReceiptUrl String? @map("remittance_receipt_url") @db.VarChar(500)
  bankStatementUrl     String? @map("bank_statement_url") @db.VarChar(500)

  // メモ
  notes String? @db.Text

  // 担当者
  createdByUserId String? @map("created_by_user_id")

  // タイムスタンプ
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([companyId, remittanceNumber])
  @@index([companyId, status])
  @@index([companyId, direction])
  @@index([companyId, initiatedAt])
  @@index([paymentId])
  @@map("international_remittances")
}

enum RemittanceStatus {
  INITIATED // 送金開始
  PROCESSING // 銀行処理中
  IN_TRANSIT // 中継銀行経由中
  ARRIVED // 着金
  CONFIRMED // 着金確認済み
  FAILED // 失敗
  RETURNED // 返金
  CANCELLED // キャンセル
}

// =====================================================
// 為替差損益記録
// =====================================================

/// 為替差損益記録
/// 仕様書5.5：為替差損益の自動計算・記録
/// 多通貨取引の発生時 vs 決済時のレート差を記録
model FxRecord {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  // 関連エンティティ
  recordType FxRecordType @map("record_type")

  // 関連取引
  invoiceId    String? @map("invoice_id")
  paymentId    String? @map("payment_id")
  poId         String? @map("po_id")
  woId         String? @map("wo_id")
  remittanceId String? @map("remittance_id")

  // 通貨情報
  baseCurrency   Currency @map("base_currency") // 元の通貨
  targetCurrency Currency @default(JPY) @map("target_currency") // 換算先（通常JPY）

  // 金額
  amountInBase Decimal @map("amount_in_base") @db.Decimal(15, 2)

  // レート情報
  initialRate    Decimal  @map("initial_rate") @db.Decimal(15, 6) // 取引発生時
  finalRate      Decimal? @map("final_rate") @db.Decimal(15, 6) // 決済時
  rateDifference Decimal? @map("rate_difference") @db.Decimal(15, 6)

  // 換算額
  initialAmountJpy Decimal  @map("initial_amount_jpy") @db.Decimal(15, 2)
  finalAmountJpy   Decimal? @map("final_amount_jpy") @db.Decimal(15, 2)

  // 為替差損益
  fxGainLossAmount Decimal? @map("fx_gain_loss_amount") @db.Decimal(15, 2)
  isGain           Boolean? @map("is_gain") // true = 利益、false = 損失

  // 期間
  transactionDate DateTime  @map("transaction_date") @db.Date // 取引発生日
  settlementDate  DateTime? @map("settlement_date") @db.Date // 決済日

  // 説明
  description String? @db.Text

  // 会計処理
  isPostedToAccounting Boolean   @default(false) @map("is_posted_to_accounting")
  postedAt             DateTime? @map("posted_at")

  // タイムスタンプ
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([companyId, recordType])
  @@index([companyId, transactionDate])
  @@index([invoiceId])
  @@index([paymentId])
  @@index([remittanceId])
  @@map("fx_records")
}

enum FxRecordType {
  AT_TRANSACTION // 取引発生時の記録
  AT_SETTLEMENT // 決済時の記録
  PERIOD_END // 期末評価
