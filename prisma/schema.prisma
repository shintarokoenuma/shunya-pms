  isIndividual Boolean @default(true) @map("is_individual")

  // 専門分野
  specialties ContractorSpecialty[]

  // 連絡先（住所4分割）
  country      String  @default("JP") @db.VarChar(2)
  postalCode   String? @map("postal_code") @db.VarChar(20)
  prefecture   String? @db.VarChar(50)
  city         String? @db.VarChar(100)
  address      String? @db.Text
  addressLine2 String? @map("address_line2") @db.VarChar(255)
  addressEn    String? @map("address_en") @db.Text
  phone        String? @db.VarChar(50)
  fax          String? @db.VarChar(50)
  email        String? @db.VarChar(255)

  // 海外取引用
  chatTool          String?  @map("chat_tool") @db.VarChar(50)
  chatToolId        String?  @map("chat_tool_id") @db.VarChar(255)
  preferredLanguage Language @default(JA) @map("preferred_language")
  preferredCurrency Currency @default(JPY) @map("preferred_currency")
  timezone          String?  @db.VarChar(50)

  // 契約形態
  contractType ContractorContractType @map("contract_type")

  // 料金体系
  packageFee Decimal? @map("package_fee") @db.Decimal(15, 2) // パッケージ料金
  hourlyRate Decimal? @map("hourly_rate") @db.Decimal(10, 2) // 時給
  monthlyFee Decimal? @map("monthly_fee") @db.Decimal(15, 2) // 月額固定

  // 個別作業単価（JSON、品目別の単価）
  unitFees Json? @map("unit_fees")
  // 例：{"pattern_new": 30000, "pattern_revision": 5000, "grading": 15000}

  // ロイヤリティ
  royaltyType            RoyaltyType @default(NONE) @map("royalty_type")
  royaltyRate            Decimal?    @map("royalty_rate") @db.Decimal(5, 2) // 例：3.00%
  royaltyMinimum         Decimal?    @map("royalty_minimum") @db.Decimal(15, 2)
  royaltyMinimumCurrency Currency?   @map("royalty_minimum_currency")
  royaltyPaymentCycle    String?     @map("royalty_payment_cycle") @db.VarChar(50) // monthly / quarterly / yearly

  // 取引条件
  taxId                    String?         @map("tax_id") @db.VarChar(50)
  isQualifiedInvoiceIssuer Boolean         @default(true) @map("is_qualified_invoice_issuer")
  paymentTermType          PaymentTermType @default(MONTHLY_CLOSING) @map("payment_term_type")
  closingDay               Int?            @map("closing_day")
  paymentMonthOffset       Int?            @map("payment_month_offset")
  paymentDay               Int?            @map("payment_day")

  // 著作権・所有権
  defaultPatternOwnership OwnershipType @default(SHUNYA) @map("default_pattern_ownership")
  defaultDesignOwnership  OwnershipType @default(SHUNYA) @map("default_design_ownership")

  // システムユーザーとしての招待
  invitedUserId String? @map("invited_user_id") // 招待時のユーザーID

  // 担当者
  assignedToUserId String? @map("assigned_to_user_id")

  // メモ
  notes String? @db.Text

  // ステータス
  status ContractorStatus @default(ACTIVE)

  // タイムスタンプ
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // リレーション
  contacts ContractorContact[]

  @@unique([companyId, contractorCode])
  @@index([companyId, status])
  @@index([companyId, country])
  @@index([assignedToUserId])
  @@map("contractors")
}

enum ContractorStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

