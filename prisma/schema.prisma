/// AI翻訳記録
/// 仕様書7：用語マスター活用、AI翻訳 + 担当者確認
model AiTranslationRecord {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  // 翻訳対象
  sourceLanguage Language @map("source_language")
  targetLanguage Language @map("target_language")

  // 関連エンティティ
  attachedToType String? @map("attached_to_type") @db.VarChar(50)
  attachedToId   String? @map("attached_to_id") @db.VarChar(255)

  // 元テキスト
  sourceText     String  @map("source_text") @db.Text
  sourceTextHash String? @map("source_text_hash") @db.VarChar(64) // キャッシュ用

  // 翻訳結果
  translatedText String @map("translated_text") @db.Text

  // 使用された用語マスター
  glossaryTermsUsed Json? @map("glossary_terms_used")

  // AI処理ログとの紐付け
  aiProcessingLogId String? @map("ai_processing_log_id")

  // モデル情報
  modelUsed String? @map("model_used") @db.VarChar(100)

  // 品質情報
  qualityScore Decimal? @map("quality_score") @db.Decimal(5, 4)

  // 担当者レビュー
  isReviewed       Boolean   @default(false) @map("is_reviewed")
  reviewedByUserId String?   @map("reviewed_by_user_id")
  reviewedAt       DateTime? @map("reviewed_at")
  reviewerNotes    String?   @map("reviewer_notes") @db.Text

  // 修正された翻訳
  correctedText String? @map("corrected_text") @db.Text

  // 使用回数（キャッシュ）
  usageCount Int      @default(1) @map("usage_count")
  lastUsedAt DateTime @default(now()) @map("last_used_at")

  // タイムスタンプ
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([sourceLanguage, targetLanguage])
  @@index([attachedToType, attachedToId])
  @@index([sourceTextHash])
  @@map("ai_translation_records")
}

// =====================================================
// 議事録管理
// =====================================================

/// 議事録
/// 既存文字起こしツール統合、AI要約
model MeetingTranscript {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  // 議事録番号
  meetingNumber String @map("meeting_number") @db.VarChar(50)

  // ミーティング情報
  title           String   @db.VarChar(255)
  description     String?  @db.Text
  meetingDate     DateTime @map("meeting_date")
  durationMinutes Int?     @map("duration_minutes")

  // ミーティングタイプ
  meetingType MeetingType @map("meeting_type")

  // 参加者
  participants Json @map("participants")
  // [{user_id, name, role, is_external}, ...]

  // 関連エンティティ
  relatedProductIds Json? @map("related_product_ids")
  relatedClientIds  Json? @map("related_client_ids")

  // 元データ
  audioFileUrl String? @map("audio_file_url") @db.VarChar(500)
  videoFileUrl String? @map("video_file_url") @db.VarChar(500)

  // 文字起こし
  rawTranscript       String?  @map("raw_transcript") @db.Text
  formattedTranscript String?  @map("formatted_transcript") @db.Text
  language            Language @default(JA)
  isMultilingual      Boolean  @default(false) @map("is_multilingual")

  // 多言語版（翻訳）
  translations Json?
  // {en: {text, translated_at, translator_id}, zh: {...}}

  // AI要約
  aiSummary     String? @map("ai_summary") @db.Text
  aiActionItems Json?   @map("ai_action_items")
  // [{description, assignee, due_date, status}]
  aiDecisions   Json?   @map("ai_decisions")
  aiKeywords    Json?   @map("ai_keywords")

  // 仕様変更・納期変更の検知
  detectedChanges Json? @map("detected_changes")
  // [{type: "spec_change", related_entity, description}, ...]

  // 編集情報
  editedSummary  String?   @map("edited_summary") @db.Text
  editedByUserId String?   @map("edited_by_user_id")
  editedAt       DateTime? @map("edited_at")

  // 共有設定
  visibility String @default("INTERNAL") @db.VarChar(20) // INTERNAL / CLIENT_SHARED / PUBLIC

  // ステータス
  status MeetingTranscriptStatus @default(DRAFT)

  // PDF出力
  pdfFileUrl String? @map("pdf_file_url") @db.VarChar(500)

  // 担当者
  createdByUserId String? @map("created_by_user_id")

  // タイムスタンプ
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([companyId, meetingNumber])
  @@index([companyId, meetingDate])
  @@index([companyId, status])
  @@index([companyId, meetingType])
  @@map("meeting_transcripts")
}

enum MeetingType {
  INTERNAL // 社内ミーティング
  CLIENT_MEETING // クライアントミーティング
  SUPPLIER_MEETING // 仕入先との打ち合わせ
  FACTORY_MEETING // 工場との打ち合わせ
  WEEKLY_TEAM // 週次チーム会議
  PROJECT_KICKOFF // 案件キックオフ
  PROJECT_REVIEW // 案件レビュー
  DESIGN_REVIEW // デザインレビュー
  TECHNICAL_REVIEW // 技術レビュー
  TRADE_DISCUSSION // 貿易・物流打ち合わせ
  OTHER
}

enum MeetingTranscriptStatus {
  DRAFT // 文字起こし中
  PROCESSING // AI処理中
  REVIEW // レビュー中
  FINALIZED // 確定
  ARCHIVED
}

