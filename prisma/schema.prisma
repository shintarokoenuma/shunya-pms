// =====================================================
// 仕様書（Specifications）
// =====================================================

/// 仕様書
/// 品番ごとに作成、バージョン管理あり
/// 仕様書 v_n ↔ パターン v_n ↔ デザイン v_n の三位一体管理
model Specification {
  id        String @id @default(uuid())
  companyId String @map("company_id")
  productId String @map("product_id")

  // バージョン
  version       String  @db.VarChar(20) // v1.0 / v2.0 / v3.0
  versionNumber Int     @map("version_number") // 1, 2, 3...（ソート用）
  baseVersionId String? @map("base_version_id") // 派生元のバージョン

  // ステータス
  status         SpecificationStatus @default(DRAFT)
  isLocked       Boolean             @default(false) @map("is_locked")
  lockedAt       DateTime?           @map("locked_at")
  lockedByUserId String?             @map("locked_by_user_id")

  // 三位一体管理（同期するバージョン）
  patternVersionId String? @map("pattern_version_id")
  designVersionId  String? @map("design_version_id")

  // セクション1：基本情報
  specCode String? @map("spec_code") @db.VarChar(50)

  // セクション2：商品情報（productから継承、上書き可能）
  silhouette String? @db.VarChar(100)

  // セクション3：デザイン情報（参照のみ、実体はdesign_versions）
  // → designVersionId で参照

  // セクション4：素材情報（参照のみ、実体はbom）
  // → bom テーブルで管理

  // セクション5：副資材情報（参照のみ、実体はbom）
  // → bom テーブルで管理

  // セクション6：縫製仕様
  sewingMethod  String? @map("sewing_method") @db.Text
  stitchSpec    Json?   @map("stitch_spec") // {needle_size, color, thickness}
  seamAllowance String? @map("seam_allowance") @db.Text

  // セクション7：サイズスペック
  sizeSpec     Json? @map("size_spec") // [{size, measurements: {chest, length, ...}, tolerance}]
  gradingRules Json? @map("grading_rules")

  // セクション8：加工仕様
  washingSpec       String? @map("washing_spec") @db.Text
  printSpec         Json?   @map("print_spec") // [{position, colors, size, method}]
  embroiderySpec    Json?   @map("embroidery_spec")
  specialProcessing String? @map("special_processing") @db.Text

  // セクション9：検品基準
  inspectionPoints Json?   @map("inspection_points")
  defectCriteria   Json?   @map("defect_criteria")
  toleranceRange   String? @map("tolerance_range") @db.Text

  // セクション10：その他
  packaging       String? @db.Text
  packagingFormat String? @map("packaging_format") @db.VarChar(100)
  internalRemarks String? @map("internal_remarks") @db.Text
  factoryRemarks  Json?   @map("factory_remarks") // 工場別の備考

  // 多言語対応
  language       Language @default(JA)
  isMultilingual Boolean  @default(false) @map("is_multilingual")

  // 承認フロー（saagara V2継承）
  isApproved       Boolean   @default(false) @map("is_approved")
  approvedByUserId String?   @map("approved_by_user_id")
  approvedAt       DateTime? @map("approved_at")
  clientApproved   Boolean   @default(false) @map("client_approved")
  clientApprovedAt DateTime? @map("client_approved_at")

  // 出力ファイル（自動生成）
  pdfFileUrl   String? @map("pdf_file_url") @db.VarChar(500)
  excelFileUrl String? @map("excel_file_url") @db.VarChar(500)

  // 改訂情報
  revisionNotes String? @map("revision_notes") @db.Text // このバージョンの変更点

  // 作成・更新者
  createdByUserId String? @map("created_by_user_id")
  updatedByUserId String? @map("updated_by_user_id")

  // タイムスタンプ
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // リレーション
  bom                  Bom?
  multilingualVersions SpecificationMultilingual[]

  @@unique([productId, version])
  @@index([companyId, productId])
  @@index([companyId, status])
  @@index([productId, versionNumber])
  @@map("specifications")
}

enum SpecificationStatus {
  DRAFT // ドラフト（編集中）
  IN_REVIEW // レビュー中
  APPROVED_INTERNAL // 社内承認済
  SUBMITTED // クライアント提出済（ロック）
  CLIENT_APPROVED // クライアント承認済
  ARCHIVED // アーカイブ（旧バージョン）
}

/// 仕様書の多言語バージョン
/// 4言語（日英中越）の自動生成版
model SpecificationMultilingual {
  id              String @id @default(uuid())
  specificationId String @map("specification_id")

  language Language

  // 翻訳されたコンテンツ（JSON）
  translatedContent Json @map("translated_content")

  // 出力ファイル
  pdfFileUrl String? @map("pdf_file_url") @db.VarChar(500)

  // 翻訳情報
  translatedByAi   Boolean   @default(true) @map("translated_by_ai")
  reviewedByUserId String?   @map("reviewed_by_user_id")
  reviewedAt       DateTime? @map("reviewed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  specification Specification @relation(fields: [specificationId], references: [id], onDelete: Cascade)

  @@unique([specificationId, language])
  @@map("specifications_multilingual")
}

// =====================================================
// パターン（Pattern Versions）
// =====================================================

/// パターンバージョン
/// モデルコード単位で管理（気づき4で確定：B+Cハイブリッド）
/// 仕様書バージョンと連動
model PatternVersion {
  id          String @id @default(uuid())
  companyId   String @map("company_id")
  modelCodeId String @map("model_code_id")

  // バージョン情報
  version       String  @db.VarChar(20) // v1 / v2 / v3
  versionNumber Int     @map("version_number")
  baseVersionId String? @map("base_version_id") // 修正のベースバージョン

  // 作成・修正の発注（WO）
  workOrderId String? @map("work_order_id") // 後でWOテーブルから参照

  // ファイル情報（Google Drive中心、気づき4で確定）
  driveFileUrl  String? @map("drive_file_url") @db.VarChar(500)
  driveFilePath String? @map("drive_file_path") @db.Text
  fileName      String? @map("file_name") @db.VarChar(255)
  fileType      String? @map("file_type") @db.VarChar(50) // .dxf, .ai, .pat
  fileSize      BigInt? @map("file_size")

  // システム内サムネイル
  thumbnailUrl String? @map("thumbnail_url") @db.VarChar(500)

  // 作成者（パタンナー）
  contractorId    String? @map("contractor_id") // Contractor
  createdByUserId String? @map("created_by_user_id") // システムユーザーの場合

  // パターン内容
  workType    PatternWorkType @map("work_type") // 新規/修正/グレーディング
  patternType String?         @map("pattern_type") @db.VarChar(100) // CAD / 紙パターン / ハイブリッド

  // 修正内容
  revisionNotes String? @map("revision_notes") @db.Text // 「ボタン位置調整」等
  revisionItems Json?   @map("revision_items") // 構造化された修正項目

  // グレーディング情報
  hasGrading   Boolean @default(false) @map("has_grading")
  gradingSizes Json?   @map("grading_sizes") // ["S", "M", "L", "XL"]

  // 保管情報
  storageLocation String? @map("storage_location") @db.VarChar(255) // 物理保管場所
  storageNotes    String? @map("storage_notes") @db.Text

  // ステータス
  status PatternVersionStatus @default(ACTIVE)

  // メタデータ
  receivedAt DateTime? @map("received_at") // パタンナーから受領した日時

  // タイムスタンプ
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([modelCodeId, version])
  @@index([companyId, modelCodeId])
  @@index([companyId, status])
  @@index([baseVersionId])
  @@index([contractorId])
  @@map("pattern_versions")
}

enum PatternWorkType {
  NEW // 新規作成
  REVISION // 修正
  GRADING // グレーディング追加
  RE_GRADING // グレーディング修正
  COPY // 別モデルからコピー
}

enum PatternVersionStatus {
  DRAFT // 作成中
  ACTIVE // 現役
  ARCHIVED // 旧版
  DEPRECATED // 非推奨（使用禁止）
}

// =====================================================
// デザイン（Design Versions）
// =====================================================

/// デザインバージョン
/// 仕様書・パターンと同期したバージョン管理
/// 気づき5で確定：Google Drive中心
model DesignVersion {
  id          String  @id @default(uuid())
  companyId   String  @map("company_id")
  modelCodeId String  @map("model_code_id")
  productId   String? @map("product_id") // 品番固有の場合

  // バージョン情報
  version       String  @db.VarChar(20) // v1 / v2 / v3
  versionNumber Int     @map("version_number")
  baseVersionId String? @map("base_version_id")

  // ファイル情報
  driveFileUrl  String? @map("drive_file_url") @db.VarChar(500)
  driveFilePath String? @map("drive_file_path") @db.Text
  fileName      String? @map("file_name") @db.VarChar(255)
  fileType      String? @map("file_type") @db.VarChar(50) // .ai, .psd, .pdf
  fileSize      BigInt? @map("file_size")

  // システム内サムネイル（仕様書用画像）
  thumbnailUrl       String? @map("thumbnail_url") @db.VarChar(500)
  flatSketchFrontUrl String? @map("flat_sketch_front_url") @db.VarChar(500)
  flatSketchBackUrl  String? @map("flat_sketch_back_url") @db.VarChar(500)
  detailImages       Json?   @map("detail_images") // [{url, description, position}]

  // 作成者
  designerId         String? @map("designer_id") // User (designer role)
  externalDesignerId String? @map("external_designer_id") // Contractor の場合

  // バージョン内容
  designType DesignType @map("design_type") // 初回 / 修正 / カラー追加 等

  // 配色
  colorPalette Json? @map("color_palette") // [{name, hex, pantone}]

  // 改訂内容
  revisionNotes String? @map("revision_notes") @db.Text
  revisionItems Json?   @map("revision_items")

  // ステータス
  status DesignVersionStatus @default(DRAFT)

  // 承認フロー
  isApproved       Boolean   @default(false) @map("is_approved")
  approvedByUserId String?   @map("approved_by_user_id")
  approvedAt       DateTime? @map("approved_at")
  clientApproved   Boolean   @default(false) @map("client_approved")
  clientApprovedAt DateTime? @map("client_approved_at")

  // タイムスタンプ
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([modelCodeId, version])
  @@index([companyId, modelCodeId])
  @@index([companyId, productId])
  @@index([companyId, status])
  @@index([designerId])
  @@map("design_versions")
}

enum DesignType {
  INITIAL // 初回案
  REVISION // 修正
  COLOR_ADDITION // カラー追加
  SIZE_ADDITION // サイズ追加
  COLLABORATION // コラボバージョン
  FINAL // 最終確定版
}

enum DesignVersionStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  CLIENT_APPROVED
  ARCHIVED
}

// =====================================================
// BOM（Bill of Materials、資材表）
// =====================================================

/// BOM（資材表）
/// 仕様書バージョンに紐付け
/// 見積もりエンジンと連動
model Bom {
  id              String @id @default(uuid())
  companyId       String @map("company_id")
  specificationId String @unique @map("specification_id") // 1仕様書に1BOM

  // バージョン情報（specificationのバージョンと連動）
  version String @db.VarChar(20)

  // 用尺計算の単位
  baseQuantity Int @default(1) @map("base_quantity") // 計算基準（通常1枚）

  // 合計コスト（自動計算）
  totalMaterialCost  Decimal? @map("total_material_cost") @db.Decimal(15, 2) // 材料費合計
  totalAccessoryCost Decimal? @map("total_accessory_cost") @db.Decimal(15, 2) // 副資材費合計
  totalCostPerUnit   Decimal? @map("total_cost_per_unit") @db.Decimal(15, 4) // 1枚あたり原価
  currency           Currency @default(JPY)

  // 為替レート（計算時点）
  exchangeRateData Json? @map("exchange_rate_data") // 多通貨計算用

  // ステータス
  status BomStatus @default(DRAFT)

  // タイムスタンプ
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // リレーション
  specification Specification @relation(fields: [specificationId], references: [id], onDelete: Cascade)
  items         BomItem[]

  @@index([companyId])
  @@map("bom")
}

enum BomStatus {
  DRAFT
  CONFIRMED
  LOCKED // 仕様書ロック時
  ARCHIVED
}

/// BOM明細（生地・副資材の個別行）
model BomItem {
  id    String @id @default(uuid())
  bomId String @map("bom_id")

  // 明細番号
  itemOrder Int @map("item_order")

  // 素材情報（マスター連動 or 直接入力）
  materialId           String? @map("material_id") // マスター連動の場合
  customMaterialName   String? @map("custom_material_name") @db.VarChar(255) // マスターにない場合
  customMaterialNameEn String? @map("custom_material_name_en") @db.VarChar(255)

  // 分類
  itemCategory BomItemCategory @map("item_category")

  // 仕様（マスターから引用 or カスタム）
  specification String? @db.Text
  composition   String? @db.Text

  // 仕入先
  supplierId String? @map("supplier_id")

  // 数量・単位
  usagePerUnit      Decimal  @map("usage_per_unit") @db.Decimal(10, 4) // 1枚あたり使用量
  lossRate          Decimal  @default(0) @map("loss_rate") @db.Decimal(5, 2) // ロス率%
  totalUsagePerUnit Decimal? @map("total_usage_per_unit") @db.Decimal(10, 4) // ロス込み（自動計算）
  unit              String   @db.VarChar(20) // m / 個 / kg

  // カラー指定（生地等）
  colorCode String? @map("color_code") @db.VarChar(50)
  colorName String? @map("color_name") @db.VarChar(100)
  pantone   String? @db.VarChar(50)

  // 単価
  unitPrice Decimal  @map("unit_price") @db.Decimal(15, 4)
  currency  Currency @default(JPY)

  // 1枚あたり原価（自動計算）
  costPerUnit Decimal? @map("cost_per_unit") @db.Decimal(15, 4)

  // 貿易データ（マスターから引用、案件で上書き可能）
  hsCode        String? @map("hs_code") @db.VarChar(20)
  originCountry String? @map("origin_country") @db.VarChar(2)

  // 備考
  notes String? @db.Text

  // タイムスタンプ
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  bom Bom @relation(fields: [bomId], references: [id], onDelete: Cascade)

  @@index([bomId, itemOrder])
  @@index([materialId])
  @@index([supplierId])
  @@map("bom_items")
}

enum BomItemCategory {
  // 生地
  MAIN_FABRIC // 本体生地
  LINING_FABRIC // 裏地
  INTERLINING // 芯地

  // 副資材
  ZIPPER // ファスナー
  BUTTON // ボタン
  THREAD // 糸
  ELASTIC // ゴム
  TAPE // テープ
  RIVET // リベット

  // ラベル類
  BRAND_LABEL // ブランドネーム
  SIZE_LABEL // サイズラベル
  CARE_LABEL // 品質表示
  HANG_TAG // 下げ札

  // パッケージ
  POLYBAG // ポリ袋
  OPP_BAG // OPP袋
  BOX // 箱
  TISSUE // 詰め紙

  // その他
  ACCESSORY // その他副資材
  OTHER
}

// =====================================================
// ムードボード（気づき5で確定）
// =====================================================

/// ムードボード
/// 企画段階のコンセプト整理用
/// 複数レベル紐付け（ブランド / モデル / 案件 / 品番）
model Moodboard {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  // 基本情報
  title       String  @db.VarChar(255)
  concept     String? @db.Text
  description String? @db.Text

  // 紐付け（複数レベル）
  brandId      String? @map("brand_id")
  modelCodeId  String? @map("model_code_id")
  inquiryId    String? @map("inquiry_id")
  productId    String? @map("product_id")
  collectionId String? @map("collection_id")

  // キャンバスサイズ
  canvasWidth  Int @default(1920) @map("canvas_width")
  canvasHeight Int @default(1080) @map("canvas_height")

  // サムネイル
  thumbnailUrl String? @map("thumbnail_url") @db.VarChar(500)

  // エクスポート
