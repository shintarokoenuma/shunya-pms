/// 会社設定
/// テナント固有の設定・カスタマイズ
model CompanySetting {
  id        String @id @default(uuid())
  companyId String @unique @map("company_id")

  // 基本設定
  defaultLanguage Language @default(JA) @map("default_language")
  defaultCurrency Currency @default(JPY) @map("default_currency")
  timezone        String   @default("Asia/Tokyo") @db.VarChar(50)
  fiscalYearStart Int      @default(4) @map("fiscal_year_start") // 4月開始（日本標準）

  // 通貨換算
  exchangeRateSource String @default("BOJ") @map("exchange_rate_source") @db.VarChar(50)

  // 番号採番ルール
  numberingRules Json @map("numbering_rules")
  // {inquiry: {prefix: "INQ", year_format: "YYYY", sequence_padding: 3}, ...}

  // メール設定
  emailSettings Json @map("email_settings")

  // 為替アラート閾値
  fxAlertThreshold Decimal @default(5.0) @map("fx_alert_threshold") @db.Decimal(5, 2)

  // 在庫アラート閾値
  lowStockThresholdDays Int  @default(14) @map("low_stock_threshold_days")
  expiryWarningDays     Json @map("expiry_warning_days")
  // {first: 60, second: 30, third: 0}

  // 歩留まり率デフォルト
  defaultYieldRate Decimal @default(5.0) @map("default_yield_rate") @db.Decimal(5, 2)

  // 見積もり有効期限
  quotationValidityDays Json @map("quotation_validity_days")
  // {sample: 60, mass: 30, final: null}

  // 自動化設定
  automationSettings Json @map("automation_settings")

  // AI設定
  aiSettings Json @map("ai_settings")
  // {email_classification: true, meeting_summary: true, translation: true, ...}

  // セキュリティ設定
  securitySettings Json @map("security_settings")
  // {password_min_length, mfa_required, session_timeout_minutes, ...}

  // 表示設定
  uiPreferences Json? @map("ui_preferences")

  // カスタムフィールド定義
  customFields Json? @map("custom_fields")

  // タイムスタンプ
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("company_settings")
}

