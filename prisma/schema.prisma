/// 書類テンプレート管理
/// 仕様書6.6：4階層テンプレート（全社/用途/クライアント/仕入先）
model DocumentTemplate {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  // テンプレート基本情報
  templateName   String  @map("template_name") @db.VarChar(255)
  templateNameEn String? @map("template_name_en") @db.VarChar(255)
  description    String? @db.Text

  // テンプレート種別
  templateType DocumentTemplateType @map("template_type")

  // 階層レベル（仕様書6.6）
  level TemplateLevel @map("level")

  // 適用対象（階層に応じて）
  clientId   String? @map("client_id") // CLIENT_LEVELの場合
  supplierId String? @map("supplier_id") // SUPPLIER_LEVELの場合
  brandId    String? @map("brand_id") // BRAND_LEVELの場合

  // テンプレートデータ
  templateContent Json @map("template_content")
  // テンプレートの構造化データ

  // レイアウト・スタイル
  layoutConfig Json? @map("layout_config")
  styleConfig  Json? @map("style_config")

  // ロゴ・ヘッダー画像
  logoUrl        String? @map("logo_url") @db.VarChar(500)
  headerImageUrl String? @map("header_image_url") @db.VarChar(500)

  // 言語対応
  supportedLanguages Language[] @map("supported_languages")
  defaultLanguage    Language   @default(JA) @map("default_language")

  // 通貨対応
  supportedCurrencies Currency[] @map("supported_currencies")
  defaultCurrency     Currency   @default(JPY) @map("default_currency")

  // バージョン
  version        Int     @default(1)
  isLatest       Boolean @default(true) @map("is_latest")
  baseTemplateId String? @map("base_template_id")

  // 利用統計
  usageCount Int       @default(0) @map("usage_count")
  lastUsedAt DateTime? @map("last_used_at")

  // デフォルトフラグ
  isDefault Boolean @default(false) @map("is_default")

  // ステータス
  status String @default("ACTIVE") @db.VarChar(20)

  // 作成・更新者
  createdByUserId String? @map("created_by_user_id")
  updatedByUserId String? @map("updated_by_user_id")

  // タイムスタンプ
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([companyId, templateType, level])
  @@index([companyId, status])
  @@index([clientId])
  @@index([supplierId])
  @@map("document_templates")
}

enum DocumentTemplateType {
  // 主要書類
  QUOTATION // 見積もり
  PURCHASE_ORDER // 発注書
  WORK_ORDER // 工場発注書
  INVOICE // 請求書
  DELIVERY_NOTE // 納品書
  SPECIFICATION // 仕様書

  // 貿易書類
  COMMERCIAL_INVOICE // 商業送り状
  PACKING_LIST // 梱包明細書

  // メール
  EMAIL_TEMPLATE // メールテンプレート

  // その他
  REPORT // レポート
  LABEL // 下げ札・品質表示
  OTHER
}

enum TemplateLevel {
  COMPANY_DEFAULT // 全社デフォルト
  USE_CASE // 用途別（仕様書/発注書等）
  CLIENT_LEVEL // クライアント別カスタム
  SUPPLIER_LEVEL // 仕入先別カスタム
  BRAND_LEVEL // ブランド別カスタム
}

