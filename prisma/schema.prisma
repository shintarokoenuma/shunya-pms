// =====================================================
// PDF出力履歴
// =====================================================

/// 見積もりPDF出力履歴
/// 同じバージョンでも複数回出力される
model QuotationPdfOutput {
  id          String @id @default(uuid())
  quotationId String @map("quotation_id")

  // 出力設定
  outputType QuotationPdfType @map("output_type") // 内部用 / 顧客用
  language   Language
  currency   Currency

  // ファイル情報
  fileUrl  String  @map("file_url") @db.VarChar(500)
  fileName String  @map("file_name") @db.VarChar(255)
  fileSize BigInt? @map("file_size")

  // 出力時のスナップショット（再現性確保）
  snapshotData         Json     @map("snapshot_data") // 出力時の全データ
  exchangeRateAtOutput Decimal? @map("exchange_rate_at_output") @db.Decimal(15, 6)

  // 送付情報
  sentTo String?   @map("sent_to") @db.VarChar(255) // メールアドレス
  sentAt DateTime? @map("sent_at")

