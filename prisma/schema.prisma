// =====================================================
// 保管場所マスター
// =====================================================

/// 保管場所マスター
/// 国内倉庫・外部倉庫・工場内・輸送中等
model StorageLocation {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  // 基本情報
  locationCode   String  @map("location_code") @db.VarChar(50)
  locationName   String  @map("location_name") @db.VarChar(255)
  locationNameEn String? @map("location_name_en") @db.VarChar(255)

  // タイプ
  locationType StorageLocationType @map("location_type")

  // 関連エンティティ
  supplierId String? @map("supplier_id") // 仕入先倉庫の場合
  factoryId  String? @map("factory_id") // 工場内の場合

  // 住所
  country    String  @default("JP") @db.VarChar(2)
  postalCode String? @map("postal_code") @db.VarChar(20)
  address    String? @db.Text

  // 連絡先
  contactPerson String? @map("contact_person") @db.VarChar(255)
  phone         String? @db.VarChar(50)
  email         String? @db.VarChar(255)

  // 容量・特性
  totalCapacity         Decimal? @map("total_capacity") @db.Decimal(15, 2)
  capacityUnit          String?  @map("capacity_unit") @db.VarChar(20) // m³/坪
  hasTemperatureControl Boolean  @default(false) @map("has_temperature_control")
  hasHumidityControl    Boolean  @default(false) @map("has_humidity_control")

  // 月額費用（外部倉庫の場合）
  monthlyFee  Decimal?  @map("monthly_fee") @db.Decimal(15, 2)
  feeCurrency Currency? @map("fee_currency")

  // メモ
  notes String? @db.Text

  // ステータス
  status String @default("ACTIVE") @db.VarChar(20)

  // タイムスタンプ
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([companyId, locationCode])
  @@index([companyId, locationType])
  @@index([companyId, status])
  @@map("storage_locations")
}

enum StorageLocationType {
  // 国内
  OWN_WAREHOUSE_A // 自社倉庫A
  OWN_WAREHOUSE_B // 自社倉庫B
  EXTERNAL_WAREHOUSE // 外部倉庫
  OFFICE_STORAGE // オフィス内保管

  // 海外
  OVERSEAS_SUPPLIER // 海外仕入先（中国素材メーカー等）
  OVERSEAS_FACTORY // 海外工場（ベトナム縫製工場等）

  // 輸送中
  IN_TRANSIT_SEA // 海上輸送中
  IN_TRANSIT_AIR // 航空輸送中
  IN_TRANSIT_LAND // 陸送中
  CUSTOMS_CLEARANCE // 通関中

  // その他
  CLIENT_LOCATION // クライアント預け
  TEMPORARY // 一時保管
  OTHER
}

// =====================================================
// 在庫ロット（仕入先×品目×カラー×ロット）
// =====================================================

/// 在庫ロット
/// 気づき2で確定の在庫粒度：仕入先 × 品目 × カラー × ロット
model InventoryLot {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  // ロット番号
  lotNumber       String  @map("lot_number") @db.VarChar(100) // LOT-2026-0042-001
  internalLotCode String? @map("internal_lot_code") @db.VarChar(100) // 内部識別コード

  // 関連エンティティ
  materialId        String? @map("material_id") // マスター連動
  supplierId        String  @map("supplier_id") // 仕入先
  storageLocationId String  @map("storage_location_id")

  // 紐付くPO（仕入元）
  poId     String? @map("po_id")
  poItemId String? @map("po_item_id")

  // 品目情報（マスターから引用 or カスタム）
  itemName   String  @map("item_name") @db.VarChar(255)
  itemNameEn String? @map("item_name_en") @db.VarChar(255)

  // カラー・規格
  colorCode     String? @map("color_code") @db.VarChar(50)
  colorName     String? @map("color_name") @db.VarChar(100)
  pantone       String? @db.VarChar(50)
  specification String? @db.Text
  composition   String? @db.Text

  // 数量管理
  originalQuantity  Decimal  @map("original_quantity") @db.Decimal(15, 4) // 入荷時の数量
  currentQuantity   Decimal  @map("current_quantity") @db.Decimal(15, 4) // 現在残量
  reservedQuantity  Decimal  @default(0) @map("reserved_quantity") @db.Decimal(15, 4) // 引当済み（未出庫）
  availableQuantity Decimal? @map("available_quantity") @db.Decimal(15, 4) // 利用可能量（current - reserved）
  unit              String   @db.VarChar(20) // m / 個 / kg / 反

  // 単価情報（移動平均法）
  unitPrice Decimal  @map("unit_price") @db.Decimal(15, 4)
  totalCost Decimal? @map("total_cost") @db.Decimal(15, 2)
  currency  Currency @default(JPY)

  // JPY換算（多通貨時）
  unitPriceJpy          Decimal? @map("unit_price_jpy") @db.Decimal(15, 4)
  totalCostJpy          Decimal? @map("total_cost_jpy") @db.Decimal(15, 2)
  exchangeRateAtReceipt Decimal? @map("exchange_rate_at_receipt") @db.Decimal(15, 6)

  // 受入情報
  receivedDate     DateTime @map("received_date") @db.Date
  receivedByUserId String?  @map("received_by_user_id")

  // 品質情報
  qualityCheckStatus String?   @map("quality_check_status") @db.VarChar(50) // PENDING / PASSED / FAILED
  qualityCheckNotes  String?   @map("quality_check_notes") @db.Text
  qualityCheckedAt   DateTime? @map("quality_checked_at")

  // 期限管理
  expiryDate      DateTime? @map("expiry_date") @db.Date // 保管期限
  manufactureDate DateTime? @map("manufacture_date") @db.Date // 製造日

  // 貿易データ（海外調達時）
  hsCode          String? @map("hs_code") @db.VarChar(20)
  originCountry   String? @map("origin_country") @db.VarChar(2)
  importDocNumber String? @map("import_doc_number") @db.VarChar(100)

  // ステータス
  status InventoryLotStatus @default(IN_STOCK)

  // 注意フラグ
  hasQualityIssue Boolean @default(false) @map("has_quality_issue")
  hasShortage     Boolean @default(false) @map("has_shortage")
  isLowStock      Boolean @default(false) @map("is_low_stock")
  isExcessStock   Boolean @default(false) @map("is_excess_stock")
  isNearExpiry    Boolean @default(false) @map("is_near_expiry")

  // 在庫タイプ
  inventoryType InventoryType @default(STANDARD) @map("inventory_type")

  // メモ
  notes String? @db.Text

  // タイムスタンプ
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // リレーション
  movements InventoryMovement[]

  @@unique([companyId, lotNumber])
  @@index([companyId, materialId])
  @@index([companyId, supplierId])
  @@index([companyId, storageLocationId])
  @@index([companyId, status])
  @@index([companyId, inventoryType])
  @@index([poId])
  @@index([expiryDate])
  @@index([receivedDate])
  @@map("inventory_lots")
}

enum InventoryLotStatus {
  PENDING_RECEIPT // 入荷待ち
  IN_STOCK // 在庫中
  PARTIALLY_USED // 一部使用済み
  DEPLETED // 使い切り
  EXPIRED // 期限切れ
  DAMAGED // 破損
  LOST // 紛失
  RETURNED // 返品済み
  WRITTEN_OFF // 損失計上済み
  IN_TRANSIT // 輸送中
}

enum InventoryType {
  STANDARD // 標準在庫
  ORIGINAL_FABRIC // オリジナル生地（先行発注）
  CLIENT_CONSIGNED // クライアント預かり
  FACTORY_CONSIGNED // 工場内在庫（CMT契約等）
  SAMPLE // サンプル材料
  RETURNED // 返品在庫
}

// =====================================================
// 入出庫履歴
// =====================================================

/// 入出庫履歴
/// すべての在庫変動を完全記録
model InventoryMovement {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  // 関連ロット
  inventoryLotId String @map("inventory_lot_id")

  // 移動タイプ
  movementType      InventoryMovementType @map("movement_type")
  movementDirection MovementDirection     @map("movement_direction") // IN / OUT / INTERNAL

  // 数量
  quantity Decimal @db.Decimal(15, 4)
  unit     String  @db.VarChar(20)

  // 単価（移動時点）
  unitPriceAtMovement Decimal? @map("unit_price_at_movement") @db.Decimal(15, 4)
  totalValue          Decimal? @map("total_value") @db.Decimal(15, 2)
  currency            Currency @default(JPY)

  // 移動前後の残量（監査用）
  quantityBefore Decimal? @map("quantity_before") @db.Decimal(15, 4)
  quantityAfter  Decimal? @map("quantity_after") @db.Decimal(15, 4)

  // 移動元・移動先（場所間移動の場合）
  fromLocationId String? @map("from_location_id")
  toLocationId   String? @map("to_location_id")

  // 関連エンティティ（出庫の場合）
  productId          String? @map("product_id") // 紐付け品番
  skuId              String? @map("sku_id")
  poId               String? @map("po_id") // 関連PO
  woId               String? @map("wo_id") // 関連WO
  soId               String? @map("so_id") // 関連SO
  sampleProductionId String? @map("sample_production_id") // 関連サンプル

  // 配分情報（SHARED の場合）
  allocationId String? @map("allocation_id") // PoAllocation

  // 出庫先（工場への支給等）
  destinationType String? @map("destination_type") @db.VarChar(50) // factory / contractor / external
  destinationId   String? @map("destination_id") @db.VarChar(255)

  // 検品結果（入庫の場合）
  qualityCheckPassed Boolean? @map("quality_check_passed")
  qualityNotes       String?  @map("quality_notes") @db.Text

  // 理由・メモ
  reason String? @db.VarChar(255)
  notes  String? @db.Text

  // 担当者
  performedByUserId String?  @map("performed_by_user_id")
  performedAt       DateTime @default(now()) @map("performed_at")

  // 承認情報（重要な移動の場合）
  requiresApproval Boolean   @default(false) @map("requires_approval")
  approvedByUserId String?   @map("approved_by_user_id")
  approvedAt       DateTime? @map("approved_at")

  // タイムスタンプ
  createdAt DateTime @default(now()) @map("created_at")

  // リレーション
  inventoryLot InventoryLot @relation(fields: [inventoryLotId], references: [id], onDelete: Cascade)

  @@index([companyId, performedAt])
  @@index([inventoryLotId, performedAt])
  @@index([productId])
  @@index([skuId])
  @@index([movementType])
  @@map("inventory_movements")
}

enum InventoryMovementType {
  // 入庫系
  RECEIPT_FROM_PO // PO検収（入荷）
  RECEIPT_FROM_FACTORY // 工場からの戻し
  RECEIPT_FROM_RETURN // 返品入庫
  RECEIPT_FROM_OTHER // その他入庫

  // 出庫系
  ISSUE_FOR_PRODUCTION // 量産用出庫
  ISSUE_FOR_SAMPLE // サンプル用出庫
  ISSUE_FOR_FACTORY // 工場への支給
  ISSUE_FOR_CONTRACTOR // 外注先への支給
  ISSUE_FOR_CLIENT // クライアント買取

  // 内部移動
  TRANSFER_BETWEEN_LOCATIONS // 場所間移動
  TRANSFER_TO_FACTORY_STOCK // 工場在庫へ移動

  // 調整系
  ADJUSTMENT_INCREASE // 増加調整（棚卸し益等）
  ADJUSTMENT_DECREASE // 減少調整（棚卸し損等）
  WRITE_OFF // 損失計上
  DAMAGE // 破損処理
  LOSS // 紛失処理
  EXPIRY // 期限切れ処理

  // 余剰処理
  SURPLUS_RETURN // 在庫戻し（余剰生地）
  SURPLUS_CLIENT_BUYBACK // クライアント買取（余剰）
}

enum MovementDirection {
  IN // 入庫
  OUT // 出庫
  INTERNAL // 内部移動
}

// =====================================================
// 在庫評価
// =====================================================

/// 在庫評価スナップショット
/// 月次・四半期・年次の在庫評価を記録
/// 移動平均法での評価額（仕様書5.2で確定）
model InventoryValuation {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  // 評価対象期間
  valuationDate DateTime            @map("valuation_date") @db.Date
  periodType    ValuationPeriodType @map("period_type") // MONTHLY / QUARTERLY / YEARLY

  // 評価方法
  valuationMethod ValuationMethod @default(MOVING_AVERAGE) @map("valuation_method")

  // 集計データ
  totalLots     Int      @default(0) @map("total_lots")
  totalQuantity Decimal? @map("total_quantity") @db.Decimal(15, 4)
  totalValueJpy Decimal  @map("total_value_jpy") @db.Decimal(15, 2)

  // タイプ別内訳（JSON）
  breakdownByType Json? @map("breakdown_by_type")
  // 例：{ standard: 5000000, original_fabric: 1500000, ... }

  // 場所別内訳
  breakdownByLocation Json? @map("breakdown_by_location")

  // カテゴリ別内訳（生地・副資材等）
  breakdownByCategory Json? @map("breakdown_by_category")

  // 為替レート使用情報
  exchangeRatesUsed Json? @map("exchange_rates_used")

  // ステータス
  status String @default("DRAFT") @db.VarChar(20)

  // 承認情報
  approvedByUserId String?   @map("approved_by_user_id")
  approvedAt       DateTime? @map("approved_at")

  // メモ
  notes String? @db.Text

  // 作成者
  createdByUserId String? @map("created_by_user_id")

  // タイムスタンプ
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([companyId, valuationDate, periodType])
  @@index([companyId, valuationDate])
  @@map("inventory_valuations")
}

enum ValuationPeriodType {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
  AD_HOC // 任意時点
}

enum ValuationMethod {
  MOVING_AVERAGE // 移動平均法（標準）
  FIFO // 先入先出法
  LIFO // 後入先出法（日本では非推奨）
  SPECIFIC_IDENTIFICATION // 個別法
}

// =====================================================
// 在庫アラート
// =====================================================

/// 在庫アラート
/// 仕様書5.2で確定の3種：在庫切れ警告 / 在庫過剰警告 / 期限切れ警告
model InventoryAlert {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  // アラートタイプ
  alertType InventoryAlertType @map("alert_type")
  severity  AlertSeverity      @default(MEDIUM)

  // 対象
  inventoryLotId    String? @map("inventory_lot_id")
  materialId        String? @map("material_id")
  storageLocationId String? @map("storage_location_id")

  // アラート内容
  title   String @db.VarChar(255)
  message String @db.Text
  details Json?

  // 推奨アクション
  recommendedAction String? @map("recommended_action") @db.Text

  // ステータス
  status AlertStatus @default(ACTIVE)

  // 確認情報
  acknowledgedAt       DateTime? @map("acknowledged_at")
  acknowledgedByUserId String?   @map("acknowledged_by_user_id")
  acknowledgmentNotes  String?   @map("acknowledgment_notes") @db.Text

  // 解決情報
  resolvedAt       DateTime? @map("resolved_at")
  resolvedByUserId String?   @map("resolved_by_user_id")
  resolutionNotes  String?   @map("resolution_notes") @db.Text

  // 通知履歴
  notifiedAt      DateTime? @map("notified_at")
  notifiedUserIds Json?     @map("notified_user_ids")

  // 発生情報
  triggeredAt DateTime @default(now()) @map("triggered_at")
  triggerData Json?    @map("trigger_data") // 発生時の状態

  // タイムスタンプ
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([companyId, alertType, status])
  @@index([companyId, severity, status])
  @@index([inventoryLotId])
  @@index([triggeredAt])
  @@map("inventory_alerts")
}

enum InventoryAlertType {
  // 仕様書5.2の3種類
  LOW_STOCK // 在庫切れ警告（最小在庫数を下回る）
  EXCESS_STOCK // 在庫過剰警告（最大在庫数を超える）
  EXPIRY_WARNING // 期限切れ警告（60日前 / 30日前 / 当日）

  // 追加アラート
  QUALITY_ISSUE // 品質問題
  LOST_OR_DAMAGED // 紛失・破損
  DELIVERY_DELAY // 入荷遅延
  ALLOCATION_CONFLICT // 配分の不整合
  COST_DEVIATION // 単価の異常変動
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertStatus {
  ACTIVE
  ACKNOWLEDGED
  RESOLVED
  DISMISSED
  EXPIRED
}

// =====================================================
// 完成品在庫
// =====================================================

/// 完成品在庫
/// 仕様書5.2で確定：SKU単位で管理
model FinishedGoodsInventory {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  // 関連SKU
  skuId     String @map("sku_id")
  productId String @map("product_id")

  // 保管場所
  storageLocationId String @map("storage_location_id")

  // 数量
  totalProduced  Int @default(0) @map("total_produced") // 累計生産数
  totalDelivered Int @default(0) @map("total_delivered") // 累計納品数
  currentStock   Int @default(0) @map("current_stock") // 現在在庫
  reservedStock  Int @default(0) @map("reserved_stock") // 引当済み
  availableStock Int @default(0) @map("available_stock") // 利用可能
  defectStock    Int @default(0) @map("defect_stock") // 不良品在庫

  // 評価額（原価）
  averageCost Decimal? @map("average_cost") @db.Decimal(15, 4)
  totalValue  Decimal? @map("total_value") @db.Decimal(15, 2)
  currency    Currency @default(JPY)

  // 受注消化率（自動計算）
  totalOrdered    Int?     @map("total_ordered")
  fulfillmentRate Decimal? @map("fulfillment_rate") @db.Decimal(5, 2) // %

  // ステータス
  status String @default("ACTIVE") @db.VarChar(20)

  // メモ
  notes String? @db.Text

  // タイムスタンプ
  lastUpdatedAt DateTime @default(now()) @map("last_updated_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // リレーション
  movements FinishedGoodsMovement[]

  @@unique([skuId, storageLocationId])
  @@index([companyId, productId])
  @@index([companyId, skuId])
  @@map("finished_goods_inventory")
}

/// 完成品入出庫履歴
model FinishedGoodsMovement {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  // 関連在庫
  finishedGoodsId String @map("finished_goods_id")

  // 移動タイプ
  movementType      FinishedGoodsMovementType @map("movement_type")
  movementDirection MovementDirection         @map("movement_direction")

  // 数量
  quantity       Int
  defectQuantity Int? @map("defect_quantity")

  // 関連エンティティ
  woId           String? @map("wo_id") // 量産WOからの入庫
  soId           String? @map("so_id") // SOへの出庫
  deliveryNoteId String? @map("delivery_note_id") // 納品書（後のステップ）

  // 出庫先
  deliveryDestinationId String? @map("delivery_destination_id")

  // 入庫時の品質情報
  qualityCheckPassed Boolean? @map("quality_check_passed")
  qualityNotes       String?  @map("quality_notes") @db.Text
  defectReason       String?  @map("defect_reason") @db.Text

  // メモ
  reason String? @db.VarChar(255)
  notes  String? @db.Text

  // 担当者
  performedByUserId String?  @map("performed_by_user_id")
  performedAt       DateTime @default(now()) @map("performed_at")

  // タイムスタンプ
  createdAt DateTime @default(now()) @map("created_at")

  finishedGoods FinishedGoodsInventory @relation(fields: [finishedGoodsId], references: [id], onDelete: Cascade)

  @@index([companyId, performedAt])
  @@index([finishedGoodsId, performedAt])
  @@index([woId])
  @@index([soId])
  @@map("finished_goods_movements")
}

enum FinishedGoodsMovementType {
  // 入庫
  PRODUCTION_RECEIPT // 量産完成品入庫
  RETURN_RECEIPT // 返品入庫
  ADJUSTMENT_IN // 調整入庫

  // 出庫
  SALES_DELIVERY // 受注納品
  SAMPLE_USE // サンプル使用
  INTERNAL_USE // 自社販売・社内使用
  GIFT // 贈呈

  // 不良処理
  DEFECT_REGISTRATION // 不良登録
  REWORK // やり直し
  WRITE_OFF // 損失処理
  DISPOSAL // 廃棄
  CLIENT_BUYBACK // クライアント買取

  // 内部移動
  TRANSFER // 場所間移動
}

// =====================================================
// 工場内在庫（海外工場への材料支給）
// =====================================================

/// 工場内在庫（海外工場への材料支給管理）
/// 気づき2で確定：消費ベース原価計上、未消費分は在庫扱い継続
model FactoryConsignedInventory {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  // 関連エンティティ
  factoryId      String  @map("factory_id")
  inventoryLotId String? @map("inventory_lot_id") // 元の在庫ロット
  productId      String? @map("product_id")

  // 品目情報
  itemName   String  @map("item_name") @db.VarChar(255)
  materialId String? @map("material_id")
  colorCode  String? @map("color_code") @db.VarChar(50)
  colorName  String? @map("color_name") @db.VarChar(100)

  // 数量管理
  consignedQuantity Decimal @map("consigned_quantity") @db.Decimal(15, 4) // 支給数量
  consumedQuantity  Decimal @default(0) @map("consumed_quantity") @db.Decimal(15, 4) // 消費数量
  remainingQuantity Decimal @map("remaining_quantity") @db.Decimal(15, 4) // 残量
  unit              String  @db.VarChar(20)

  // 単価（原価計上の基礎）
  unitCost            Decimal  @map("unit_cost") @db.Decimal(15, 4)
  totalConsignedValue Decimal? @map("total_consigned_value") @db.Decimal(15, 2)
  totalConsumedValue  Decimal? @map("total_consumed_value") @db.Decimal(15, 2)
  remainingValue      Decimal? @map("remaining_value") @db.Decimal(15, 2)
  currency            Currency @default(JPY)

  // 支給情報
  consignedDate DateTime @map("consigned_date") @db.Date
  consignedWoId String?  @map("consigned_wo_id") // CMT契約等のWO

  // ステータス
  status FactoryConsignedStatus @default(ACTIVE)

  // 返却情報（残った材料の処理）
  returnedQuantity Decimal?  @map("returned_quantity") @db.Decimal(15, 4)
  returnedDate     DateTime? @map("returned_date") @db.Date
  dispositionType  String?   @map("disposition_type") @db.VarChar(50)
  // returned / kept_at_factory / used_for_other / written_off

  // メモ
  notes String? @db.Text

  // タイムスタンプ
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // リレーション
  consumptionRecords FactoryConsumptionRecord[]

  @@index([companyId, factoryId])
  @@index([companyId, status])
  @@index([inventoryLotId])
  @@index([productId])
  @@map("factory_consigned_inventory")
}

enum FactoryConsignedStatus {
  ACTIVE // 工場内に在庫あり
  FULLY_CONSUMED // 全消費済み
  PARTIALLY_RETURNED // 一部返却
  FULLY_RETURNED // 全返却
  WRITTEN_OFF // 損失計上
}

/// 工場消費記録
/// 工場が支給材料を消費した記録（原価計上の根拠）
model FactoryConsumptionRecord {
  id                 String @id @default(uuid())
  factoryConsignedId String @map("factory_consigned_id")

  // 消費数量
  consumedQuantity Decimal @map("consumed_quantity") @db.Decimal(15, 4)
  unit             String  @db.VarChar(20)

  // 原価計上額
  cogsAmount Decimal  @map("cogs_amount") @db.Decimal(15, 2)
  currency   Currency @default(JPY)

  // 関連エンティティ
  productId String? @map("product_id")
  woId      String? @map("wo_id")

  // 報告情報
  reportedByFactory Boolean @default(true) @map("reported_by_factory")
  reportSource      String? @map("report_source") @db.VarChar(100) // メール / システム入力等

  // 確認情報
  verifiedByUserId String?   @map("verified_by_user_id")
  verifiedAt       DateTime? @map("verified_at")

  // メモ
  notes String? @db.Text

  // タイムスタンプ
  consumedDate DateTime @map("consumed_date") @db.Date
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  factoryConsigned FactoryConsignedInventory @relation(fields: [factoryConsignedId], references: [id], onDelete: Cascade)

  @@index([factoryConsignedId, consumedDate])
  @@index([productId])
  @@map("factory_consumption_records")
}

// =====================================================
// 棚卸し
// =====================================================

/// 棚卸し
/// 仕様書5.2で確定：差異の登録・原因記録・在庫調整
model Stocktaking {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  // 棚卸し番号
  stocktakingNumber String @map("stocktaking_number") @db.VarChar(50) // ST-2026-001

  // タイトル
  title String @db.VarChar(255)

  // 対象範囲
  scopeType           StocktakingScope @map("scope_type")
  storageLocationIds  Json?            @map("storage_location_ids") // 対象場所
  materialCategoryIds Json?            @map("material_category_ids") // 対象カテゴリ

  // 期間
  scheduledDate DateTime  @map("scheduled_date") @db.Date
  startedAt     DateTime? @map("started_at")
  completedAt   DateTime? @map("completed_at")

  // ステータス
  status StocktakingStatus @default(PLANNED)

  // 集計
  totalItemsPlanned  Int @default(0) @map("total_items_planned")
  totalItemsCounted  Int @default(0) @map("total_items_counted")
  totalDiscrepancies Int @default(0) @map("total_discrepancies")

  // 差異額
  totalIncreaseAmount Decimal? @map("total_increase_amount") @db.Decimal(15, 2)
  totalDecreaseAmount Decimal? @map("total_decrease_amount") @db.Decimal(15, 2)
  netAdjustmentAmount Decimal? @map("net_adjustment_amount") @db.Decimal(15, 2)
  currency            Currency @default(JPY)

  // 担当者
  responsibleUserId  String? @map("responsible_user_id")
  participantUserIds Json?   @map("participant_user_ids")

  // 承認情報
  approvedByUserId String?   @map("approved_by_user_id")
  approvedAt       DateTime? @map("approved_at")

  // メモ
  notes String? @db.Text

  // タイムスタンプ
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // リレーション
  items StocktakingItem[]

  @@unique([companyId, stocktakingNumber])
  @@index([companyId, status])
  @@index([scheduledDate])
  @@map("stocktakings")
}

enum StocktakingScope {
  FULL // 全在庫
  BY_LOCATION // 場所別
  BY_CATEGORY // カテゴリ別
  BY_SUPPLIER // 仕入先別
  SPOT_CHECK // 抜き取り
}

enum StocktakingStatus {
  PLANNED // 計画中
  IN_PROGRESS // 実施中
  COUNTING_COMPLETED // カウント完了
  RECONCILING // 差異調整中
  PENDING_APPROVAL // 承認待ち
  APPROVED // 承認済み
  COMPLETED // 完了（在庫反映済み）
  CANCELLED // キャンセル
}

/// 棚卸し明細
model StocktakingItem {
  id            String @id @default(uuid())
  stocktakingId String @map("stocktaking_id")

  // 対象ロット
  inventoryLotId String @map("inventory_lot_id")

  // システム上の数量
  systemQuantity Decimal @map("system_quantity") @db.Decimal(15, 4)

  // 実地カウント
  countedQuantity Decimal? @map("counted_quantity") @db.Decimal(15, 4)
  unit            String   @db.VarChar(20)

  // 差異
  discrepancyQuantity Decimal? @map("discrepancy_quantity") @db.Decimal(15, 4) // counted - system
  discrepancyValue    Decimal? @map("discrepancy_value") @db.Decimal(15, 2)

  // 差異の原因
  discrepancyReason DiscrepancyReason? @map("discrepancy_reason")
  reasonDetails     String?            @map("reason_details") @db.Text

  // 処理方法
  adjustmentType AdjustmentType? @map("adjustment_type")

  // カウント情報
  countedByUserId String?   @map("counted_by_user_id")
  countedAt       DateTime? @map("counted_at")

  // 写真記録（オプション）
  photoUrls Json? @map("photo_urls")

  // メモ
  notes String? @db.Text

  // タイムスタンプ
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  stocktaking Stocktaking @relation(fields: [stocktakingId], references: [id], onDelete: Cascade)

  @@unique([stocktakingId, inventoryLotId])
  @@index([stocktakingId])
  @@index([inventoryLotId])
  @@map("stocktaking_items")
}

enum DiscrepancyReason {
  COUNTING_ERROR // カウントミス
  SYSTEM_ERROR // システム入力ミス
  THEFT // 盗難
  DAMAGE // 破損
  EXPIRY // 期限切れ
  UNRECORDED_USAGE // 未記録の使用
  UNRECORDED_RETURN // 未記録の返却
  MISPLACED // 配置ミス
  EVAPORATION // 経年変化（生地縮み等）
  OTHER
}

enum AdjustmentType {
  STOCK_ADJUSTMENT // 在庫調整
  LOSS_ENTRY // 損失計上
  GAIN_ENTRY // 棚卸し益計上
  WRITE_OFF // 完全償却
  RECOUNT_NEEDED // 再カウント必要
  NO_ADJUSTMENT // 調整なし
}

// =====================================================
// 余剰生地処理
// =====================================================

/// 余剰生地処理
/// 仕様書5.2で確定：在庫戻し / 損失 / 買取 / 部分処理の手動選択
model SurplusDisposition {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  // 関連エンティティ
  productId      String  @map("product_id") // 元案件
  inventoryLotId String? @map("inventory_lot_id") // 元の在庫ロット
  clientId       String? @map("client_id") // 関連クライアント

  // 余剰情報
  itemName        String   @map("item_name") @db.VarChar(255)
  surplusQuantity Decimal  @map("surplus_quantity") @db.Decimal(15, 4)
  unit            String   @db.VarChar(20)
  unitCost        Decimal  @map("unit_cost") @db.Decimal(15, 4)
  totalValue      Decimal  @map("total_value") @db.Decimal(15, 2)
  currency        Currency @default(JPY)

  // 処理タイプ（複数の処理を組み合わせ可能）
  dispositionItems Json @map("disposition_items")
  // 例：[{type: "stock_return", quantity: 5, ...}, {type: "client_buyback", quantity: 3, ...}]

  // 処理内訳（自動計算）
  stockReturnQty      Decimal? @map("stock_return_qty") @db.Decimal(15, 4)
  lossEntryQty        Decimal? @map("loss_entry_qty") @db.Decimal(15, 4)
  clientBuybackQty    Decimal? @map("client_buyback_qty") @db.Decimal(15, 4)
  otherDispositionQty Decimal? @map("other_disposition_qty") @db.Decimal(15, 4)

  // クライアント買取の場合
  buybackUnitPrice   Decimal? @map("buyback_unit_price") @db.Decimal(15, 2)
  buybackTotalAmount Decimal? @map("buyback_total_amount") @db.Decimal(15, 2)
  buybackInvoiceId   String?  @map("buyback_invoice_id") // 関連請求書（後のステップ）

  // 損失計上の場合
  lossAmount Decimal? @map("loss_amount") @db.Decimal(15, 2)
  lossReason String?  @map("loss_reason") @db.VarChar(255)

  // 在庫戻しの場合
  newInventoryLotId String? @map("new_inventory_lot_id") // 戻し先ロット

  // ステータス
  status SurplusDispositionStatus @default(PENDING)

  // 決定情報
  decidedByUserId String?   @map("decided_by_user_id")
  decidedAt       DateTime? @map("decided_at")

  // 実行情報
  executedByUserId String?   @map("executed_by_user_id")
  executedAt       DateTime? @map("executed_at")

  // メモ
  notes String? @db.Text

  // タイムスタンプ
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([companyId, productId])
  @@index([companyId, status])
  @@index([inventoryLotId])
  @@index([clientId])
  @@map("surplus_dispositions")
}

enum SurplusDispositionStatus {
  PENDING // 処理待ち
  DECIDED // 処理方法決定済
  IN_PROGRESS // 処理中
  COMPLETED // 処理完了
  CANCELLED // キャンセル
}

