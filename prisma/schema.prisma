// =====================================================
// 仕入先発注（Purchase Orders）
// =====================================================

/// 仕入先発注（PO）
/// 生地・副資材・資材の発注
/// 3タイプ：仕様書発注 / オンライン発注 / 通常発注
model PurchaseOrder {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  // PO番号（PO-2026-0142）
  poNumber String @map("po_number") @db.VarChar(50)

  // 関連エンティティ
  supplierId       String  @map("supplier_id")
  primaryProductId String? @map("primary_product_id") // 主要品番（DIRECT時）

  // 発注タイプ（仕様書F-5で確定の3タイプ）
  poType PurchaseOrderType @map("po_type")

  // 配分タイプ（DIRECT / SHARED / STOCK）
  allocationType AllocationType @map("allocation_type")

  // メール件名（統一フォーマット用）
  emailSubject String? @map("email_subject") @db.VarChar(500)

  // タイトル・摘要
  title       String? @db.VarChar(255)
  description String? @db.Text

  // 通貨
  currency Currency @default(JPY)

  // 為替レート（発注時点）
  exchangeRateAtOrder Decimal? @map("exchange_rate_at_order") @db.Decimal(15, 6)

  // 金額情報
  subtotal    Decimal? @db.Decimal(15, 2)
  taxAmount   Decimal? @map("tax_amount") @db.Decimal(15, 2)
  totalAmount Decimal? @map("total_amount") @db.Decimal(15, 2)

  // JPY換算（多通貨時）
  totalAmountJpy Decimal? @map("total_amount_jpy") @db.Decimal(15, 2)

  // 支払条件
  paymentTermType PaymentTermType? @map("payment_term_type")
  paymentDueDate  DateTime?        @map("payment_due_date") @db.Date

  // 国際送金（海外発注時）
  isInternational Boolean   @default(false) @map("is_international")
  bankFeeAmount   Decimal?  @map("bank_fee_amount") @db.Decimal(15, 2)
  bankFeeCurrency Currency? @map("bank_fee_currency")

  // 納期情報
  expectedDeliveryDate DateTime? @map("expected_delivery_date") @db.Date
  actualDeliveryDate   DateTime? @map("actual_delivery_date") @db.Date
  isDeliveryDelayed    Boolean   @default(false) @map("is_delivery_delayed")

  // 納品先
  deliveryAddress String? @map("delivery_address") @db.Text
  deliveryNotes   String? @map("delivery_notes") @db.Text

  // 貿易書類連動（海外時、ステップ9で実装）
  hasTradeDocuments Boolean @default(false) @map("has_trade_documents")

  // 言語設定（発注書出力時）
  outputLanguage Language @default(JA) @map("output_language")

  // テンプレート
  templateId String? @map("template_id") // 発注書テンプレート

  // PDF出力
  poPdfUrl         String?   @map("po_pdf_url") @db.VarChar(500)
  poPdfGeneratedAt DateTime? @map("po_pdf_generated_at")

  // ステータス
  status PurchaseOrderStatus @default(DRAFT)

  // 送付情報
  sentAt       DateTime? @map("sent_at")
  sentMethod   String?   @map("sent_method") @db.VarChar(50) // email / fax / system / online
  sentTo       String?   @map("sent_to") @db.VarChar(255)
  sentByUserId String?   @map("sent_by_user_id")

  // 承認情報
  approvedAt       DateTime? @map("approved_at")
  approvedByUserId String?   @map("approved_by_user_id")

  // 受領確認（仕入先からの返信）
  acknowledgedAt      DateTime? @map("acknowledged_at")
  acknowledgmentNotes String?   @map("acknowledgment_notes") @db.Text

  // 検収
  receivedAt           DateTime? @map("received_at")
  receivedByUserId     String?   @map("received_by_user_id")
  receivedQualityCheck String?   @map("received_quality_check") @db.Text

  // 月次ステータス確認（AI下書き）
  lastStatusCheckAt DateTime? @map("last_status_check_at")

  // 担当者
  createdByUserId  String? @map("created_by_user_id")
  assignedToUserId String? @map("assigned_to_user_id")

  // メモ
  internalNotes String? @map("internal_notes") @db.Text
  supplierNotes String? @map("supplier_notes") @db.Text

  // タイムスタンプ
  orderDate DateTime  @default(now()) @map("order_date") @db.Date
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // リレーション
  items       PoItem[]
  allocations PoAllocation[]

  @@unique([companyId, poNumber])
  @@index([companyId, supplierId])
  @@index([companyId, status])
  @@index([companyId, primaryProductId])
  @@index([companyId, allocationType])
  @@index([companyId, orderDate])
  @@index([expectedDeliveryDate])
  @@map("purchase_orders")
}

enum PurchaseOrderType {
  SPEC_BASED // 仕様書発注（副資材、メール/FAX/PDF送付）
  ONLINE // オンライン発注（CAB等、履歴記録のみ）
  STANDARD // 通常発注（縫製仕様書+数量明細添付）
}

enum AllocationType {
  DIRECT // 1品番専用
  SHARED // 複数品番に配分（1反を3品番に按分等）
  STOCK // 在庫プール経由（オリジナル生地の先行発注）
}

enum PurchaseOrderStatus {
  DRAFT // ドラフト
  PENDING_APPROVAL // 承認待ち
  APPROVED // 承認済み
  SENT // 送付済み
  ACKNOWLEDGED // 仕入先確認済み
  IN_PRODUCTION // 生産中（仕入先側）
  SHIPPED // 出荷済み
  RECEIVED // 検収済み
  COMPLETED // 完了
  CANCELLED // キャンセル
  ON_HOLD // 保留
}

/// PO明細
model PoItem {
  id   String @id @default(uuid())
  poId String @map("po_id")

  // 明細順序
  itemOrder Int @map("item_order")

  // 品目情報
  materialId       String? @map("material_id")
  customItemName   String? @map("custom_item_name") @db.VarChar(255)
  customItemNameEn String? @map("custom_item_name_en") @db.VarChar(255)
  description      String? @db.Text

  // 仕様
  specification String? @db.Text
  color         String? @db.VarChar(100)
  colorCode     String? @map("color_code") @db.VarChar(50)
  pantone       String? @db.VarChar(50)

  // 数量
  quantity Decimal @db.Decimal(15, 4)
  unit     String  @db.VarChar(20) // m / 個 / kg

  // 単価
  unitPrice Decimal  @map("unit_price") @db.Decimal(15, 4)
  currency  Currency @default(JPY)

  // 小計（自動計算）
  subtotal Decimal @db.Decimal(15, 2)

  // JPY換算
  subtotalJpy Decimal? @map("subtotal_jpy") @db.Decimal(15, 2)

  // 貿易データ
  hsCode        String? @map("hs_code") @db.VarChar(20)
  originCountry String? @map("origin_country") @db.VarChar(2)

  // 数量検収
  receivedQuantity Decimal? @map("received_quantity") @db.Decimal(15, 4)
  shortage         Decimal? @map("shortage") @db.Decimal(15, 4)

  // メモ
  notes String? @db.Text

  // タイムスタンプ
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  po PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)

  @@index([poId, itemOrder])
  @@index([materialId])
  @@map("po_items")
}

/// PO配分テーブル
/// SHARED/STOCK の場合、複数品番への按分を管理
model PoAllocation {
  id       String  @id @default(uuid())
  poId     String  @map("po_id")
  poItemId String? @map("po_item_id") // 特定明細の配分の場合

  // 配分先
  productId String @map("product_id") // 配分先品番

  // 配分量
  allocatedQuantity Decimal  @map("allocated_quantity") @db.Decimal(15, 4)
  allocatedAmount   Decimal? @map("allocated_amount") @db.Decimal(15, 2)
  allocationPercent Decimal? @map("allocation_percent") @db.Decimal(5, 2)

  // 配分タイプ詳細
  allocationReason String? @map("allocation_reason") @db.Text

  // ステータス
  status String @default("ACTIVE") @db.VarChar(20)

  // タイムスタンプ
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  po PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)

  @@index([poId])
  @@index([productId])
  @@index([poItemId])
  @@map("po_allocations")
}

// =====================================================
// 工場発注（Work Orders）
// =====================================================

/// 工場発注（WO）
/// 縫製・加工・パターン外注等
model WorkOrder {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  // WO番号（WO-2026-0058）
  woNumber String @map("wo_number") @db.VarChar(50)

  // 関連エンティティ
  factoryId    String? @map("factory_id") // 工場の場合
  contractorId String? @map("contractor_id") // 外注先（パタンナー等）の場合
  productId    String? @map("product_id") // 紐付け品番
  modelCodeId  String? @map("model_code_id") // パターン関連の場合

  // 作業タイプ
  workType     WorkOrderType     @map("work_type")
  workCategory WorkOrderCategory @map("work_category") // 仕様書F-5の発注種類タグ

  // タイトル・摘要
  title       String? @db.VarChar(255)
  description String? @db.Text

  // 通貨
  currency Currency @default(JPY)

  // 為替レート
  exchangeRateAtOrder Decimal? @map("exchange_rate_at_order") @db.Decimal(15, 6)

  // 金額情報
  subtotal       Decimal? @db.Decimal(15, 2)
  taxAmount      Decimal? @map("tax_amount") @db.Decimal(15, 2)
  totalAmount    Decimal? @map("total_amount") @db.Decimal(15, 2)
  totalAmountJpy Decimal? @map("total_amount_jpy") @db.Decimal(15, 2)

  // 数量情報
  totalQuantity Int? @map("total_quantity")

  // CMT等の場合の材料情報
  isCmtContract    Boolean @default(false) @map("is_cmt_contract")
  cmtMaterialNotes String? @map("cmt_material_notes") @db.Text

  // 連動仕様書バージョン
  specificationVersion String? @map("specification_version") @db.VarChar(20)

  // 連動パターンバージョン（pattern/grading の場合）
  patternVersionId String? @map("pattern_version_id")

  // サンプル製作セットへの紐付け
  samplProductionId String? @map("sample_production_id")
  sampleRound       String? @map("sample_round") @db.VarChar(10) // 1st/2nd/3rd

  // 支払条件
  paymentTermType PaymentTermType? @map("payment_term_type")
  paymentDueDate  DateTime?        @map("payment_due_date") @db.Date

  // 国際取引（海外工場時）
  isInternational Boolean @default(false) @map("is_international")

  // 納期情報
  expectedDeliveryDate DateTime? @map("expected_delivery_date") @db.Date
  actualDeliveryDate   DateTime? @map("actual_delivery_date") @db.Date
  isDeliveryDelayed    Boolean   @default(false) @map("is_delivery_delayed")

  // 納品先
  deliveryAddress String? @map("delivery_address") @db.Text

  // 貿易書類連動
  hasTradeDocuments Boolean @default(false) @map("has_trade_documents")

  // 言語設定
  outputLanguage Language @default(JA) @map("output_language")

  // テンプレート
  templateId String? @map("template_id")

  // PDF出力
  woPdfUrl         String?   @map("wo_pdf_url") @db.VarChar(500)
  woPdfGeneratedAt DateTime? @map("wo_pdf_generated_at")

  // ステータス
  status WorkOrderStatus @default(DRAFT)

  // 送付情報
  sentAt       DateTime? @map("sent_at")
  sentMethod   String?   @map("sent_method") @db.VarChar(50)
  sentByUserId String?   @map("sent_by_user_id")

  // 承認情報
  approvedAt       DateTime? @map("approved_at")
  approvedByUserId String?   @map("approved_by_user_id")

  // 受領確認
  acknowledgedAt      DateTime? @map("acknowledged_at")
  acknowledgmentNotes String?   @map("acknowledgment_notes") @db.Text

  // 進捗（量産時）
  productionStartedAt   DateTime? @map("production_started_at")
  productionCompletedAt DateTime? @map("production_completed_at")
  completedQuantity     Int?      @map("completed_quantity")
  defectQuantity        Int?      @map("defect_quantity")

  // ロイヤリティ計算（contractor の場合）
  royaltyAmount Decimal?  @map("royalty_amount") @db.Decimal(15, 2)
  royaltyPaidAt DateTime? @map("royalty_paid_at")

  // 月次ステータス確認
  lastStatusCheckAt DateTime? @map("last_status_check_at")

  // 担当者
  createdByUserId  String? @map("created_by_user_id")
  assignedToUserId String? @map("assigned_to_user_id")

  // メモ
  internalNotes String? @map("internal_notes") @db.Text
  factoryNotes  String? @map("factory_notes") @db.Text

  // タイムスタンプ
  orderDate DateTime  @default(now()) @map("order_date") @db.Date
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // リレーション
  items WoItem[]

  @@unique([companyId, woNumber])
  @@index([companyId, factoryId])
  @@index([companyId, contractorId])
  @@index([companyId, productId])
  @@index([companyId, modelCodeId])
  @@index([companyId, status])
  @@index([companyId, workType])
  @@index([companyId, workCategory])
  @@index([companyId, samplProductionId])
  @@index([expectedDeliveryDate])
  @@map("work_orders")
}

