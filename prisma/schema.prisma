/// アセットライブラリ
/// ロゴ・グラフィック・色見本・フォント・アイテム別デザイン画
/// タグ管理
model AssetLibrary {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  // 基本情報
  assetCode   String? @map("asset_code") @db.VarChar(50)
  assetName   String  @map("asset_name") @db.VarChar(255)
  assetNameEn String? @map("asset_name_en") @db.VarChar(255)
  description String? @db.Text

  // カテゴリ
  category    AssetCategory @map("category")
  subCategory String?       @map("sub_category") @db.VarChar(100)

  // ファイル情報
  fileUrl         String               @map("file_url") @db.VarChar(500)
  thumbnailUrl    String?              @map("thumbnail_url") @db.VarChar(500)
  fileName        String?              @map("file_name") @db.VarChar(255)
  fileType        String?              @map("file_type") @db.VarChar(50)
  fileSize        BigInt?              @map("file_size")
  storageLocation AssetStorageLocation @default(SYSTEM_R2) @map("storage_location")

  // カラー情報（色見本の場合）
  colorHex     String? @map("color_hex") @db.VarChar(7)
  colorPantone String? @map("color_pantone") @db.VarChar(50)
  colorRgb     String? @map("color_rgb") @db.VarChar(50)
  colorCmyk    String? @map("color_cmyk") @db.VarChar(50)

  // フォント情報（フォントの場合）
  fontFamily        String?   @map("font_family") @db.VarChar(255)
  fontLicense       String?   @map("font_license") @db.Text
  fontLicenseExpiry DateTime? @map("font_license_expiry") @db.Date

  // 紐付け（オプション、複数レベル）
  brandId           String? @map("brand_id")
  modelCodeId       String? @map("model_code_id")
  productCategoryId String? @map("product_category_id") // アイテムカテゴリ

  // 利用情報
  usageCount Int       @default(0) @map("usage_count")
  lastUsedAt DateTime? @map("last_used_at")

  // ステータス
  status String @default("ACTIVE") @db.VarChar(20)

  // 著作権
  copyrightOwner String? @map("copyright_owner") @db.VarChar(255)
  copyrightNotes String? @map("copyright_notes") @db.Text

  // 作成者
  uploadedByUserId String? @map("uploaded_by_user_id")

  // タイムスタンプ
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // リレーション
  tagLinks AssetTagLink[]

  @@index([companyId, category])
  @@index([brandId])
  @@index([modelCodeId])
  @@index([productCategoryId])
  @@map("asset_library")
}

enum AssetCategory {
  LOGO // ロゴ
  GRAPHIC // よく使うグラフィック
  COLOR_PALETTE // 色見本
  FONT // フォント
  ITEM_DESIGN // アイテム別デザイン画
  PATTERN_GRAPHIC // パターン素材
  ICON // アイコン
  ILLUSTRATION // イラスト
  PHOTO_REFERENCE // 参考写真
  TEMPLATE // テンプレート
  OTHER
}

enum AssetStorageLocation {
  SYSTEM_R2 // Cloudflare R2
  GOOGLE_DRIVE // Google Drive
  EXTERNAL_URL // 外部URL
}

/// アセットタグマスター
model AssetTag {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  tagName   String  @map("tag_name") @db.VarChar(100)
  tagNameEn String? @map("tag_name_en") @db.VarChar(100)
  tagColor  String? @map("tag_color") @db.VarChar(7) // 表示色

