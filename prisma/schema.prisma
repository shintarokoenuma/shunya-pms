// =====================================================
// shunya 生産管理システム Prisma スキーマ
// ステップ5：見積もりエンジン（核心機能）
// =====================================================

// =====================================================
// 見積もり（Quotations）
// =====================================================

/// 見積もり
/// 3タイプ（SAMPLE / MASS / FINAL）
/// バージョン管理あり、提出後ロック
model Quotation {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  // 見積もり番号（QT-2026-0142）
  quotationNumber String @map("quotation_number") @db.VarChar(50)

  // バージョン
  version       String  @db.VarChar(20) // v1.0 / v2.0
  versionNumber Int     @map("version_number")
  baseVersionId String? @map("base_version_id") // 前バージョン
  isLatest      Boolean @default(true) @map("is_latest") // 最新版フラグ

  // 関連エンティティ
  productId    String  @map("product_id")
  clientId     String  @map("client_id")
  collectionId String? @map("collection_id") // コレクション単位の見積もりの場合
  inquiryId    String? @map("inquiry_id")

  // 関連BOM
  bomId      String? @map("bom_id") // 連動するBOM版
  bomVersion String? @map("bom_version") @db.VarChar(20)

  // 見積もりタイプ
  quotationType QuotationType @map("quotation_type")

  // タイトル・説明
  title          String? @db.VarChar(255)
  description    String? @db.Text
  notesForClient String? @map("notes_for_client") @db.Text // クライアント向けメモ
  internalNotes  String? @map("internal_notes") @db.Text // 社内メモ

  // 通貨
  currency Currency @default(JPY)

  // 為替レート（作成時点で記録、変動を追跡）
  exchangeRateAtCreation Decimal?  @map("exchange_rate_at_creation") @db.Decimal(15, 6)
  exchangeRateSource     String?   @map("exchange_rate_source") @db.VarChar(50) // BOJ等
  exchangeRateDate       DateTime? @map("exchange_rate_date") @db.Date

  // 単価情報（メイン単価 or 階段単価）
  // 階段の場合は quotation_moq_tiers テーブル参照
  hasMoqTiers Boolean @default(true) @map("has_moq_tiers")

  // SAMPLE見積もりの場合のシンプル単価
  sampleQuantity  Int?     @map("sample_quantity")
  sampleUnitPrice Decimal? @map("sample_unit_price") @db.Decimal(15, 2)

  // 想定数量・金額（参考値）
  expectedQuantity Int?     @map("expected_quantity")
  expectedTotal    Decimal? @map("expected_total") @db.Decimal(15, 2)

  // ステータス
  status QuotationStatus @default(DRAFT)

  // 有効期限管理（論点9で確定：種類別）
  validFrom       DateTime @default(now()) @map("valid_from")
  validUntil      DateTime @map("valid_until")
  daysUntilExpiry Int?     @map("days_until_expiry") // 自動計算（バッチ）

  // 有効期限切れ
  isExpired Boolean   @default(false) @map("is_expired")
  expiredAt DateTime? @map("expired_at")

  // 為替変動チェック（論点9：±5%以内は保証）
  fxToleranceRate  Decimal   @default(5.00) @map("fx_tolerance_rate") @db.Decimal(5, 2) // ±5%
  fxAlertTriggered Boolean   @default(false) @map("fx_alert_triggered")
  fxAlertAt        DateTime? @map("fx_alert_at")

  // ロック状態（提出後は編集不可）
  isLocked       Boolean   @default(false) @map("is_locked")
  lockedAt       DateTime? @map("locked_at")
  lockedByUserId String?   @map("locked_by_user_id")

  // 提出・承認情報
  submittedAt       DateTime? @map("submitted_at")
  submittedByUserId String?   @map("submitted_by_user_id")

  approvedInternallyAt DateTime? @map("approved_internally_at")
  approvedByUserId     String?   @map("approved_by_user_id")

  clientApprovedAt    DateTime? @map("client_approved_at")
  clientApprovalNotes String?   @map("client_approval_notes") @db.Text

  rejectedAt       DateTime? @map("rejected_at")
  rejectionReason  String?   @map("rejection_reason") @db.Text
  rejectionDetails Json?     @map("rejection_details") // 構造化された却下理由

  // 受注に紐付いた場合
  isConvertedToOrder Boolean   @default(false) @map("is_converted_to_order")
  convertedAt        DateTime? @map("converted_at")

  // 緊急進行（論点9で確定）
  isEmergencyProgressing    Boolean   @default(false) @map("is_emergency_progressing")
  emergencyApprovedByUserId String?   @map("emergency_approved_by_user_id")
  emergencyApprovedAt       DateTime? @map("emergency_approved_at")
  emergencyRiskAcceptance   String?   @map("emergency_risk_acceptance") @db.VarChar(50)
  // shunya_absorb / client_request / supplier_recheck / cancel
  emergencyNotes            String?   @map("emergency_notes") @db.Text

  // 表示設定
  showInternalBreakdown Boolean  @default(false) @map("show_internal_breakdown") // 社内詳細を見せるか
  displayLanguage       Language @default(JA) @map("display_language")

  // 担当者
  createdByUserId  String? @map("created_by_user_id")
  assignedToUserId String? @map("assigned_to_user_id")

  // タイムスタンプ
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // リレーション
  moqTiers             QuotationMoqTier[]
  costBreakdowns       QuotationCostBreakdown[]
  approvalHistory      QuotationApprovalHistory[]
  multilingualVersions QuotationMultilingual[]
  pdfOutputs           QuotationPdfOutput[]

  @@unique([companyId, quotationNumber])
  @@index([companyId, productId])
  @@index([companyId, clientId])
  @@index([companyId, status])
  @@index([companyId, quotationType])
  @@index([validUntil, isExpired])
  @@index([isLatest, productId])
  @@map("quotations")
}

enum QuotationType {
  SAMPLE // サンプル見積もり（有効期限60日）
  MASS // 量産見積もり（MOQ階段、有効期限30日）
  FINAL // 最終見積もり（受注確定までの間有効）
  CUSTOM // カスタム見積もり
}

enum QuotationStatus {
  DRAFT // ドラフト（編集中）
  IN_REVIEW // 社内レビュー中
  APPROVED_INTERNAL // 社内承認済（提出可能）
  SUBMITTED // クライアント提出済（ロック）
  CLIENT_APPROVED // クライアント承認
  CLIENT_REJECTED // クライアント却下
  EXPIRED // 有効期限切れ
  CONVERTED // 受注確定（次工程に進行）
  CANCELLED // キャンセル
  ARCHIVED // アーカイブ
}

// =====================================================
// MOQ階段単価
// =====================================================

/// MOQ階段単価
/// 数量帯ごとの単価設定
/// MASS見積もりで必須、SAMPLE・FINALは任意
model QuotationMoqTier {
  id          String @id @default(uuid())
  quotationId String @map("quotation_id")

  // 階段順序
  tierOrder Int @map("tier_order") // 1, 2, 3...

  // 数量帯
  minQuantity Int  @map("min_quantity") // 例：100
  maxQuantity Int? @map("max_quantity") // 例：299（nullは無制限）

  // 単価
  unitPrice Decimal  @map("unit_price") @db.Decimal(15, 2)
  currency  Currency @default(JPY)

  // この階段が標準（推奨）か
  isRecommended Boolean @default(false) @map("is_recommended")

  // 階段の表示ラベル
  label String? @db.VarChar(100) // 例：「初回ロット」

  // 階段ごとのメモ
  notes String? @db.Text

  // 自動計算値
  totalAtMin Decimal? @map("total_at_min") @db.Decimal(15, 2) // 最小数量での合計
  totalAtMax Decimal? @map("total_at_max") @db.Decimal(15, 2) // 最大数量での合計

  // タイムスタンプ
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@unique([quotationId, tierOrder])
  @@index([quotationId])
  @@map("quotation_moq_tiers")
}

// =====================================================
// 原価明細（2層構造）
// =====================================================

/// 原価明細
/// 社内詳細（カテゴリ×項目）と社外集約（4項目）の2層構造
model QuotationCostBreakdown {
  id          String @id @default(uuid())
  quotationId String @map("quotation_id")

  // 表示用順序
  itemOrder Int @map("item_order")

  // 社外表示カテゴリ（4項目に集約）
  externalCategory ExternalCostCategory @map("external_category")

  // 社内詳細カテゴリ（細分化）
  internalCategory InternalCostCategory @map("internal_category")

  // 項目名
  itemName   String  @map("item_name") @db.VarChar(255)
  itemNameEn String? @map("item_name_en") @db.VarChar(255)

  // 仕入先・工場の紐付け（自動計算の根拠）
  supplierId        String? @map("supplier_id")
  factoryId         String? @map("factory_id")
  contractorId      String? @map("contractor_id")
  materialId        String? @map("material_id")
  expenseCategoryId String? @map("expense_category_id")

  // BOMからの引用（材料費）
  bomItemId String? @map("bom_item_id")

  // 数量・単価
  quantity  Decimal? @db.Decimal(15, 4)
  unit      String?  @db.VarChar(20)
  unitPrice Decimal? @map("unit_price") @db.Decimal(15, 4)

  // 計算方法（諸経費マスターと連動）
  calculationType CalculationType @default(FIXED) @map("calculation_type")

  // 原価（マージン適用前）
  costAmount   Decimal  @map("cost_amount") @db.Decimal(15, 4)
  costCurrency Currency @default(JPY) @map("cost_currency")

  // マージン情報
  marginRate   Decimal?      @map("margin_rate") @db.Decimal(5, 2) // 適用された%
  marginAmount Decimal?      @map("margin_amount") @db.Decimal(15, 4)
  marginSource MarginSource? @map("margin_source") // 4階層のどこから取得したか

  // 売価（マージン込み）
  sellingAmount Decimal? @map("selling_amount") @db.Decimal(15, 4)

  // JPY換算（多通貨時）
  costAmountJpy    Decimal? @map("cost_amount_jpy") @db.Decimal(15, 4)
  sellingAmountJpy Decimal? @map("selling_amount_jpy") @db.Decimal(15, 4)
  exchangeRateUsed Decimal? @map("exchange_rate_used") @db.Decimal(15, 6)

  // 表示制御
  showToClient Boolean @default(false) @map("show_to_client") // クライアントに見せるか

  // メモ
  notes String? @db.Text

  // タイムスタンプ
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([quotationId, itemOrder])
  @@index([quotationId, externalCategory])
  @@index([quotationId, internalCategory])
  @@map("quotation_cost_breakdowns")
}

/// 社外表示カテゴリ（4項目に集約、クライアント向け）
enum ExternalCostCategory {
