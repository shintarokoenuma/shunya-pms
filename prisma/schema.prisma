// =====================================================
// shunya 生産管理システム Prisma スキーマ
// ステップ2：マスター類（基盤データ）
// =====================================================

// =====================================================
// クライアントマスター（営業先データベース統合）
// =====================================================

/// クライアント（顧客）マスター
/// INQから自動登録される、営業先データベースとしても機能
model Client {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  // 基本情報
  clientCode  String  @map("client_code") @db.VarChar(50) // 内部識別コード
  companyName String  @map("company_name") @db.VarChar(255)
  legalEntity String? @map("legal_entity") @db.VarChar(255)

  // 取引先分類
  businessType ClientBusinessType @map("business_type")
  clientSize   ClientSize?        @map("client_size")

  // 連絡先
  postalCode   String? @map("postal_code") @db.VarChar(20)
  country      String  @default("JP") @db.VarChar(2) // ISO 3166-1 alpha-2
  prefecture   String? @db.VarChar(50)
  city         String? @db.VarChar(100)
  address      String? @db.Text
  addressLine2 String? @map("address_line2") @db.VarChar(255) // 建物名・部屋番号
  phone        String? @db.VarChar(50)
  fax          String? @db.VarChar(50)
  email        String? @db.VarChar(255)
  website      String? @db.VarChar(500)

  // 請求書発送先住所（マスター住所と異なる場合のみ入力）
  billingPostalCode   String? @map("billing_postal_code") @db.VarChar(20)
  billingPrefecture   String? @map("billing_prefecture") @db.VarChar(50)
  billingCity         String? @map("billing_city") @db.VarChar(100)
  billingAddress      String? @map("billing_address") @db.Text
  billingAddressLine2 String? @map("billing_address_line2") @db.VarChar(255)

  // 商品配送先住所（マスター住所と異なる場合のみ入力）
  shippingPostalCode   String? @map("shipping_postal_code") @db.VarChar(20)
  shippingPrefecture   String? @map("shipping_prefecture") @db.VarChar(50)
  shippingCity         String? @map("shipping_city") @db.VarChar(100)
  shippingAddress      String? @map("shipping_address") @db.Text
  shippingAddressLine2 String? @map("shipping_address_line2") @db.VarChar(255)

  // SNS
  instagram String? @db.VarChar(255)
  twitter   String? @db.VarChar(255)

  // 取引情報
  taxId                    String? @map("tax_id") @db.VarChar(50) // 適格請求書発行事業者番号
  isQualifiedInvoiceIssuer Boolean @default(true) @map("is_qualified_invoice_issuer")

  // 支払い条件
  paymentTermType    PaymentTermType @default(MONTHLY_CLOSING) @map("payment_term_type")
  closingDay         Int?            @map("closing_day") // 締日（1-31、31=月末）
  paymentMonthOffset Int?            @map("payment_month_offset") // 1=翌月、2=翌々月
  paymentDay         Int?            @map("payment_day") // 支払日（1-31、31=月末）

  // デポジット設定
  depositRequired   Boolean  @default(false) @map("deposit_required")
  depositPercentage Decimal? @map("deposit_percentage") @db.Decimal(5, 2) // 例：30.00

  // 通貨・言語
  preferredCurrency Currency @default(JPY) @map("preferred_currency")
  preferredLanguage Language @default(JA) @map("preferred_language")

  // 表示パターン（F-3 確定の4パターン）
  // A: 社内詳細10段階 / B: 簡略5段階 / C: 概要2段階 / D: 完全非開示
  displayPattern ClientDisplayPattern @default(B) @map("display_pattern")

  // 営業先データベース機能
  leadSource        LeadSource? @map("lead_source")
  referrer          String?     @db.VarChar(255)
  inquiryCount      Int         @default(0) @map("inquiry_count")
  successfulCount   Int         @default(0) @map("successful_count") // 案件化数
  totalRevenue      Decimal?    @map("total_revenue") @db.Decimal(15, 2)
  lastInquiryAt     DateTime?   @map("last_inquiry_at")
  lastTransactionAt DateTime?   @map("last_transaction_at")

  // パターン・デザイン所有権のデフォルト設定
  patternOwnership OwnershipType @default(SHUNYA) @map("pattern_ownership")
  designOwnership  OwnershipType @default(SHUNYA) @map("design_ownership")

  // 担当者
  primaryContactId String? @map("primary_contact_id")
  assignedToUserId String? @map("assigned_to_user_id")

  // メモ
  notes String? @db.Text

  // ステータス
  status ClientStatus @default(ACTIVE)

  // タイムスタンプ
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // リレーション
  contacts ClientContact[]
  brands   Brand[]
  buyers   Buyer[]

  @@unique([companyId, clientCode])
  @@index([companyId, status])
  @@index([companyId, businessType])
  @@index([companyId, leadSource])
  @@index([companyId, country])
  @@map("clients")
}

enum ClientBusinessType {
  APPAREL_BRAND // アパレルブランド
  SELECT_SHOP // セレクトショップ
  TRADING_COMPANY // 商社
  INDIVIDUAL // 個人
  WHOLESALE // 卸
  ONLINE_RETAILER // EC専門
  PRIVATE_BRAND // PB
  OTHER
}

enum ClientSize {
  INDIVIDUAL // 個人
  SMALL // 小規模（〜20名）
  MEDIUM // 中堅（〜100名）
  LARGE // 大手（100名超）
}

enum ClientDisplayPattern {
  A // 社内詳細10段階
  B // 簡略5段階
  C // 概要2段階
  D // 完全非開示
}

enum LeadSource {
  REFERRAL // 紹介
  WEB_SEARCH // Web検索
  EXHIBITION // 展示会
  SOCIAL_MEDIA // SNS
  EMAIL // メール
  PHONE // 電話
  EXISTING_CLIENT // 既存クライアント
  OTHER
}

enum PaymentTermType {
  MONTHLY_CLOSING // 月末締め払い
  DEPOSIT_COD // デポジット + COD（着金確認後出荷）
  ADVANCE_PAYMENT // 前払い
  CASH_ON_DELIVERY // 代引き
  LETTER_OF_CREDIT // L/C
  CUSTOM // カスタム条件
}

enum OwnershipType {
  SHUNYA // shunya所有
  CLIENT // クライアント所有
  SHARED // 共有
  CONTRACT_BASED // 契約による（個別案件で設定）
}

enum ClientStatus {
  ACTIVE
  PROSPECT // 見込み客
  PAUSED // 休止中
  ARCHIVED
  BLACKLIST
}

/// クライアントの担当者
model ClientContact {
  id        String @id @default(uuid())
  companyId String @map("company_id")
  clientId  String @map("client_id")

  // 個人情報
  firstName   String  @map("first_name") @db.VarChar(100)
  lastName    String  @map("last_name") @db.VarChar(100)
  displayName String? @map("display_name") @db.VarChar(200)
  jobTitle    String? @map("job_title") @db.VarChar(255)
  department  String? @db.VarChar(255)

  // 連絡先
  email  String? @db.VarChar(255)
  phone  String? @db.VarChar(50)
  mobile String? @db.VarChar(50)

  // ロール
  isPrimary         Boolean   @default(false) @map("is_primary")
  preferredLanguage Language? @map("preferred_language")

  // メモ
  notes String? @db.Text

  // タイムスタンプ
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // リレーション
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, isPrimary])
  @@map("client_contacts")
}

// =====================================================
// ブランドマスター
// =====================================================

/// ブランドマスター
/// 1クライアントが複数ブランドを持つ場合に対応
model Brand {
  id        String @id @default(uuid())
  companyId String @map("company_id")
  clientId  String @map("client_id")

  // 基本情報
  brandCode   String  @map("brand_code") @db.VarChar(20) // 略号（例：MK）
  brandName   String  @map("brand_name") @db.VarChar(255)
  brandNameEn String? @map("brand_name_en") @db.VarChar(255)

  // ブランディング
  logoUrl     String? @map("logo_url") @db.VarChar(500)
  brandColors Json?   @map("brand_colors") // 配色情報
  concept     String? @db.Text

  // 設定
  defaultMarginRate Decimal? @map("default_margin_rate") @db.Decimal(5, 2)

  // ステータス
  status BrandStatus @default(ACTIVE)

  // タイムスタンプ
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // リレーション
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([companyId, brandCode])
  @@index([clientId])
  @@map("brands")
}

enum BrandStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

// =====================================================
// 仕入先マスター
// =====================================================

/// 仕入先マスター（生地・副資材等）
model Supplier {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  // 基本情報
  supplierCode  String  @map("supplier_code") @db.VarChar(50)
  companyName   String  @map("company_name") @db.VarChar(255)
  companyNameEn String? @map("company_name_en") @db.VarChar(255)

  // 取扱品目
  supplierType SupplierType[] @map("supplier_type") // 複数選択可

  // 連絡先
  country      String  @default("JP") @db.VarChar(2)
  postalCode   String? @map("postal_code") @db.VarChar(20)
  prefecture   String? @db.VarChar(50)
  city         String? @db.VarChar(100)
  address      String? @db.Text
  addressLine2 String? @map("address_line2") @db.VarChar(255)
  addressEn    String? @map("address_en") @db.Text
  phone        String? @db.VarChar(50)
  fax          String? @db.VarChar(50)
  email        String? @db.VarChar(255)
  website      String? @db.VarChar(500)

  // 海外取引用
  chatTool          String?  @map("chat_tool") @db.VarChar(50) // WeChat / LINE / Zalo
  chatToolId        String?  @map("chat_tool_id") @db.VarChar(255)
  preferredLanguage Language @default(JA) @map("preferred_language")
  preferredCurrency Currency @default(JPY) @map("preferred_currency")
  timezone          String?  @db.VarChar(50)

  // 取引条件
  taxId                    String?         @map("tax_id") @db.VarChar(50) // 適格請求書発行事業者番号
  isQualifiedInvoiceIssuer Boolean         @default(true) @map("is_qualified_invoice_issuer")
  paymentTermType          PaymentTermType @default(MONTHLY_CLOSING) @map("payment_term_type")
  closingDay               Int?            @map("closing_day") // 締日（1-31、31=月末）
  paymentMonthOffset       Int?            @map("payment_month_offset") // 1=翌月、2=翌々月
  paymentDay               Int?            @map("payment_day") // 支払日（1-31、31=月末）

  // 国際送金情報
  bankName        String? @map("bank_name") @db.VarChar(255)
  bankSwiftCode   String? @map("bank_swift_code") @db.VarChar(20)
  bankIban        String? @map("bank_iban") @db.VarChar(50)
  bankAccountInfo Json?   @map("bank_account_info")

  // テンプレート
  poTemplateId String? @map("po_template_id") // 発注書テンプレート

  // 評価
  qualityRating  Int? @map("quality_rating") // 1-5
  deliveryRating Int? @map("delivery_rating") // 1-5
  priceRating    Int? @map("price_rating") // 1-5

  // 担当者
  assignedToUserId String? @map("assigned_to_user_id")

  // メモ
  notes String? @db.Text

  // ステータス
  status SupplierStatus @default(ACTIVE)

  // タイムスタンプ
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // リレーション
  contacts  SupplierContact[]
  materials Material[]

  @@unique([companyId, supplierCode])
  @@index([companyId, status])
  @@index([companyId, country])
  @@index([assignedToUserId])
  @@map("suppliers")
}

enum SupplierStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum SupplierType {
  FABRIC // 生地
  TRIM // 付属
  THREAD // 糸
  ACCESSORY // 副資材
  LABEL // ネーム
  PATTERN // パターン
  BODY // ボディ
  USED_CLOTHING // 古着
  OTHER // その他
}

/// 仕入先担当者
model SupplierContact {
  id         String @id @default(uuid())
  companyId  String @map("company_id")
  supplierId String @map("supplier_id")

  firstName   String  @map("first_name") @db.VarChar(100)
  lastName    String  @map("last_name") @db.VarChar(100)
  displayName String? @map("display_name") @db.VarChar(200)
  jobTitle    String? @map("job_title") @db.VarChar(255)
  department  String? @db.VarChar(255)

  email  String? @db.VarChar(255)
  phone  String? @db.VarChar(50)
  mobile String? @db.VarChar(50)

  isPrimary         Boolean   @default(false) @map("is_primary")
  preferredLanguage Language? @map("preferred_language")

  notes String? @db.Text

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId, isPrimary])
  @@map("supplier_contacts")
}

// =====================================================
// 工場マスター
// =====================================================

/// 工場マスター（縫製・加工・プリント等）
model Factory {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  // 基本情報
  factoryCode   String  @map("factory_code") @db.VarChar(50)
  factoryName   String  @map("factory_name") @db.VarChar(255)
  factoryNameEn String? @map("factory_name_en") @db.VarChar(255)

  // 工場タイプ
  factoryTypes FactoryType[] @map("factory_types") // 複数選択可

  // 契約形態
  contractTypes FactoryContractType[] @map("contract_types")

  // 連絡先（仕入先と同様）
  country      String  @default("JP") @db.VarChar(2)
  postalCode   String? @map("postal_code") @db.VarChar(20)
  prefecture   String? @db.VarChar(50)
  city         String? @db.VarChar(100)
  address      String? @db.Text
  addressLine2 String? @map("address_line2") @db.VarChar(255)
  addressEn    String? @map("address_en") @db.Text
  phone        String? @db.VarChar(50)
  fax          String? @db.VarChar(50)
  email        String? @db.VarChar(255)

  // 海外取引用
  chatTool          String?  @map("chat_tool") @db.VarChar(50)
  chatToolId        String?  @map("chat_tool_id") @db.VarChar(255)
  preferredLanguage Language @default(JA) @map("preferred_language")
  preferredCurrency Currency @default(JPY) @map("preferred_currency")
  timezone          String?  @db.VarChar(50)

  // 取引条件
  taxId                    String?         @map("tax_id") @db.VarChar(50)
  isQualifiedInvoiceIssuer Boolean         @default(true) @map("is_qualified_invoice_issuer")
  paymentTermType          PaymentTermType @default(MONTHLY_CLOSING) @map("payment_term_type")
  closingDay               Int?            @map("closing_day") // 締日（1-31、31=月末）
  paymentMonthOffset       Int?            @map("payment_month_offset") // 1=翌月、2=翌々月
  paymentDay               Int?            @map("payment_day") // 支払日（1-31、31=月末）

  // 国際送金情報
  bankName        String? @map("bank_name") @db.VarChar(255)
  bankSwiftCode   String? @map("bank_swift_code") @db.VarChar(20)
  bankIban        String? @map("bank_iban") @db.VarChar(50)
  bankAccountInfo Json?   @map("bank_account_info")

  // 製造キャパシティ
  monthlyCapacity     Int? @map("monthly_capacity") // 月間生産可能数
  minimumOrderQty     Int? @map("minimum_order_qty") // 最小ロット
  averageLeadTimeDays Int? @map("average_lead_time_days") // 標準リードタイム

  // 標準工賃（アイテムカテゴリ別、JSON）
  standardLaborRates Json? @map("standard_labor_rates")

  // 評価
  qualityRating  Int?     @map("quality_rating")
  deliveryRating Int?     @map("delivery_rating")
  priceRating    Int?     @map("price_rating")
  defectRate     Decimal? @map("defect_rate") @db.Decimal(5, 2) // 平均減産率

  // メモ
  notes String? @db.Text

  // 担当者（shunya 側）
  assignedToUserId String? @map("assigned_to_user_id")

  // ステータス
  status FactoryStatus @default(ACTIVE)

  // タイムスタンプ
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // リレーション
  contacts FactoryContact[]

  @@unique([companyId, factoryCode])
  @@index([companyId, status])
  @@index([companyId, country])
  @@index([assignedToUserId])
  @@map("factories")
}

enum FactoryType {
