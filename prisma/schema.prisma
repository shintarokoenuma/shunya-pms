// =====================================================
// shunya 生産管理システム Prisma スキーマ
// ステップ1：マルチテナント基盤
// =====================================================
// このファイルは段階的に構築されます。
// ステップ1〜10を順次追加していきます。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================
// マルチテナント基盤
// =====================================================

/// テナント（利用企業）
/// 1法人 = 1テナント
/// shunya自身はマスター管理者テナント
model Company {
  id          String  @id @default(uuid())
  companyName String  @map("company_name") @db.VarChar(255)
  legalEntity String? @map("legal_entity") @db.VarChar(255)

  // 日本の事業者情報
  taxId String? @map("tax_id") @db.VarChar(50) // 適格請求書発行事業者番号（T+13桁）

  // テナントタイプ
  tenantType TenantType @default(CUSTOMER) @map("tenant_type")

  // 契約情報
  subscriptionPlan  String?   @map("subscription_plan") @db.VarChar(100)
  contractStartDate DateTime? @map("contract_start_date")
  contractEndDate   DateTime? @map("contract_end_date")

  // 住所・連絡先
  postalCode String? @map("postal_code") @db.VarChar(20)
  address    String? @db.Text
  phone      String? @db.VarChar(50)
  email      String? @db.VarChar(255)
  website    String? @db.VarChar(255)

  // 設定
  defaultLanguage Language @default(JA) @map("default_language")
  defaultCurrency Currency @default(JPY) @map("default_currency")
  timezone        String   @default("Asia/Tokyo") @db.VarChar(50)

  // ステータス
  status CompanyStatus @default(ACTIVE)

  // タイムスタンプ
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // リレーション（後で追加されます）
  users     User[]
  auditLogs AuditLog[]

  @@index([tenantType])
  @@index([status])
  @@map("companies")
}

enum TenantType {
  MASTER_ADMIN // shunya（マスター管理者）
  CUSTOMER // 通常テナント
  TRIAL // トライアル
}

enum CompanyStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

// =====================================================
// ユーザー管理
// =====================================================

/// システムユーザー
model User {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  // 認証情報
  email         String    @unique @db.VarChar(255)
  emailVerified DateTime? @map("email_verified")
  passwordHash  String    @map("password_hash") @db.VarChar(255)

  // プロフィール
  firstName   String  @map("first_name") @db.VarChar(100)
  lastName    String  @map("last_name") @db.VarChar(100)
  displayName String? @map("display_name") @db.VarChar(200)
  avatarUrl   String? @map("avatar_url") @db.VarChar(500)

  // 連絡先
  phone String? @db.VarChar(50)

  // 設定
  language Language @default(JA)
  timezone String   @default("Asia/Tokyo") @db.VarChar(50)

  // 権限
  role           UserRole @default(STAFF)
  isExternalUser Boolean  @default(false) @map("is_external_user") // true = クライアント・取引先のユーザー

  // ステータス
  status      UserStatus @default(ACTIVE)
  lastLoginAt DateTime?  @map("last_login_at")

  // セキュリティ
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until")
  passwordChangedAt   DateTime? @map("password_changed_at")

  // タイムスタンプ
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // リレーション
  company      Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  loginHistory UserLoginHistory[]
  auditLogs    AuditLog[]
  sessions     Session[]

  @@index([companyId, role])
  @@index([companyId, status])
  @@index([email])
  @@map("users")
}

enum UserRole {
  OWNER // オーナー（全権限）
  ADMIN // 管理者
  PRODUCTION // 生産管理
  ACCOUNTING // 経理
  SALES // 営業
  DESIGNER // デザイナー
  STAFF // 一般スタッフ
  EXTERNAL // 外部ユーザー（クライアント・取引先）
}

enum UserStatus {
  ACTIVE
  INVITED // 招待済み・未承諾
  SUSPENDED
  ARCHIVED
}

enum Language {
  JA // 日本語
  EN // 英語
  ZH // 中国語（簡体字）
  VI // ベトナム語
}

enum Currency {
  JPY
  USD
  CNY
  VND
  EUR
}

/// ログイン履歴
model UserLoginHistory {
  id     String @id @default(uuid())
  userId String @map("user_id")

  loginAt   DateTime @default(now()) @map("login_at")
  ipAddress String?  @map("ip_address") @db.VarChar(50)
  userAgent String?  @map("user_agent") @db.Text

  success    Boolean
  failReason String? @map("fail_reason") @db.VarChar(255)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, loginAt])
  @@map("user_login_history")
}

/// セッション管理
model Session {
  id     String @id @default(uuid())
  userId String @map("user_id")

  refreshToken String   @unique @map("refresh_token")
  expiresAt    DateTime @map("expires_at")

  ipAddress String? @map("ip_address") @db.VarChar(50)
  userAgent String? @map("user_agent") @db.Text

  createdAt  DateTime @default(now()) @map("created_at")
  lastUsedAt DateTime @default(now()) @map("last_used_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

// =====================================================
// 監査ログ
// =====================================================

/// 監査ログ（重要操作の完全記録）
model AuditLog {
  id        String  @id @default(uuid())
  companyId String  @map("company_id")
  userId    String? @map("user_id")

  // 操作情報
  action     AuditAction
  entityType String      @map("entity_type") @db.VarChar(100) // products, quotations, etc.
  entityId   String?     @map("entity_id") @db.VarChar(255)

  // 変更内容
  beforeData Json? @map("before_data")
  afterData  Json? @map("after_data")

  // メタデータ
  ipAddress   String? @map("ip_address") @db.VarChar(50)
  userAgent   String? @map("user_agent") @db.Text
  description String? @db.Text

  // マスター管理者特権アクセス（shunyaが他テナントを見た場合）
  isPrivilegedAccess Boolean @default(false) @map("is_privileged_access")
  accessedTenantId   String? @map("accessed_tenant_id")
  accessReason       String? @map("access_reason") @db.Text
  customerConsent    Boolean @default(false) @map("customer_consent")

  createdAt DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id])
  user    User?   @relation(fields: [userId], references: [id])

  @@index([companyId, createdAt])
  @@index([entityType, entityId])
  @@index([userId])
  @@index([isPrivilegedAccess])
  @@map("audit_logs")
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  READ // 機密データの閲覧
  EXPORT // データのエクスポート
  LOGIN
  LOGOUT
  APPROVE
  REJECT
  STATUS_CHANGE
  PRIVILEGED_ACCESS // マスター管理者の特権アクセス
}

