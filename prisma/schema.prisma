/// メール添付ファイル
model EmailAttachment {
  id             String @id @default(uuid())
  emailMessageId String @map("email_message_id")

  // ファイル情報
  fileName String  @map("file_name") @db.VarChar(255)
  fileType String? @map("file_type") @db.VarChar(50)
  fileSize BigInt? @map("file_size")
  mimeType String? @map("mime_type") @db.VarChar(100)

  // ストレージ
  fileUrl         String               @map("file_url") @db.VarChar(500)
  storageLocation AssetStorageLocation @default(SYSTEM_R2) @map("storage_location")

  // ダウンロード元
  downloadedAt DateTime? @map("downloaded_at")

  // AI分析
  aiContentType   String? @map("ai_content_type") @db.VarChar(100)
  // invoice / po / pattern_file / spec_sheet / payment_receipt / etc.
  aiExtractedData Json?   @map("ai_extracted_data")

  // 関連エンティティへの紐付け
  attachedToType String? @map("attached_to_type") @db.VarChar(50)
  attachedToId   String? @map("attached_to_id") @db.VarChar(255)

  // Google Drive 連動
  driveUploadedAt DateTime? @map("drive_uploaded_at")
  driveFileUrl    String?   @map("drive_file_url") @db.VarChar(500)

  // タイムスタンプ
  createdAt DateTime @default(now()) @map("created_at")

  // リレーション
  emailMessage EmailMessage @relation(fields: [emailMessageId], references: [id], onDelete: Cascade)

  @@index([emailMessageId])
  @@index([attachedToType, attachedToId])
  @@map("email_attachments")
}

/// メールAI振り分けログ（仕様書H：3段階フィルタリング）
model EmailClassificationLog {
  id             String @id @default(uuid())
  emailMessageId String @map("email_message_id")

  // 処理レベル
  processingLevel Int @map("processing_level") // 1, 2, 3
  // 1: ローカルルール / 2: Haiku / 3: Sonnet

  // 処理方法
  classificationMethod ClassificationMethod @map("classification_method")

  // モデル情報
  modelUsed String? @map("model_used") @db.VarChar(100)
  // claude-haiku-4-5 / claude-sonnet-4-5 / etc.

  // 入力
  inputData Json? @map("input_data")

  // 結果
  classificationResult EmailClassification? @map("classification_result")
  confidence           Decimal?             @db.Decimal(5, 4)
  reasoning            String?              @db.Text

  // コスト
  tokensUsed   Int?     @map("tokens_used")
  costAmount   Decimal? @map("cost_amount") @db.Decimal(10, 6)
  costCurrency Currency @default(USD) @map("cost_currency")

  // 処理時間
  processingTimeMs Int? @map("processing_time_ms")

  // エラー
  hasError     Boolean @default(false) @map("has_error")
  errorMessage String? @map("error_message") @db.Text

  // タイムスタンプ
  processedAt DateTime @default(now()) @map("processed_at")

  // リレーション
  emailMessage EmailMessage @relation(fields: [emailMessageId], references: [id], onDelete: Cascade)

  @@index([emailMessageId, processingLevel])
  @@index([processedAt])
  @@map("email_classification_logs")
}

enum ClassificationMethod {
  LOCAL_RULE // ローカルルール（コストゼロ）
  AI_HAIKU // Claude Haiku（軽量）
  AI_SONNET // Claude Sonnet（深い解析）
  AI_OPUS // Claude Opus（最高精度、現状未使用）
  MANUAL // 手動分類
  HYBRID // 複数方法の組み合わせ
}

