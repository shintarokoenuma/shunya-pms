  salesTaxAmount10     Decimal? @map("sales_tax_amount_10") @db.Decimal(15, 2)
  salesTaxableAmount8  Decimal? @map("sales_taxable_amount_8") @db.Decimal(15, 2)
  salesTaxAmount8      Decimal? @map("sales_tax_amount_8") @db.Decimal(15, 2)
  salesExemptAmount    Decimal? @map("sales_exempt_amount") @db.Decimal(15, 2)
  totalSalesTax        Decimal? @map("total_sales_tax") @db.Decimal(15, 2)

  // 仕入の税額（仕入税額控除）
  qualifiedPurchaseAmount10        Decimal? @map("qualified_purchase_amount_10") @db.Decimal(15, 2)
  qualifiedPurchaseTax10           Decimal? @map("qualified_purchase_tax_10") @db.Decimal(15, 2)
  unqualifiedPurchaseAmount        Decimal? @map("unqualified_purchase_amount") @db.Decimal(15, 2)
  unqualifiedPurchaseTaxDeductible Decimal? @map("unqualified_purchase_tax_deductible") @db.Decimal(15, 2)
  transitionMeasurePercent         Decimal? @map("transition_measure_percent") @db.Decimal(5, 2)
  totalPurchaseTaxDeductible       Decimal? @map("total_purchase_tax_deductible") @db.Decimal(15, 2)

  // 納付税額
  taxPayableAmount Decimal? @map("tax_payable_amount") @db.Decimal(15, 2)

  // 詳細データ
  detailsJson Json? @map("details_json")

  // ステータス
  status String @default("DRAFT") @db.VarChar(20)

  // 確定情報
  finalizedAt       DateTime? @map("finalized_at")
